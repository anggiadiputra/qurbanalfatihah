    <div class="section-header">
      <div class="section-title">Input & Kelola Data</div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-outline btn-sm" onclick="resetAll()">Reset Semua</button>
      </div>
    </div>

    <div class="form-grid">
      <!-- Karkas & ABF -->
      <div class="form-card">
        <div class="form-card-title">Karkas & ABF</div>
        <div class="form-group"><label class="form-label">Total Karkas (keseluruhan)</label><input type="number" class="form-input" id="inp-total-karkas" placeholder="contoh: 150" min="0"></div>
        <div class="form-group"><label class="form-label">Karkas Keluar ABF</label><input type="number" class="form-input" id="inp-abf-keluar" placeholder="contoh: 120" min="0"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Mulai ABF</label><input type="time" class="form-input" id="inp-abf-mulai"></div>
          <div class="form-group"><label class="form-label">Selesai ABF</label><input type="time" class="form-input" id="inp-abf-selesai"></div>
        </div>
        <div class="btn-group"><button class="btn btn-success" onclick="saveABF()">Simpan ABF</button></div>
      </div>

      <!-- Pencacahan per Meja -->
      <div class="form-card" style="grid-column:1/-1">
        <div class="form-card-title">Pencacahan — Per Meja (6 Meja)</div>
        <div style="overflow-x:auto">
          <table style="width:100%;border-collapse:collapse;margin-bottom:14px">
            <thead><tr>
              <th style="background:var(--surface2);border:1px solid var(--border);padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--text2);text-align:left;width:90px">Meja</th>
              <th style="background:var(--surface2);border:1px solid var(--border);padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--text2);text-align:left">Jumlah Karkas</th>
              <th style="background:var(--surface2);border:1px solid var(--border);padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--text2);text-align:left">Waktu Mulai</th>
              <th style="background:var(--surface2);border:1px solid var(--border);padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--text2);text-align:left">Waktu Selesai</th>
              <th style="background:var(--surface2);border:1px solid var(--border);padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--text2);text-align:left;width:100px">Durasi</th>
            </tr></thead>
            <tbody id="meja-tbody"></tbody>
          </table>
        </div>
        <div style="display:flex;align-items:center;gap:16px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 16px;margin-bottom:14px;flex-wrap:wrap">
          <div style="font-size:12px;color:var(--text2);font-weight:600">Total Cacah Semua Meja:</div>
          <div style="font-size:20px;font-weight:800;font-family:var(--mono);color:var(--orange)" id="meja-total-display">0</div>
          <div style="font-size:12px;color:var(--text3)">karkas</div>
        </div>
        <div class="btn-group">
          <button class="btn btn-success" onclick="saveCacah()">Simpan Pencacahan</button>
          <button class="btn btn-outline btn-sm" onclick="resetMeja()">Reset Meja</button>
        </div>
      </div>

      <!-- Packing -->
      <div class="form-card">
        <div class="form-card-title">Packing</div>
        <div class="form-group"><label class="form-label">Total Packing Box</label><input type="number" class="form-input" id="inp-pack-box" placeholder="contoh: 80" min="0"></div>
        <div class="form-group"><label class="form-label">Total Packing Pack</label><input type="number" class="form-input" id="inp-pack-pack" placeholder="contoh: 200" min="0"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Mulai Packing</label><input type="time" class="form-input" id="inp-pack-mulai"></div>
          <div class="form-group"><label class="form-label">Selesai Packing</label><input type="time" class="form-input" id="inp-pack-selesai"></div>
        </div>
        <div class="btn-group"><button class="btn btn-success" onclick="savePacking()">Simpan Packing</button></div>
      </div>

      <!-- Waktu Keseluruhan -->
      <div class="form-card">
        <div class="form-card-title">Waktu & Info Keseluruhan</div>
        <div class="form-group"><label class="form-label">Tanggal Qurban Day 2</label><input type="date" class="form-input" id="inp-tanggal"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Jam Mulai Proses</label><input type="time" class="form-input" id="inp-mulai"></div>
          <div class="form-group"><label class="form-label">Jam Selesai Proses</label><input type="time" class="form-input" id="inp-selesai"></div>
        </div>
        <div class="btn-group"><button class="btn btn-success" onclick="saveInfo()">Simpan Info</button></div>
      </div>
    </div>

    <!-- Distribusi Input -->
    <div class="form-card" style="margin-top:20px">
      <div class="form-card-title">Input Distribusi</div>
      <div class="form-row" style="margin-bottom:12px">
        <div class="form-group"><label class="form-label">Mulai Distribusi</label><input type="time" class="form-input" id="inp-dist-mulai"></div>
        <div class="form-group"><label class="form-label">Selesai Distribusi</label><input type="time" class="form-input" id="inp-dist-selesai"></div>
      </div>
      <div class="form-card-title" style="font-size:13px;margin-bottom:10px">Daftar Lokasi Distribusi</div>
      <div id="distrib-inputs"></div>
      <div class="btn-group">
        <button class="btn btn-outline btn-sm" onclick="addDistribRow()">+ Tambah Lokasi</button>
        <button class="btn btn-success" onclick="saveDistrib()">Simpan Distribusi</button>
      </div>
    </div>
  </div>

</main>
</div>

<!-- NOTIFICATION -->
<div class="notif" id="notif">
  <div class="notif-icon" id="notif-icon">&#x2705;</div>
  <div id="notif-msg">Data berhasil disimpan!</div>
</div>

<script is:inline>
// ================================================================
// DATA STORE
// ================================================================
let data = {
  totalKarkas: 0,
  abfKeluar: 0,
  abfMulai: '', abfSelesai: '',
  cacah: 0,
  cacahMulai: '', cacahSelesai: '',
  mejaCacah: Array.from({length:6},(_,i)=>({nama:'Meja '+(i+1),jumlah:0,mulai:'',selesai:''})),
  packBox: 0, packPack: 0,
  packMulai: '', packSelesai: '',
  distribMulai: '', distribSelesai: '',
  tanggal: '',
  mulai: '', selesai: '',
  distribusi: []
};

let isSaving = false;
let pendingSave = false;

// ================================================================
// API CALLS
// ================================================================
async function loadStateFromAPI() {
  try {
    const res = await fetch('/api/day2-state');
    if (res.ok) {
      const d = await res.json();
      if (d && typeof d === 'object' && d.totalKarkas !== undefined) {
        data = d;
        if (!data.mejaCacah || data.mejaCacah.length === 0) {
          data.mejaCacah = Array.from({length:6},(_,i)=>({nama:'Meja '+(i+1),jumlah:0,mulai:'',selesai:''}));
        }
        if (!data.distribusi) data.distribusi = [];
      }
    }
  } catch(e) {
    console.warn('Failed to load Day 2 state from API');
  }
}

async function saveStateToAPI() {
  if (isSaving) { pendingSave = true; return; }
  isSaving = true;
  showSaveIndicator(true);
  try {
    const res = await fetch('/api/day2-state', {
      method: 'PATCH',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify(data)
    });
    if (!res.ok) throw new Error('Save failed');
  } catch(e) {
    showNotif('Gagal menyimpan data', 'error');
  } finally {
    isSaving = false;
    showSaveIndicator(false);
    if (pendingSave) { pendingSave = false; saveStateToAPI(); }
  }
}

function showSaveIndicator(show) {
  const el = document.getElementById('saveIndicator');
  if (el) el.classList.toggle('visible', show);
}

// ================================================================
// SIDEBAR NAVIGATION
// ================================================================
function showPage(page, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  if (el) el.classList.add('active');
  const titles = {
    dashboard: 'Dashboard Utama', abf: 'ABF / Karkas',
    pencacahan: 'Pencacahan', packing: 'Packing',
    distribusi: 'Distribusi', input: 'Input Data'
  };
  document.getElementById('topbar-title').textContent = titles[page] || page;
  updateAll();
  if (page === 'input') fillInputFields();
}

function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('collapsed');
}

// ================================================================
// DARK MODE
// ================================================================
function toggleDark() {
  document.body.classList.toggle('dark');
  localStorage.setItem('qurban_day2_dark', document.body.classList.contains('dark') ? '1' : '0');
}

// ================================================================
// CLOCK
// ================================================================
function updateClock() {
  const now = new Date();
  const wib = new Date(now.toLocaleString('en-US', { timeZone: 'Asia/Jakarta' }));
  const h = String(wib.getHours()).padStart(2, '0');
  const m = String(wib.getMinutes()).padStart(2, '0');
  const s = String(wib.getSeconds()).padStart(2, '0');
  const timeStr = h+':'+m+':'+s;
  const dateStr = wib.toLocaleDateString('id-ID', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
  document.getElementById('sidebar-clock').textContent = timeStr;
  document.getElementById('sidebar-date').textContent = dateStr;
  const jamEl = document.getElementById('d-jam-wib');
  if (jamEl) jamEl.textContent = timeStr;
}

// ================================================================
// DURATION CALC
// ================================================================
function calcDuration(mulai, selesai) {
  if (!mulai || !selesai) return '—';
  const [h1, m1] = mulai.split(':').map(Number);
  const [h2, m2] = selesai.split(':').map(Number);
  let total = (h2 * 60 + m2) - (h1 * 60 + m1);
  if (total < 0) total += 1440;
  const hh = Math.floor(total / 60), mm = total % 60;
  return hh+'j '+mm+'m';
}

// ================================================================
// UPDATE ALL
// ================================================================
function updateAll() {
  const d = data;
  const total = d.totalKarkas || 0;
  const abf = d.abfKeluar || 0;
  const cacah = d.cacah || 0;
  const box = d.packBox || 0;
  const pack = d.packPack || 0;
  const packTotal = box + pack;
  const distribList = d.distribusi || [];
  const distribSelesai = distribList.filter(function(x){return x.status === 'selesai'}).length;
  const distribProses = distribList.filter(function(x){return x.status === 'proses'}).length;
  const distribTotal = distribList.length;

  const pctABF = total > 0 ? Math.min(100, Math.round(abf / total * 100)) : 0;
  const pctCacah = total > 0 ? Math.min(100, Math.round(cacah / total * 100)) : 0;
  const pctPack = cacah > 0 ? Math.min(100, Math.round(packTotal / cacah * 100)) : 0;
  const pctDist = distribTotal > 0 ? Math.min(100, Math.round(distribSelesai / distribTotal * 100)) : 0;
  const overall = Math.round((pctABF + pctCacah + pctPack + pctDist) / 4);

  setText('d-total-karkas', total);
  setText('d-abf-keluar', abf);
  setText('d-sisa-karkas', Math.max(0, total - abf));
  setText('d-cacah', cacah);
  setText('d-packing', packTotal);
  setText('d-distrib', distribSelesai);
  setText('d-overall-pct', overall + '%');
  setText('d-mulai', d.mulai || '—');
  setText('d-selesai', d.selesai || '—');
  setText('d-tanggal', d.tanggal || '—');
  setText('d-total-durasi', calcDuration(d.mulai, d.selesai));

  setBar('bar-abf', pctABF); setText('pct-abf', pctABF + '%');
  setText('info-abf', abf+' dari '+total+' karkas');
  setBar('bar-cacah', pctCacah); setText('pct-cacah', pctCacah + '%');
  setText('info-cacah', cacah+' dari '+total+' karkas');
  setBar('bar-pack', pctPack); setText('pct-pack', pctPack + '%');
  setText('info-pack', box+' box, '+pack+' pack');
  setBar('bar-dist', pctDist); setText('pct-dist', pctDist + '%');
  setText('info-dist', distribSelesai+' dari '+distribTotal+' lokasi');

  setBarH('chart-abf', pctABF); setBarH('chart-cacah', pctCacah);
  setBarH('chart-pack', pctPack); setBarH('chart-dist', pctDist);

  updateTimeline(pctABF, pctCacah, pctPack, pctDist, abf, cacah, packTotal, distribSelesai);

  setText('abf-total', total); setText('abf-keluar', abf);
  setText('abf-sisa', Math.max(0, total - abf)); setText('abf-pct', pctABF + '%');
  setBar('abf-bar', pctABF); setText('abf-bar-pct', pctABF + '%');
  setText('abf-bar-info', abf+' dari '+total+' karkas diambil');
  setText('abf-mulai', d.abfMulai || '—'); setText('abf-selesai', d.abfSelesai || '—');
  setText('abf-durasi', calcDuration(d.abfMulai, d.abfSelesai));

  setText('cac-total', cacah); setText('cac-sisa', Math.max(0, total - cacah));
  setText('cac-pct', pctCacah + '%');
  setBar('cac-bar', pctCacah); setText('cac-bar-pct', pctCacah + '%');
  setText('cac-bar-info', cacah+' dari '+total+' karkas');
  setText('cac-mulai', d.cacahMulai || '—'); setText('cac-selesai', d.cacahSelesai || '—');
  setText('cac-durasi', calcDuration(d.cacahMulai, d.cacahSelesai));
  setBarH('cac-chart1', total > 0 ? cacah / total * 100 : 0);
  setBarH('cac-chart2', total > 0 ? Math.max(0, total - cacah) / total * 100 : 0);

  setText('pack-box', box); setText('pack-pack', pack);
  setText('pack-total', packTotal); setText('pack-pct', pctPack + '%');
  setBar('pack-bar1', cacah > 0 ? Math.min(100, box / cacah * 100) : 0);
  setText('pack-bar-pct1', cacah > 0 ? Math.round(box/cacah*100) + '%' : '0%');
  setText('pack-bar-info1', box+' box');
  setBar('pack-bar2', cacah > 0 ? Math.min(100, pack / cacah * 100) : 0);
  setText('pack-bar-pct2', cacah > 0 ? Math.round(pack/cacah*100) + '%' : '0%');
  setText('pack-bar-info2', pack+' pack');
  var maxPack = Math.max(box, pack, 1);
  setBarH('pack-chart1', box / maxPack * 100); setBarH('pack-chart2', pack / maxPack * 100);
  setText('pack-mulai', d.packMulai || '—'); setText('pack-selesai', d.packSelesai || '—');
  setText('pack-durasi', calcDuration(d.packMulai, d.packSelesai));

  setText('dist-selesai', distribSelesai); setText('dist-proses', distribProses);
  setText('dist-total-loc', distribTotal); setText('dist-pct', pctDist + '%');
  setBar('dist-bar', pctDist); setText('dist-bar-pct', pctDist + '%');
  setText('dist-bar-info', distribSelesai+' dari '+distribTotal+' lokasi');
  setText('dist-mulai', d.distribMulai || '—');
  setText('dist-selesai-time', d.distribSelesai || '—');
  setText('dist-durasi', calcDuration(d.distribMulai, d.distribSelesai));
  renderDistribTable(distribList);

  var badge = document.getElementById('distrib-badge');
  if (badge) badge.textContent = distribTotal;

  var now = new Date();
  document.getElementById('last-refresh').textContent = String(now.getHours()).padStart(2,'0')+':'+String(now.getMinutes()).padStart(2,'0')+':'+String(now.getSeconds()).padStart(2,'0');
}

function updateTimeline(pABF, pCacah, pPack, pDist, abf, cacah, pack, dist) {
  var steps = [
    { id: 'tl-abf', val: abf, pct: pABF, time: data.abfMulai, valId: 'tl-abf-val', timeId: 'tl-abf-time' },
    { id: 'tl-cacah', val: cacah, pct: pCacah, time: data.cacahMulai, valId: 'tl-cacah-val', timeId: 'tl-cacah-time' },
    { id: 'tl-pack', val: pack, pct: pPack, time: data.packMulai, valId: 'tl-pack-val', timeId: 'tl-pack-time' },
    { id: 'tl-dist', val: dist, pct: pDist, time: data.distribMulai, valId: 'tl-dist-val', timeId: 'tl-dist-time' }
  ];
  steps.forEach(function(s) {
    var el = document.getElementById(s.id);
    if (!el) return;
    el.classList.remove('done', 'active');
    if (s.pct >= 100) el.classList.add('done');
    else if (s.pct > 0) el.classList.add('active');
    setText(s.valId, s.val);
    setText(s.timeId, s.time || '—');
  });
}

function setText(id, val) { var el = document.getElementById(id); if (el) el.textContent = val; }
function setBar(id, pct) { var el = document.getElementById(id); if (el) el.style.width = Math.min(100, pct) + '%'; }
function setBarH(id, pct) { var el = document.getElementById(id); if (el) el.style.height = Math.min(100, Math.max(4, pct)) + '%'; }

// ================================================================
// RENDER DISTRIBUSI TABLE
// ================================================================
function renderDistribTable(list) {
  var tbody = document.getElementById('distrib-tbody');
  if (!tbody) return;
  if (!list || list.length === 0) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--text3);padding:30px">Belum ada data distribusi</td></tr>';
    return;
  }
  tbody.innerHTML = list.map(function(item, i) {
    return '<tr>'+
      '<td class="font-mono" style="color:var(--text3)">'+String(i + 1).padStart(2, '0')+'</td>'+
      '<td><strong>'+(item.nama || '—')+'</strong></td>'+
      '<td class="font-mono fw-700">'+(item.jumlah || 0)+'</td>'+
      '<td><span class="badge '+(item.status === 'selesai' ? 'badge-done' : item.status === 'proses' ? 'badge-process' : 'badge-wait')+'">'+
      (item.status === 'selesai' ? 'Selesai' : item.status === 'proses' ? 'Proses' : 'Menunggu')+'</span></td>'+
      '<td style="color:var(--text3);font-size:12px">'+(item.catatan || '—')+'</td></tr>';
  }).join('');
}

// ================================================================
// DISTRIBUSI INPUT ROWS
// ================================================================
function addDistribRow(item) {
  if (!item) data.distribusi.push({ nama: '', jumlah: 0, status: 'proses', catatan: '' });
  renderDistribInputs();
}
function renderDistribInputs() {
  var c = document.getElementById('distrib-inputs');
  if (!c) return;
  var list = data.distribusi;
  if (!list || list.length === 0) { c.innerHTML = '<p style="color:var(--text3);font-size:12px;margin-bottom:12px">Belum ada lokasi. Klik "+ Tambah Lokasi".</p>'; return; }
  c.innerHTML = list.map(function(item, i) {
    return '<div class="distrib-item">'+
      '<span style="font-size:12px;color:var(--text3);min-width:22px">'+(i + 1)+'.</span>'+
      '<input type="text" class="form-input" placeholder="Nama lokasi / alamat" value="'+(item.nama || '')+'" style="flex:2;min-width:150px" onchange="updateDistribRow('+i+',\'nama\',this.value)">'+
      '<input type="number" class="form-input" placeholder="Jumlah" value="'+(item.jumlah || '')+'" style="width:80px" onchange="updateDistribRow('+i+',\'jumlah\',this.value)">'+
      '<select class="form-input" style="width:120px" onchange="updateDistribRow('+i+',\'status\',this.value)">'+
      '<option value="proses" '+(item.status==='proses'?'selected':'')+'>Proses</option>'+
      '<option value="selesai" '+(item.status==='selesai'?'selected':'')+'>Selesai</option>'+
      '<option value="menunggu" '+(item.status==='menunggu'?'selected':'')+'>Menunggu</option>'+
      '</select>'+
      '<input type="text" class="form-input" placeholder="Catatan" value="'+(item.catatan || '')+'" style="flex:1;min-width:100px" onchange="updateDistribRow('+i+',\'catatan\',this.value)">'+
      '<button class="distrib-remove" onclick="removeDistribRow('+i+')">&#x2715;</button></div>';
  }).join('');
}
function updateDistribRow(i, field, val) {
  if (data.distribusi[i]) data.distribusi[i][field] = field === 'jumlah' ? Number(val) : val;
}
function removeDistribRow(i) {
  data.distribusi.splice(i, 1);
  renderDistribInputs();
}

// ================================================================
// FILL INPUT FIELDS
// ================================================================
function fillInputFields() {
  var d = data;
  setVal('inp-total-karkas', d.totalKarkas);
  setVal('inp-abf-keluar', d.abfKeluar);
  setVal('inp-abf-mulai', d.abfMulai);
  setVal('inp-abf-selesai', d.abfSelesai);
  renderMejaTable();
  setVal('inp-pack-box', d.packBox);
  setVal('inp-pack-pack', d.packPack);
  setVal('inp-pack-mulai', d.packMulai);
  setVal('inp-pack-selesai', d.packSelesai);
  setVal('inp-dist-mulai', d.distribMulai);
  setVal('inp-dist-selesai', d.distribSelesai);
  setVal('inp-tanggal', d.tanggal);
  setVal('inp-mulai', d.mulai);
  setVal('inp-selesai', d.selesai);
  renderDistribInputs();
}
function setVal(id, val) { var el = document.getElementById(id); if (el && val !== undefined && val !== null) el.value = val; }
function getVal(id) { var el = document.getElementById(id); return el ? el.value : ''; }
function getNum(id) { return Number(getVal(id)) || 0; }

// ================================================================
// SAVE FUNCTIONS
// ================================================================
function saveABF() {
  var total = getNum('inp-total-karkas'), keluar = getNum('inp-abf-keluar');
  if (total === 0) { showNotif('Total karkas tidak boleh 0!', 'error'); return; }
  if (keluar > total) { showNotif('Karkas keluar melebihi total!', 'error'); return; }
  data.totalKarkas = total; data.abfKeluar = keluar;
  data.abfMulai = getVal('inp-abf-mulai'); data.abfSelesai = getVal('inp-abf-selesai');
  saveStateToAPI(); updateAll(); showNotif('Data ABF berhasil disimpan!', 'success');
}
function saveCacah() {
  var totalCacah = 0;
  var earliestMulai = '', latestSelesai = '';
  data.mejaCacah.forEach(function(m, i) {
    var jumlah = Number(document.getElementById('meja-jumlah-' + i)?.value) || 0;
    var mulai  = document.getElementById('meja-mulai-'  + i)?.value || '';
    var selesai= document.getElementById('meja-selesai-'+ i)?.value || '';
    data.mejaCacah[i].jumlah  = jumlah;
    data.mejaCacah[i].mulai   = mulai;
    data.mejaCacah[i].selesai = selesai;
    totalCacah += jumlah;
    if (mulai  && (!earliestMulai  || mulai  < earliestMulai )) earliestMulai  = mulai;
    if (selesai&& (!latestSelesai  || selesai> latestSelesai)) latestSelesai  = selesai;
  });
  if (data.totalKarkas > 0 && totalCacah > data.totalKarkas) {
    showNotif('Total cacah melebihi total karkas!', 'error'); return;
  }
  data.cacah = totalCacah;
  data.cacahMulai = earliestMulai;
  data.cacahSelesai = latestSelesai;
  renderMejaTable();
  saveStateToAPI(); updateAll(); showNotif('Data Pencacahan berhasil disimpan!', 'success');
}
function resetMeja() {
  data.mejaCacah = Array.from({length:6},function(_,i){return {nama:'Meja '+(i+1),jumlah:0,mulai:'',selesai:''}});
  data.cacah=0; data.cacahMulai=''; data.cacahSelesai='';
  renderMejaTable(); saveStateToAPI(); updateAll();
  showNotif('Data meja direset!','success');
}
function renderMejaTable() {
  var tbody = document.getElementById('meja-tbody');
  if (!tbody) return;
  if (!data.mejaCacah || data.mejaCacah.length === 0) {
    data.mejaCacah = Array.from({length:6},function(_,i){return {nama:'Meja '+(i+1),jumlah:0,mulai:'',selesai:''}});
  }
  tbody.innerHTML = data.mejaCacah.map(function(m, i) {
    var dur = calcDuration(m.mulai, m.selesai);
    return '<tr>'+
      '<td style="border:1px solid var(--border);padding:8px 12px;font-weight:700;font-size:13px;background:var(--surface2)">'+
      '<span style="display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;background:var(--orange-light);color:var(--orange);border-radius:8px;font-weight:800;font-size:12px">'+(i+1)+'</span>'+
      '&nbsp;'+m.nama+'</td>'+
      '<td style="border:1px solid var(--border);padding:6px 10px"><input type="number" id="meja-jumlah-'+i+'" class="form-input" value="'+(m.jumlah||'')+'" placeholder="0" min="0" style="width:90px;padding:7px 10px" oninput="updateMejaDurasi('+i+')"></td>'+
      '<td style="border:1px solid var(--border);padding:6px 10px"><input type="time" id="meja-mulai-'+i+'" class="form-input" value="'+(m.mulai||'')+'" style="width:120px;padding:7px 10px" oninput="updateMejaDurasi('+i+')"></td>'+
      '<td style="border:1px solid var(--border);padding:6px 10px"><input type="time" id="meja-selesai-'+i+'" class="form-input" value="'+(m.selesai||'')+'" style="width:120px;padding:7px 10px" oninput="updateMejaDurasi('+i+')"></td>'+
      '<td style="border:1px solid var(--border);padding:8px 12px;font-family:var(--mono);font-weight:700;font-size:13px;color:'+(dur!=='—'?'var(--green)':'var(--text3)')+'" id="meja-durasi-'+i+'">'+dur+'</td></tr>';
  }).join('');
  updateMejaTotalDisplay();
}
function updateMejaDurasi(i) {
  var mulai   = document.getElementById('meja-mulai-'  + i)?.value || '';
  var selesai = document.getElementById('meja-selesai-'+ i)?.value || '';
  var dur = calcDuration(mulai, selesai);
  var el = document.getElementById('meja-durasi-' + i);
  if (el) { el.textContent = dur; el.style.color = dur !== '—' ? 'var(--green)' : 'var(--text3)'; }
  updateMejaTotalDisplay();
}
function updateMejaTotalDisplay() {
  var total = 0;
  if (!data.mejaCacah) return;
  data.mejaCacah.forEach(function(_, i) {
    total += Number(document.getElementById('meja-jumlah-' + i)?.value) || 0;
  });
  var el = document.getElementById('meja-total-display');
  if (el) el.textContent = total;
}
function savePacking() {
  data.packBox = getNum('inp-pack-box'); data.packPack = getNum('inp-pack-pack');
  data.packMulai = getVal('inp-pack-mulai'); data.packSelesai = getVal('inp-pack-selesai');
  saveStateToAPI(); updateAll(); showNotif('Data Packing berhasil disimpan!', 'success');
}
function saveInfo() {
  data.tanggal = getVal('inp-tanggal'); data.mulai = getVal('inp-mulai'); data.selesai = getVal('inp-selesai');
  saveStateToAPI(); updateAll(); showNotif('Info waktu berhasil disimpan!', 'success');
}
function saveDistrib() {
  data.distribMulai = getVal('inp-dist-mulai'); data.distribSelesai = getVal('inp-dist-selesai');
  saveStateToAPI(); updateAll(); showNotif('Data Distribusi berhasil disimpan!', 'success');
}

// ================================================================
// NOTIFICATION
// ================================================================
var notifTimer;
function showNotif(msg, type) {
  type = type || 'success';
  var el = document.getElementById('notif');
  var icon = document.getElementById('notif-icon');
  var msgEl = document.getElementById('notif-msg');
  icon.textContent = type === 'success' ? '✅' : '⚠️';
  msgEl.textContent = msg;
  el.className = 'notif show ' + type;
  clearTimeout(notifTimer);
  notifTimer = setTimeout(function(){ el.classList.remove('show'); }, 3000);
}

// ================================================================
// EXPORT CSV
// ================================================================
function exportCSV() {
  var d = data;
  var rows = [
    ['Qurban Day 2 — Laporan Monitoring', '', ''],
    ['Tanggal', d.tanggal, ''],
    ['', '', ''],
    ['KARKAS & ABF', '', ''],
    ['Total Karkas', d.totalKarkas, ''],
    ['Karkas Keluar ABF', d.abfKeluar, ''],
    ['Sisa di ABF', Math.max(0, d.totalKarkas - d.abfKeluar), ''],
    ['Waktu ABF', d.abfMulai + ' - ' + d.abfSelesai, ''],
    ['', '', ''],
    ['PENCACAHAN', '', ''],
    ['Total Dicacah', d.cacah, ''],
    ['Waktu Cacah', d.cacahMulai + ' - ' + d.cacahSelesai, ''],
    ['', '', ''],
    ['PACKING', '', ''],
    ['Total Box', d.packBox, ''],
    ['Total Pack', d.packPack, ''],
    ['Total Packing', d.packBox + d.packPack, ''],
    ['', '', ''],
    ['DISTRIBUSI', '', ''],
    ['No', 'Lokasi', 'Jumlah', 'Status']
  ];
  (d.distribusi||[]).forEach(function(x, i) { rows.push([i + 1, x.nama, x.jumlah, x.status]); });
  var csv = rows.map(function(r){ return r.join(','); }).join('\n');
  var blob = new Blob(['﻿' + csv], { type: 'text/csv;charset=utf-8;' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a'); a.href = url;
  a.download = 'Qurban_Day2_'+(d.tanggal || 'laporan')+'.csv';
  a.click(); URL.revokeObjectURL(url);
  showNotif('File CSV berhasil diunduh!', 'success');
}

// ================================================================
// RESET
// ================================================================
function resetAll() {
  if (!confirm('Reset semua data? Tindakan ini tidak bisa dibatalkan.')) return;
  data = {
    totalKarkas: 0, abfKeluar: 0, abfMulai: '', abfSelesai: '',
    cacah: 0, cacahMulai: '', cacahSelesai: '',
    mejaCacah: Array.from({length:6},function(_,i){return {nama:'Meja '+(i+1),jumlah:0,mulai:'',selesai:''}}),
    packBox: 0, packPack: 0, packMulai: '', packSelesai: '',
    distribMulai: '', distribSelesai: '', tanggal: '', mulai: '', selesai: '',
    distribusi: []
  };
  saveStateToAPI(); updateAll(); fillInputFields();
  showNotif('Semua data berhasil direset!', 'success');
}

// ================================================================
// AUTO REFRESH
// ================================================================
function startAutoRefresh() {
  setInterval(async function() {
    await loadStateFromAPI();
    updateAll();
  }, 30000);
  setInterval(updateClock, 1000);
}

// ================================================================
// INIT
// ================================================================
document.addEventListener('DOMContentLoaded', async function() {
  if (localStorage.getItem('qurban_day2_dark') === '1') document.body.classList.add('dark');
  await loadStateFromAPI();
  updateAll();
  renderDistribInputs();
  renderMejaTable();
  startAutoRefresh();
  updateClock();
  setTimeout(updateAll, 100);
});
</script>
</body>
</html>
