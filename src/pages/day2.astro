---
import { COOKIE_NAME, getRole } from '../lib/auth';
const auth = Astro.cookies.get(COOKIE_NAME)?.value;
const role = getRole(auth) || 'viewer';
---
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Qurban Day 2 — Command Center | Yayasan Al-Fatihah</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&family=Poppins:wght@300;400;500;600;700;800&family=Roboto:wght@300;400;500;700&family=Nunito:wght@300;400;500;600;700;800&family=Open+Sans:wght@300;400;500;600;700&family=Lato:wght@300;400;700&family=Montserrat:wght@300;400;500;600;700;800&family=Raleway:wght@300;400;500;600;700;800&family=Source+Sans+3:wght@300;400;500;600;700&family=Quicksand:wght@300;400;500;600;700&family=Cabin:wght@400;500;600;700&family=Ubuntu:wght@300;400;500;700&family=Rubik:wght@300;400;500;600;700&family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style is:global>
:root {
  --bg: #f0f2f5;
  --surface: #ffffff;
  --surface2: #f8f9fc;
  --border: #e8eaf0;
  --text: #1a1d2e;
  --text2: #6b7280;
  --text3: #9ca3af;
  --sidebar-bg: #0f1117;
  --sidebar-hover: rgba(255,255,255,0.06);
  --blue: #1e6af5;
  --blue-light: #dbeafe;
  --blue-dark: #1a5ce0;
  --green: #10b981;
  --green-light: #d1fae5;
  --orange: #f97316;
  --orange-light: #ffedd5;
  --maroon: #9b1c1c;
  --maroon-light: #fee2e2;
  --yellow: #f59e0b;
  --yellow-light: #fef3c7;
  --purple: #7c3aed;
  --purple-light: #ede9fe;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
  --shadow: 0 4px 16px rgba(0,0,0,0.08);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.12);
  --radius: 14px;
  --radius-sm: 8px;
  --font: 'Plus Jakarta Sans', sans-serif;
  --mono: 'JetBrains Mono', monospace;
  --sidebar-w: 240px;
  --sidebar-collapsed: 68px;
  --transition: 0.22s cubic-bezier(0.4,0,0.2,1);
}
.dark {
  --bg: #0b0d14;
  --surface: #13151f;
  --surface2: #1a1d2e;
  --border: #252836;
  --text: #f0f2f8;
  --text2: #9ca3b8;
  --text3: #6b7280;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.3);
  --shadow: 0 4px 16px rgba(0,0,0,0.4);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.5);
  --blue-light: rgba(30,106,245,0.15);
  --green-light: rgba(16,185,129,0.12);
  --orange-light: rgba(249,115,22,0.12);
  --maroon-light: rgba(155,28,28,0.15);
  --yellow-light: rgba(245,158,11,0.12);
  --purple-light: rgba(124,58,237,0.12);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--bg);color:var(--text);transition:background var(--transition),color var(--transition);min-height:100vh;overflow-x:hidden}
button{cursor:pointer;font-family:var(--font)}
input,select,textarea{font-family:var(--font)}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px}

.layout{display:flex;min-height:100vh}

/* SIDEBAR */
.sidebar{width:var(--sidebar-w);min-height:100vh;background:var(--sidebar-bg);display:flex;flex-direction:column;position:fixed;left:0;top:0;z-index:100;transition:width var(--transition);overflow:hidden}
.sidebar.collapsed{width:var(--sidebar-collapsed)}
.sidebar-logo{padding:20px 18px 16px;display:flex;align-items:center;gap:12px;border-bottom:1px solid rgba(255,255,255,0.07);min-height:68px}
.logo-icon{width:36px;height:36px;background:linear-gradient(135deg,#1e6af5,#7c3aed);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.logo-text{color:#fff;font-weight:800;font-size:13px;line-height:1.3;white-space:nowrap;overflow:hidden}
.logo-text span{display:block;color:rgba(255,255,255,0.45);font-weight:400;font-size:11px;margin-top:1px}
.sidebar-nav{flex:1;padding:12px 10px;overflow-y:auto;overflow-x:hidden}
.nav-section{margin-bottom:20px}
.nav-label{font-size:10px;font-weight:600;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.1em;padding:0 8px;margin-bottom:6px;white-space:nowrap;overflow:hidden}
.nav-item{display:flex;align-items:center;gap:12px;padding:10px;border-radius:10px;color:rgba(255,255,255,0.55);cursor:pointer;transition:all var(--transition);margin-bottom:2px;white-space:nowrap;position:relative;text-decoration:none}
.nav-item:hover{background:var(--sidebar-hover);color:rgba(255,255,255,0.85)}
.nav-item.active{background:rgba(30,106,245,0.18);color:#fff}
.nav-item.active::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:60%;background:var(--blue);border-radius:0 3px 3px 0}
.nav-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;transition:background var(--transition)}
.nav-item.active .nav-icon{background:rgba(30,106,245,0.25)}
.nav-text{font-size:13px;font-weight:500;overflow:hidden;transition:opacity var(--transition)}
.sidebar.collapsed .nav-text,.sidebar.collapsed .nav-label,.sidebar.collapsed .logo-text{opacity:0;pointer-events:none}
.nav-badge{margin-left:auto;background:var(--blue);color:#fff;font-size:10px;font-weight:700;padding:2px 7px;border-radius:99px;white-space:nowrap}
.sidebar.collapsed .nav-badge{display:none}
.sidebar-footer{padding:12px 10px;border-top:1px solid rgba(255,255,255,0.07)}
.clock-widget{background:rgba(255,255,255,0.05);border-radius:10px;padding:10px 12px;text-align:center}
.clock-time{font-size:20px;font-weight:700;color:#fff;font-family:var(--mono);letter-spacing:0.05em}
.clock-date{font-size:11px;color:rgba(255,255,255,0.4);margin-top:3px}
.sidebar.collapsed .clock-widget{display:none}
.collapse-btn{width:100%;padding:10px;background:none;border:none;color:rgba(255,255,255,0.35);font-size:18px;display:flex;align-items:center;justify-content:center;border-radius:8px;transition:all var(--transition);margin-top:8px}
.collapse-btn:hover{background:var(--sidebar-hover);color:#fff}

/* MAIN */
.main{margin-left:var(--sidebar-w);flex:1;transition:margin-left var(--transition);min-height:100vh;display:flex;flex-direction:column}
.sidebar.collapsed ~ .main{margin-left:var(--sidebar-collapsed)}

/* TOPBAR */
.topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;box-shadow:var(--shadow-sm)}
.topbar-left{display:flex;align-items:center;gap:12px}
.page-title{font-size:18px;font-weight:700;color:var(--text)}
.page-subtitle{font-size:12px;color:var(--text2);margin-top:1px}
.live-badge{display:flex;align-items:center;gap:6px;background:var(--green-light);color:var(--green);font-size:11px;font-weight:700;padding:4px 10px;border-radius:99px;border:1px solid rgba(16,185,129,0.2)}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 1.4s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.8)}}
.topbar-right{display:flex;align-items:center;gap:10px}
.topbar-btn{width:38px;height:38px;background:var(--surface2);border:1px solid var(--border);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;transition:all var(--transition);position:relative}
.topbar-btn:hover{background:var(--blue);border-color:var(--blue);color:#fff;transform:translateY(-1px);box-shadow:0 4px 12px rgba(30,106,245,0.3)}
.role-badge{font-size:11px;font-weight:600;padding:4px 12px;border-radius:20px;white-space:nowrap}
.role-badge.editor{background:var(--green-light);color:#059669}
.role-badge.viewer{background:var(--blue-light);color:var(--blue)}

/* SAVE INDICATOR */
.save-indicator{position:fixed;top:12px;right:24px;z-index:200;background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:6px 14px;font-size:12px;font-weight:600;color:var(--blue);display:none;align-items:center;gap:8px;box-shadow:var(--shadow)}
.save-indicator.visible{display:flex}
.save-dot{width:6px;height:6px;border-radius:50%;background:var(--blue);animation:pulse 1s infinite}

/* AUTOSAVE BADGE */
.autosave-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:20px;font-size:12px;font-weight:600;color:#059669;background:var(--green-light);border:1px solid rgba(16,185,129,0.2)}
.dark .autosave-badge{background:rgba(16,185,129,.15);color:var(--green)}
.autosave-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}

/* PAGE */
.page{display:none;flex:1;padding:24px;animation:fadeIn 0.3s ease}
.page.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:10px}
.section-title{font-size:14px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:0.06em}
.page-actions{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

/* STAT CARDS */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:24px}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px;box-shadow:var(--shadow-sm);transition:all var(--transition);position:relative;overflow:hidden}
.stat-card:hover{transform:translateY(-3px);box-shadow:var(--shadow)}
.stat-card::before{content:'';position:absolute;top:0;right:0;width:80px;height:80px;border-radius:50%;opacity:0.07;transform:translate(20px,-20px)}
.stat-card.blue::before{background:var(--blue)}
.stat-card.green::before{background:var(--green)}
.stat-card.orange::before{background:var(--orange)}
.stat-card.maroon::before{background:var(--maroon)}
.stat-card.yellow::before{background:var(--yellow)}
.stat-card.purple::before{background:var(--purple)}
.stat-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:14px}
.blue .stat-icon{background:var(--blue-light);color:var(--blue)}
.green .stat-icon{background:var(--green-light);color:var(--green)}
.orange .stat-icon{background:var(--orange-light);color:var(--orange)}
.maroon .stat-icon{background:var(--maroon-light);color:var(--maroon)}
.yellow .stat-icon{background:var(--yellow-light);color:var(--yellow)}
.purple .stat-icon{background:var(--purple-light);color:var(--purple)}
.stat-value{font-size:28px;font-weight:800;font-family:var(--mono);line-height:1}
.stat-label{font-size:12px;color:var(--text2);margin-top:6px;font-weight:500}
.stat-sub{font-size:11px;color:var(--text3);margin-top:3px}

/* PROGRESS */
.progress-section{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:22px;box-shadow:var(--shadow-sm);margin-bottom:20px}
.progress-title{font-size:15px;font-weight:700;margin-bottom:18px}
.progress-item{margin-bottom:16px}
.progress-item:last-child{margin-bottom:0}
.progress-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.progress-label{font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px}
.progress-pct{font-family:var(--mono);font-size:13px;font-weight:700}
.progress-bar-bg{height:10px;background:var(--surface2);border-radius:99px;border:1px solid var(--border);overflow:hidden}
.progress-bar-fill{height:100%;border-radius:99px;transition:width 1s cubic-bezier(0.4,0,0.2,1);position:relative;overflow:hidden}
.progress-bar-fill::after{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);animation:shimmer 2s infinite}
@keyframes shimmer{to{left:200%}}
.progress-bar-fill.blue{background:linear-gradient(90deg,#1e6af5,#3b82f6)}
.progress-bar-fill.green{background:linear-gradient(90deg,#059669,#10b981)}
.progress-bar-fill.orange{background:linear-gradient(90deg,#ea580c,#f97316)}
.progress-bar-fill.maroon{background:linear-gradient(90deg,#7f1d1d,#9b1c1c)}
.progress-bar-fill.yellow{background:linear-gradient(90deg,#d97706,#f59e0b)}
.progress-info{display:flex;gap:16px;margin-top:5px}
.progress-info span{font-size:11px;color:var(--text3)}

/* TIMELINE */
.timeline-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:22px;box-shadow:var(--shadow-sm);margin-bottom:20px}
.timeline{display:flex;gap:0;overflow-x:auto;padding-bottom:8px}
.timeline-step{flex:1;min-width:120px;display:flex;flex-direction:column;align-items:center;position:relative}
.timeline-step:not(:last-child)::after{content:'';position:absolute;top:20px;left:50%;width:100%;height:3px;background:var(--border);z-index:0}
.timeline-step.done:not(:last-child)::after{background:var(--green)}
.timeline-step.active:not(:last-child)::after{background:linear-gradient(90deg,var(--blue),var(--border))}
.tl-node{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;z-index:1;position:relative;border:3px solid var(--border);background:var(--surface2);transition:all var(--transition)}
.timeline-step.done .tl-node{background:var(--green-light);border-color:var(--green);color:var(--green)}
.timeline-step.active .tl-node{background:var(--blue-light);border-color:var(--blue);color:var(--blue);animation:ring 2s infinite}
@keyframes ring{0%,100%{box-shadow:0 0 0 0 rgba(30,106,245,0.3)}50%{box-shadow:0 0 0 8px rgba(30,106,245,0)}}
.tl-label{font-size:11px;font-weight:600;margin-top:8px;text-align:center}
.tl-value{font-size:13px;font-weight:700;font-family:var(--mono);color:var(--text)}
.tl-time{font-size:10px;color:var(--text3);margin-top:2px}

/* TABLE */
.table-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow-sm)}
.table-header{padding:16px 20px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border)}
.table-title{font-size:14px;font-weight:700}
table{width:100%;border-collapse:collapse}
th{background:var(--surface2);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--text2);padding:12px 16px;text-align:left;border-bottom:1px solid var(--border)}
td{padding:12px 16px;font-size:13px;border-bottom:1px solid var(--border);transition:background var(--transition)}
tr:hover td{background:var(--surface2)}
tr:last-child td{border-bottom:none}
.badge{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:700;padding:4px 10px;border-radius:99px}
.badge-done{background:var(--green-light);color:var(--green)}
.badge-process{background:var(--blue-light);color:var(--blue)}
.badge-wait{background:var(--yellow-light);color:var(--yellow)}

/* TIME CARDS */
.time-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:20px}
.time-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px;box-shadow:var(--shadow-sm);display:flex;align-items:center;gap:14px}
.time-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.time-icon.blue{background:var(--blue-light)}
.time-icon.green{background:var(--green-light)}
.time-icon.orange{background:var(--orange-light)}
.time-label{font-size:11px;color:var(--text2);font-weight:500}
.time-value{font-size:15px;font-weight:700;font-family:var(--mono);margin-top:3px}

/* CHART */
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:22px;box-shadow:var(--shadow-sm)}
.chart-bars{display:flex;align-items:flex-end;gap:10px;height:100px;padding-top:10px}
.chart-bar-wrap{display:flex;flex-direction:column;align-items:center;flex:1;gap:6px}
.chart-bar{width:100%;border-radius:6px 6px 0 0;transition:height 1s cubic-bezier(0.4,0,0.2,1);min-height:4px}
.chart-bar-label{font-size:10px;color:var(--text3);font-weight:600;text-align:center}
.overview-grid{display:grid;grid-template-columns:2fr 1fr;gap:20px}

/* FORMS */
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px}
.form-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:22px;box-shadow:var(--shadow-sm)}
.form-card-title{font-size:14px;font-weight:700;margin-bottom:18px;display:flex;align-items:center;gap:8px}
.form-group{margin-bottom:14px}
.form-group:last-child{margin-bottom:0}
.form-label{font-size:12px;font-weight:600;color:var(--text2);margin-bottom:6px;display:block}
.form-input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-size:13px;font-family:var(--font);color:var(--text);transition:all var(--transition);outline:none}
.form-input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(30,106,245,0.12)}
.form-input::placeholder{color:var(--text3)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 20px;border-radius:var(--radius-sm);font-size:13px;font-weight:700;border:none;transition:all var(--transition);cursor:pointer}
.btn-primary{background:var(--blue);color:#fff}
.btn-primary:hover{background:var(--blue-dark);transform:translateY(-1px);box-shadow:0 4px 12px rgba(30,106,245,0.35)}
.btn-success{background:var(--green);color:#fff}
.btn-success:hover{background:#059669;transform:translateY(-1px)}
.btn-danger{background:var(--maroon);color:#fff}
.btn-danger:hover{background:#7f1d1d;transform:translateY(-1px)}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--text)}
.btn-outline:hover{background:var(--surface2)}
.btn-sm{padding:7px 14px;font-size:12px}
.btn-group{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px}

/* DISTRIB FORM */
.distrib-item{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin-bottom:10px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.distrib-item input{flex:1;min-width:120px}
.distrib-item select{width:130px}
.distrib-remove{background:var(--maroon-light);color:var(--maroon);border:none;border-radius:6px;padding:6px 10px;font-size:12px;cursor:pointer;flex-shrink:0;font-weight:700;transition:all var(--transition)}
.distrib-remove:hover{background:var(--maroon);color:#fff}

/* TOAST */
.toast-container{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px}
.toast{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 18px;box-shadow:var(--shadow-lg);display:flex;align-items:center;gap:10px;font-size:13px;font-weight:500;min-width:260px;animation:slideUp .3s ease;backdrop-filter:blur(10px)}
@keyframes slideUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.toast.success{border-left:3px solid var(--green)}
.toast.error{border-left:3px solid var(--maroon)}
.toast.info{border-left:3px solid var(--blue)}
.toast-icon{font-size:16px;flex-shrink:0}

/* SETTINGS */
.settings-row{display:flex;align-items:center;justify-content:space-between;padding:16px 0;border-bottom:1px solid var(--border)}
.settings-row:last-child{border-bottom:none}
.settings-label{font-size:13px;font-weight:600}
.settings-desc{font-size:12px;color:var(--text3);margin-top:3px}
.toggle-switch{width:44px;height:24px;background:var(--border);border-radius:12px;cursor:pointer;position:relative;transition:background var(--transition);border:none;flex-shrink:0}
.toggle-switch.on{background:var(--green)}
.toggle-switch::after{content:'';position:absolute;width:18px;height:18px;background:#fff;border-radius:50%;top:3px;left:3px;transition:left var(--transition);box-shadow:0 1px 4px rgba(0,0,0,.2)}
.toggle-switch.on::after{left:23px}
.color-picker{width:44px;height:34px;border:2px solid var(--border);border-radius:var(--radius-sm);padding:2px;cursor:pointer;background:var(--surface)}
.color-picker::-webkit-color-swatch-wrapper{padding:0}
.color-picker::-webkit-color-swatch{border:none;border-radius:4px}

/* MONITOR MODE */
html.monitoring,body.monitoring{height:100%;overflow:hidden}
.monitor-overlay{display:none;position:fixed;inset:0;z-index:500;background:var(--bg);flex-direction:column;overflow-y:auto;padding:24px 32px}
.monitor-overlay.visible{display:flex}
.monitor-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-shrink:0}
.monitor-header-left{display:flex;align-items:center;gap:16px}
.monitor-header-title{font-size:20px;font-weight:800}
.monitor-header-clock{font-family:var(--mono);font-size:18px;font-weight:700;color:var(--blue)}
.monitor-header-date{font-size:13px;color:var(--text2);font-weight:500}
.monitor-exit{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;transition:all var(--transition)}
.monitor-exit:hover{background:var(--blue);color:#fff;border-color:var(--blue)}
.monitor-stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-bottom:24px}
.monitor-stats-grid .stat-card{padding:24px}
.monitor-stats-grid .stat-value{font-size:36px}
.monitor-stats-grid .stat-label{font-size:14px}
.monitor-stats-grid .stat-icon{width:48px;height:48px;font-size:24px;margin-bottom:16px}
.monitor-timeline-section{margin-bottom:24px}
.monitor-bottom-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px}
.monitor-bottom-grid .progress-section{margin-bottom:0}
.monitor-distrib-section{margin-bottom:24px}
@media(min-width:1600px){
  .monitor-stats-grid{grid-template-columns:repeat(7,1fr)}
  .monitor-stats-grid .stat-value{font-size:42px}
  .monitor-stats-grid .stat-label{font-size:15px}
}
@media(min-width:2400px){
  .monitor-overlay{padding:40px 60px}
  .monitor-stats-grid .stat-card{padding:32px}
  .monitor-stats-grid .stat-value{font-size:54px}
  .monitor-stats-grid .stat-label{font-size:17px}
  .monitor-stats-grid .stat-icon{width:56px;height:56px;font-size:28px}
  .monitor-header-title{font-size:28px}
  .monitor-header-clock{font-size:24px}
}
@media(max-width:900px){.monitor-bottom-grid{grid-template-columns:1fr}}

.color-green{color:var(--green)}
.color-orange{color:var(--orange)}
.color-maroon{color:var(--maroon)}
.color-blue{color:var(--blue)}
.font-mono{font-family:var(--mono)}
.fw-700{font-weight:700}

body[data-role="viewer"] .editor-only{display:none!important}

@media(max-width:900px){.overview-grid{grid-template-columns:1fr}
  .monitor-slide .stat-value{font-size:6rem}
  .monitor-slide .stat-label{font-size:1.3rem}
}
@media(max-width:768px){
  .sidebar{width:var(--sidebar-collapsed)}
  .sidebar .nav-text,.sidebar .nav-label,.sidebar .logo-text,.sidebar .clock-widget{opacity:0;pointer-events:none}
  .main{margin-left:var(--sidebar-collapsed)}
  .page{padding:16px}
  .stats-grid{grid-template-columns:1fr 1fr}
  .topbar{padding:0 16px}
  .form-grid{grid-template-columns:1fr}
  .overview-grid{grid-template-columns:1fr}
}
@media(max-width:480px){
  .stats-grid{grid-template-columns:1fr}
  .form-row{grid-template-columns:1fr}
  .time-grid{grid-template-columns:1fr 1fr}
  .monitor-slide .stat-value{font-size:4rem}
}
@media print{
  .sidebar,.topbar,.save-indicator,.toast-container{display:none!important}
  .main{margin-left:0!important}
  .page.active{padding:16px}
}
</style>
</head>
<body data-role={role}>

<!-- Toast Container -->
<div class="toast-container" id="toastContainer"></div>

<!-- Monitor Overlay — Grid Dashboard -->
<div class="monitor-overlay" id="monitorOverlay">
  <div class="monitor-header">
    <div class="monitor-header-left">
      <div class="monitor-header-title">Qurban Day 2 — Command Center</div>
      <div class="live-badge"><div class="live-dot"></div> LIVE</div>
    </div>
    <div style="display:flex;align-items:center;gap:16px">
      <div class="monitor-header-date" id="monitorDate">—</div>
      <div class="monitor-header-clock" id="monitorClock">00:00:00</div>
      <button class="monitor-exit" id="monitorExitBtn">&#x2715; ESC</button>
    </div>
  </div>
  <div class="monitor-stats-grid" id="monitorStats"></div>
  <div class="monitor-timeline-section" id="monitorTimeline"></div>
  <div class="monitor-bottom-grid" id="monitorBottom"></div>
  <div class="monitor-distrib-section" id="monitorDistrib"></div>
</div>

<div class="layout">

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon">&#x1f411;</div>
    <div class="logo-text">Al-Fatihah<span>Qurban Day 2 Monitor</span></div>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section">
      <div class="nav-label">Monitoring</div>
      <div class="nav-item active" onclick="showPage('dashboard',this)"><div class="nav-icon">&#x1f4ca;</div><span class="nav-text">Dashboard Utama</span></div>
      <div class="nav-item" onclick="showPage('abf',this)"><div class="nav-icon">&#x1f9ca;</div><span class="nav-text">ABF / Karkas</span></div>
      <div class="nav-item" onclick="showPage('pencacahan',this)"><div class="nav-icon">&#x1f52a;</div><span class="nav-text">Pencacahan</span></div>
      <div class="nav-item" onclick="showPage('packing',this)"><div class="nav-icon">&#x1f4e6;</div><span class="nav-text">Packing</span></div>
      <div class="nav-item" onclick="showPage('distribusi',this)"><div class="nav-icon">&#x1f69a;</div><span class="nav-text">Distribusi</span><span class="nav-badge" id="distrib-badge">0</span></div>
    </div>
    <div class="nav-section">
      <div class="nav-label">Operasional</div>
      <div class="nav-item editor-only" onclick="showPage('input',this)"><div class="nav-icon">&#x270f;&#xfe0f;</div><span class="nav-text">Input Data</span></div>
      <div class="nav-item editor-only" onclick="showPage('pengaturan',this)"><div class="nav-icon">&#x2699;&#xfe0f;</div><span class="nav-text">Pengaturan</span></div>
    </div>
    <div class="nav-section">
      <div class="nav-label">Navigasi</div>
      <a class="nav-item" href="/"><div class="nav-icon">&#x1f3e0;</div><span class="nav-text">Day 1 Dashboard</span></a>
    </div>
  </nav>
  <div class="sidebar-footer">
    <div class="clock-widget"><div class="clock-time" id="sidebar-clock">00:00:00</div><div class="clock-date" id="sidebar-date">—</div></div>
    <button class="collapse-btn" onclick="toggleSidebar()">&#x21d4;</button>
  </div>
</aside>

<!-- MAIN -->
<main class="main" id="main">
  <div class="topbar">
    <div class="topbar-left">
      <div><div class="page-title" id="topbar-title">Dashboard Utama</div><div class="page-subtitle">Monitoring Realtime Qurban Day 2</div></div>
      <div class="live-badge"><div class="live-dot"></div> LIVE</div>
    </div>
    <div class="topbar-right">
      <span class={`role-badge ${role}`}>{role === 'editor' ? 'Editor' : 'Viewer'}</span>
      <button class="topbar-btn editor-only" onclick="toggleDark()" title="Dark Mode">&#x1f319;</button>
      <button class="topbar-btn" onclick="exportXLSX()" title="Export Excel">&#x1f4e5;</button>
      <button class="topbar-btn" onclick="window.print()" title="Print">&#x1f5a8;&#xfe0f;</button>
      <button class="topbar-btn" onclick="logoutUser()" title="Logout">&#x1f6aa;</button>
    </div>
  </div>

  <div class="save-indicator" id="saveIndicator"><div class="save-dot"></div><span>Menyimpan...</span></div>

  <!-- ============ PAGE: DASHBOARD ============ -->
  <div class="page active" id="page-dashboard">
    <div class="section-header">
      <div class="section-title">Ringkasan Keseluruhan</div>
      <div class="page-actions">
        <button class="btn btn-primary btn-sm" onclick="enterMonitorMode()">&#x1f4fa; Mode Monitor</button>
        <button class="btn btn-outline btn-sm" onclick="refreshData()">&#x21bb; Refresh</button>
        <button class="btn btn-outline btn-sm" onclick="exportXLSX()">&#x1f4e5; Export Excel</button>
      </div>
    </div>
    <div class="stats-grid" id="dash-stats"></div>
    <div class="timeline-card" style="margin-bottom:20px">
      <div class="table-header" style="border:none;padding:0 0 16px"><div class="table-title">Alur Proses Qurban Day 2</div></div>
      <div class="timeline" id="main-timeline">
        <div class="timeline-step active" id="tl-abf"><div class="tl-node">&#x1f9ca;</div><div class="tl-label">ABF Keluar</div><div class="tl-value" id="tl-abf-val">0</div><div class="tl-time" id="tl-abf-time">—</div></div>
        <div class="timeline-step" id="tl-cacah"><div class="tl-node">&#x1f52a;</div><div class="tl-label">Pencacahan</div><div class="tl-value" id="tl-cacah-val">0</div><div class="tl-time" id="tl-cacah-time">—</div></div>
        <div class="timeline-step" id="tl-pack"><div class="tl-node">&#x1f4e6;</div><div class="tl-label">Packing</div><div class="tl-value" id="tl-pack-val">0</div><div class="tl-time" id="tl-pack-time">—</div></div>
        <div class="timeline-step" id="tl-dist"><div class="tl-node">&#x1f69a;</div><div class="tl-label">Distribusi</div><div class="tl-value" id="tl-dist-val">0</div><div class="tl-time" id="tl-dist-time">—</div></div>
      </div>
    </div>
    <div class="overview-grid">
      <div class="progress-section" id="dash-progress"></div>
      <div class="chart-card">
        <div class="table-title" style="margin-bottom:16px">Statistik Visual</div>
        <div class="chart-bars">
          <div class="chart-bar-wrap"><div class="chart-bar" id="chart-abf" style="background:var(--green);height:4%"></div><div class="chart-bar-label">ABF</div></div>
          <div class="chart-bar-wrap"><div class="chart-bar" id="chart-cacah" style="background:var(--orange);height:4%"></div><div class="chart-bar-label">Cacah</div></div>
          <div class="chart-bar-wrap"><div class="chart-bar" id="chart-pack" style="background:var(--yellow);height:4%"></div><div class="chart-bar-label">Pack</div></div>
          <div class="chart-bar-wrap"><div class="chart-bar" id="chart-dist" style="background:var(--maroon);height:4%"></div><div class="chart-bar-label">Distrib</div></div>
        </div>
        <div style="margin-top:20px">
          <div class="time-card" style="background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px">
            <div class="time-icon blue">&#x23f1;&#xfe0f;</div>
            <div><div class="time-label">Durasi Keseluruhan</div><div class="time-value" id="d-total-durasi">—</div></div>
          </div>
        </div>
      </div>
    </div>
    <div style="margin-top:20px">
      <div class="section-title" style="margin-bottom:14px">Waktu Proses</div>
      <div class="time-grid">
        <div class="time-card"><div class="time-icon blue">&#x1f550;</div><div><div class="time-label">Waktu Mulai</div><div class="time-value" id="d-mulai">—</div></div></div>
        <div class="time-card"><div class="time-icon green">&#x1f554;</div><div><div class="time-label">Waktu Selesai</div><div class="time-value" id="d-selesai">—</div></div></div>
        <div class="time-card"><div class="time-icon orange">&#x1f4c5;</div><div><div class="time-label">Tanggal</div><div class="time-value font-mono" style="font-size:12px" id="d-tanggal">—</div></div></div>
        <div class="time-card"><div class="time-icon" style="background:var(--purple-light)">&#x1f550;</div><div><div class="time-label">Jam WIB Sekarang</div><div class="time-value" id="d-jam-wib">—</div></div></div>
      </div>
    </div>
  </div>

  <!-- ============ PAGE: ABF ============ -->
  <div class="page" id="page-abf">
    <div class="section-header"><div class="section-title">ABF / Cold Storage</div></div>
    <div class="stats-grid" id="abf-stats"></div>
    <div class="progress-section" id="abf-progress"></div>
    <div class="time-grid" id="abf-times"></div>
  </div>

  <!-- ============ PAGE: PENCACAHAN ============ -->
  <div class="page" id="page-pencacahan">
    <div class="section-header"><div class="section-title">Pencacahan Karkas</div></div>
    <div class="stats-grid" id="cac-stats"></div>
    <div class="overview-grid">
      <div class="progress-section" id="cac-progress"></div>
      <div class="chart-card"><div class="table-title" style="margin-bottom:12px">Rasio Cacah</div>
        <div class="chart-bars"><div class="chart-bar-wrap"><div class="chart-bar" id="cac-chart1" style="background:var(--orange);height:0%"></div><div class="chart-bar-label">Dicacah</div></div><div class="chart-bar-wrap"><div class="chart-bar" id="cac-chart2" style="background:var(--border);height:0%"></div><div class="chart-bar-label">Sisa</div></div></div>
      </div>
    </div>
    <div class="time-grid" style="margin-top:20px" id="cac-times"></div>
  </div>

  <!-- ============ PAGE: PACKING ============ -->
  <div class="page" id="page-packing">
    <div class="section-header"><div class="section-title">Packing</div></div>
    <div class="stats-grid" id="pack-stats"></div>
    <div class="overview-grid">
      <div class="progress-section" id="pack-progress"></div>
      <div class="chart-card"><div class="table-title" style="margin-bottom:12px">Komposisi Packing</div>
        <div class="chart-bars"><div class="chart-bar-wrap"><div class="chart-bar" id="pack-chart1" style="background:var(--yellow);height:0%"></div><div class="chart-bar-label">Box</div></div><div class="chart-bar-wrap"><div class="chart-bar" id="pack-chart2" style="background:var(--blue);height:0%"></div><div class="chart-bar-label">Pack</div></div></div>
      </div>
    </div>
    <div class="time-grid" style="margin-top:20px" id="pack-times"></div>
  </div>

  <!-- ============ PAGE: DISTRIBUSI ============ -->
  <div class="page" id="page-distribusi">
    <div class="section-header"><div class="section-title">Distribusi</div></div>
    <div class="stats-grid" id="dist-stats"></div>
    <div class="progress-section" id="dist-progress"></div>
    <div class="time-grid" style="margin-bottom:20px" id="dist-times"></div>
    <div class="table-card">
      <div class="table-header"><div class="table-title">Daftar Distribusi</div><div class="live-badge"><div class="live-dot"></div>Realtime</div></div>
      <div style="overflow-x:auto"><table><thead><tr><th>#</th><th>Nama Lokasi / Alamat</th><th>Jumlah</th><th>Status</th><th>Catatan</th></tr></thead><tbody id="distrib-tbody"><tr><td colspan="5" style="text-align:center;color:var(--text3);padding:30px">Belum ada data distribusi</td></tr></tbody></table></div>
    </div>
  </div>

  <!-- ============ PAGE: INPUT DATA ============ -->
  <div class="page editor-only" id="page-input">
    <div class="section-header">
      <div class="section-title">Input & Kelola Data</div>
      <div class="page-actions">
        <span class="autosave-badge"><span class="autosave-dot"></span> Auto-save aktif</span>
        <button class="btn btn-outline btn-sm editor-only" onclick="resetAll()">Reset Semua</button>
      </div>
    </div>
    <div class="form-grid">
      <div class="form-card">
        <div class="form-card-title">Karkas & ABF</div>
        <div class="form-group"><label class="form-label">Total Karkas (keseluruhan)</label><input type="number" class="form-input" id="inp-total-karkas" placeholder="contoh: 150" min="0"></div>
        <div class="form-group"><label class="form-label">Karkas Keluar ABF</label><input type="number" class="form-input" id="inp-abf-keluar" placeholder="contoh: 120" min="0"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Mulai ABF</label><input type="time" class="form-input" id="inp-abf-mulai"></div>
          <div class="form-group"><label class="form-label">Selesai ABF</label><input type="time" class="form-input" id="inp-abf-selesai"></div>
        </div>
      </div>
      <div class="form-card" style="grid-column:1/-1">
        <div class="form-card-title">Pencacahan — Per Meja (6 Meja)</div>
        <div style="overflow-x:auto">
          <table style="width:100%;border-collapse:collapse;margin-bottom:14px">
            <thead><tr>
              <th style="background:var(--surface2);border:1px solid var(--border);padding:9px 12px;width:90px">Meja</th>
              <th style="background:var(--surface2);border:1px solid var(--border);padding:9px 12px">Jumlah Karkas</th>
              <th style="background:var(--surface2);border:1px solid var(--border);padding:9px 12px">Waktu Mulai</th>
              <th style="background:var(--surface2);border:1px solid var(--border);padding:9px 12px">Waktu Selesai</th>
              <th style="background:var(--surface2);border:1px solid var(--border);padding:9px 12px;width:100px">Durasi</th>
            </tr></thead>
            <tbody id="meja-tbody"></tbody>
          </table>
        </div>
        <div style="display:flex;align-items:center;gap:16px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 16px;flex-wrap:wrap">
          <div style="font-size:12px;color:var(--text2);font-weight:600">Total Cacah Semua Meja:</div>
          <div style="font-size:20px;font-weight:800;font-family:var(--mono);color:var(--orange)" id="meja-total-display">0</div>
          <div style="font-size:12px;color:var(--text3)">karkas</div>
        </div>
      </div>
      <div class="form-card">
        <div class="form-card-title">Packing</div>
        <div class="form-group"><label class="form-label">Total Packing Box</label><input type="number" class="form-input" id="inp-pack-box" placeholder="contoh: 80" min="0"></div>
        <div class="form-group"><label class="form-label">Total Packing Pack</label><input type="number" class="form-input" id="inp-pack-pack" placeholder="contoh: 200" min="0"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Mulai Packing</label><input type="time" class="form-input" id="inp-pack-mulai"></div>
          <div class="form-group"><label class="form-label">Selesai Packing</label><input type="time" class="form-input" id="inp-pack-selesai"></div>
        </div>
      </div>
      <div class="form-card">
        <div class="form-card-title">Waktu & Info Keseluruhan</div>
        <div class="form-group"><label class="form-label">Tanggal Qurban Day 2</label><input type="date" class="form-input" id="inp-tanggal"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Jam Mulai Proses</label><input type="time" class="form-input" id="inp-mulai"></div>
          <div class="form-group"><label class="form-label">Jam Selesai Proses</label><input type="time" class="form-input" id="inp-selesai"></div>
        </div>
      </div>
    </div>
    <div class="form-card" style="margin-top:20px">
      <div class="form-card-title">Input Distribusi</div>
      <div class="form-row" style="margin-bottom:12px">
        <div class="form-group"><label class="form-label">Mulai Distribusi</label><input type="time" class="form-input" id="inp-dist-mulai"></div>
        <div class="form-group"><label class="form-label">Selesai Distribusi</label><input type="time" class="form-input" id="inp-dist-selesai"></div>
      </div>
      <div class="form-card-title" style="font-size:13px;margin-bottom:10px">Daftar Lokasi Distribusi</div>
      <div id="distrib-inputs"></div>
      <div class="btn-group">
        <button class="btn btn-outline btn-sm" onclick="addDistribRow()">+ Tambah Lokasi</button>
        <button class="btn btn-success btn-sm" onclick="saveDistrib()">Simpan Distribusi</button>
      </div>
    </div>
  </div>

  <!-- ============ PAGE: PENGATURAN ============ -->
  <div class="page editor-only" id="page-pengaturan">
    <div class="section-header"><div class="section-title">Pengaturan</div></div>
    <div class="form-card" style="max-width:600px;margin-bottom:20px">
      <div style="font-weight:700;font-size:15px;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--border)">Tampilan</div>
      <div class="settings-row">
        <div><div class="settings-label">Font</div><div class="settings-desc">Pilih jenis huruf untuk seluruh tampilan</div></div>
        <select class="form-input" id="themeFont" style="width:180px">
          <option value="'Plus Jakarta Sans',sans-serif">Plus Jakarta Sans</option>
          <option value="'Inter',system-ui,sans-serif">Inter</option>
          <option value="'DM Sans',system-ui,sans-serif">DM Sans</option>
          <option value="'Poppins',system-ui,sans-serif">Poppins</option>
          <option value="'Roboto',system-ui,sans-serif">Roboto</option>
          <option value="'Nunito',system-ui,sans-serif">Nunito</option>
          <option value="'Open Sans',system-ui,sans-serif">Open Sans</option>
          <option value="'Lato',system-ui,sans-serif">Lato</option>
          <option value="'Montserrat',system-ui,sans-serif">Montserrat</option>
          <option value="'Raleway',system-ui,sans-serif">Raleway</option>
          <option value="'Source Sans 3',system-ui,sans-serif">Source Sans 3</option>
          <option value="'Quicksand',system-ui,sans-serif">Quicksand</option>
          <option value="'Cabin',system-ui,sans-serif">Cabin</option>
          <option value="'Ubuntu',system-ui,sans-serif">Ubuntu</option>
          <option value="'Rubik',system-ui,sans-serif">Rubik</option>
          <option value="'Lexend',system-ui,sans-serif">Lexend</option>
        </select>
      </div>
      <div class="settings-row"><div><div class="settings-label">Primary</div><div class="settings-desc">Warna utama (sidebar, tombol)</div></div><input type="color" class="color-picker" id="themeColorPrimary" value="#1e6af5"></div>
      <div class="settings-row"><div><div class="settings-label">Secondary</div><div class="settings-desc">Warna sekunder (progress, info)</div></div><input type="color" class="color-picker" id="themeColorSecondary" value="#10b981"></div>
      <div class="settings-row"><div><div class="settings-label">Accent</div><div class="settings-desc">Warna aksen (highlight)</div></div><input type="color" class="color-picker" id="themeColorAccent" value="#7c3aed"></div>
      <div class="settings-row"><div><div class="settings-label">Success</div><div class="settings-desc">Warna indikator waktu</div></div><input type="color" class="color-picker" id="themeColorSuccess" value="#f59e0b"></div>
      <div class="settings-row"><div><div class="settings-label">Danger</div><div class="settings-desc">Warna bahaya / distribusi</div></div><input type="color" class="color-picker" id="themeColorDanger" value="#9b1c1c"></div>
      <div style="margin-top:12px"><button class="btn btn-outline btn-sm" id="resetThemeBtn">Reset ke Default</button></div>
    </div>
    <div class="form-card" style="max-width:600px">
      <div style="font-weight:700;font-size:15px;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--border)">Sistem</div>
      <div class="settings-row"><div><div class="settings-label">Dark Mode</div><div class="settings-desc">Tampilan gelap</div></div><button class="toggle-switch" id="darkModeSwitch"></button></div>
      <div class="settings-row"><div><div class="settings-label">Auto Refresh</div><div class="settings-desc">Refresh data setiap 30 detik</div></div><button class="toggle-switch on" id="autoRefreshSwitch"></button></div>
      <div class="settings-row"><div><div class="settings-label">Export Excel</div><div class="settings-desc">Download semua data .xlsx</div></div><button class="btn btn-primary btn-sm" onclick="exportXLSX()">Download</button></div>
      <div class="settings-row editor-only"><div><div class="settings-label">Reset Semua Data</div><div class="settings-desc">Hapus seluruh data Day 2</div></div><button class="btn btn-danger btn-sm" onclick="resetAll()">Reset</button></div>
      <div class="settings-row"><div><div class="settings-label">Versi Sistem</div><div class="settings-desc">Qurban Day 2 Command Center</div></div><span style="font-size:12px;color:var(--text3);font-family:var(--mono)">v1.0.0</span></div>
    </div>
  </div>

</main>
</div>

<script is:inline>
// ================================================================
// STATE & SETTINGS
// ================================================================
var data = {totalKarkas:0,abfKeluar:0,abfMulai:'',abfSelesai:'',cacah:0,cacahMulai:'',cacahSelesai:'',mejaCacah:Array.from({length:6},function(_,i){return{nama:'Meja '+(i+1),jumlah:0,mulai:'',selesai:''}}),packBox:0,packPack:0,packMulai:'',packSelesai:'',distribMulai:'',distribSelesai:'',tanggal:'',mulai:'',selesai:'',distribusi:[]};
var settings = {darkMode:false, theme:{}, autoRefresh:true};

var isSaving=false, pendingSave=false, saveTimeout=null;
var isSettingsSaving=false, pendingSettingsSave=false, settingsSaveTimeout=null;
var autoRefreshInterval=null, autoRefreshEnabled=true;

var defaultTheme = {font:"'Plus Jakarta Sans',sans-serif",primary:'#1e6af5',secondary:'#10b981',accent:'#7c3aed',success:'#f59e0b',danger:'#9b1c1c'};

// ================================================================
// API
// ================================================================
async function loadStateFromAPI(){try{var r=await fetch('/api/day2-state');if(r.ok){var d=await r.json();if(d&&typeof d==='object'&&d.totalKarkas!==undefined){data=d;if(!data.mejaCacah||!data.mejaCacah.length)data.mejaCacah=Array.from({length:6},function(_,i){return{nama:'Meja '+(i+1),jumlah:0,mulai:'',selesai:''}});if(!data.distribusi)data.distribusi=[]}}}catch(e){console.warn('Failed to load Day 2 state')}}

async function saveStateToAPI(){if(isSaving){pendingSave=true;return}isSaving=true;showSaveIndicator(true);try{var r=await fetch('/api/day2-state',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});if(!r.ok)throw new Error()}catch(e){toast('Gagal menyimpan data','error')}finally{isSaving=false;showSaveIndicator(false);if(pendingSave){pendingSave=false;saveStateToAPI()}}}

async function loadSettingsFromAPI(){try{var r=await fetch('/api/day2-settings');if(r.ok){var d=await r.json();if(d&&typeof d==='object')settings=d}}catch(e){}}

async function saveSettingsToAPI(){if(isSettingsSaving){pendingSettingsSave=true;return}isSettingsSaving=true;try{await fetch('/api/day2-settings',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify(settings)})}catch(e){}finally{isSettingsSaving=false;if(pendingSettingsSave){pendingSettingsSave=false;saveSettingsToAPI()}}}

function queueSettingsSave(){if(settingsSaveTimeout)clearTimeout(settingsSaveTimeout);settingsSaveTimeout=setTimeout(saveSettingsToAPI,400)}

function showSaveIndicator(v){var el=document.getElementById('saveIndicator');if(el)el.classList.toggle('visible',v)}

// ================================================================
// AUTO-SAVE
// ================================================================
function collectFormData(){
  data.totalKarkas=getNum('inp-total-karkas');data.abfKeluar=getNum('inp-abf-keluar');
  data.abfMulai=getVal('inp-abf-mulai');data.abfSelesai=getVal('inp-abf-selesai');
  var totalCacah=0,eM='',lS='';
  data.mejaCacah.forEach(function(m,i){
    var j=Number(document.getElementById('meja-jumlah-'+i)?.value)||0;
    var ml=document.getElementById('meja-mulai-'+i)?.value||'';
    var sl=document.getElementById('meja-selesai-'+i)?.value||'';
    data.mejaCacah[i].jumlah=j;data.mejaCacah[i].mulai=ml;data.mejaCacah[i].selesai=sl;
    totalCacah+=j;
    if(ml&&(!eM||ml<eM))eM=ml;if(sl&&(!lS||sl>lS))lS=sl;
  });
  data.cacah=totalCacah;data.cacahMulai=eM;data.cacahSelesai=lS;
  data.packBox=getNum('inp-pack-box');data.packPack=getNum('inp-pack-pack');
  data.packMulai=getVal('inp-pack-mulai');data.packSelesai=getVal('inp-pack-selesai');
  data.tanggal=getVal('inp-tanggal');data.mulai=getVal('inp-mulai');data.selesai=getVal('inp-selesai');
  data.distribMulai=getVal('inp-dist-mulai');data.distribSelesai=getVal('inp-dist-selesai');
}

function queueSave(){if(saveTimeout)clearTimeout(saveTimeout);saveTimeout=setTimeout(function(){collectFormData();updateMejaTotalDisplay();renderAll();saveStateToAPI()},400)}

function setupAutoSave(){
  var page=document.getElementById('page-input');
  if(!page)return;
  page.addEventListener('input',function(e){if(e.target.classList.contains('form-input'))queueSave()});
  page.addEventListener('change',function(e){if(e.target.classList.contains('form-input'))queueSave()});
}

// ================================================================
// NAVIGATION
// ================================================================
function showPage(page,el){
  document.querySelectorAll('.page').forEach(function(p){p.classList.remove('active')});
  document.querySelectorAll('.nav-item').forEach(function(n){n.classList.remove('active')});
  document.getElementById('page-'+page).classList.add('active');
  if(el)el.classList.add('active');
  var titles={dashboard:'Dashboard Utama',abf:'ABF / Karkas',pencacahan:'Pencacahan',packing:'Packing',distribusi:'Distribusi',input:'Input Data',pengaturan:'Pengaturan'};
  document.getElementById('topbar-title').textContent=titles[page]||page;
  renderAll();
  if(page==='input')fillInputFields();
}

function toggleSidebar(){document.getElementById('sidebar').classList.toggle('collapsed')}

function logoutUser(){fetch('/api/login',{method:'DELETE'}).then(function(){window.location.href='/login'})}

// ================================================================
// DARK MODE
// ================================================================
function toggleDark(){
  document.body.classList.toggle('dark');
  settings.darkMode=document.body.classList.contains('dark');
  updateDarkUI();
  queueSettingsSave();
}
function updateDarkUI(){
  var on=document.body.classList.contains('dark');
  var sw=document.getElementById('darkModeSwitch');
  if(sw)sw.classList.toggle('on',on);
}

// ================================================================
// THEME
// ================================================================
function hexToHsl(hex){var r=parseInt(hex.slice(1,3),16)/255,g=parseInt(hex.slice(3,5),16)/255,b=parseInt(hex.slice(5,7),16)/255;var max=Math.max(r,g,b),min=Math.min(r,g,b),h=0,s=0,l=(max+min)/2;if(max!==min){var d=max-min;s=l>.5?d/(2-max-min):d/(max+min);if(max===r)h=((g-b)/d+(g<b?6:0))/6;else if(max===g)h=((b-r)/d+2)/6;else h=((r-g)/d+4)/6}return{h:Math.round(h*360),s:Math.round(s*100),l:Math.round(l*100)}}
function colorVariant(hex,lighten){var c=hexToHsl(hex);var nl=Math.max(0,Math.min(100,c.l+lighten));return'hsl('+c.h+','+c.s+'%,'+nl+'%)'}

function loadTheme(){return Object.assign({},defaultTheme,settings.theme||{})}

function applyTheme(theme){
  var root=document.documentElement;
  root.style.setProperty('--font',theme.font);document.body.style.fontFamily=theme.font;
  root.style.setProperty('--blue',theme.primary);root.style.setProperty('--blue-dark',colorVariant(theme.primary,-12));root.style.setProperty('--blue-light',colorVariant(theme.primary,40));
  root.style.setProperty('--green',theme.secondary);root.style.setProperty('--green-light',colorVariant(theme.secondary,40));
  root.style.setProperty('--purple',theme.accent);root.style.setProperty('--purple-light',colorVariant(theme.accent,40));
  root.style.setProperty('--yellow',theme.success);root.style.setProperty('--yellow-light',colorVariant(theme.success,40));
  root.style.setProperty('--maroon',theme.danger);root.style.setProperty('--maroon-light',colorVariant(theme.danger,40));
}

function saveTheme(theme){settings.theme=Object.assign({},theme);applyTheme(theme);queueSettingsSave()}

function setupThemeUI(){
  var theme=loadTheme();applyTheme(theme);
  var fontEl=document.getElementById('themeFont');
  if(fontEl){fontEl.value=theme.font;fontEl.addEventListener('change',function(){theme.font=fontEl.value;saveTheme(theme)})}
  var map={primary:'themeColorPrimary',secondary:'themeColorSecondary',accent:'themeColorAccent',success:'themeColorSuccess',danger:'themeColorDanger'};
  Object.keys(map).forEach(function(key){var el=document.getElementById(map[key]);if(el){el.value=theme[key];el.addEventListener('input',function(){theme[key]=el.value;saveTheme(theme)})}});
  var rb=document.getElementById('resetThemeBtn');
  if(rb)rb.addEventListener('click',function(){
    var def=Object.assign({},defaultTheme);saveTheme(def);
    if(fontEl)fontEl.value=def.font;
    Object.keys(map).forEach(function(key){var el=document.getElementById(map[key]);if(el)el.value=def[key]});
  });
}

// ================================================================
// CLOCK
// ================================================================
function updateClock(){
  var now=new Date();var wib=new Date(now.toLocaleString('en-US',{timeZone:'Asia/Jakarta'}));
  var h=String(wib.getHours()).padStart(2,'0'),m=String(wib.getMinutes()).padStart(2,'0'),s=String(wib.getSeconds()).padStart(2,'0');
  var timeStr=h+':'+m+':'+s;
  var dateStr=wib.toLocaleDateString('id-ID',{weekday:'short',day:'numeric',month:'short',year:'numeric'});
  document.getElementById('sidebar-clock').textContent=timeStr;
  document.getElementById('sidebar-date').textContent=dateStr;
  var j=document.getElementById('d-jam-wib');if(j)j.textContent=timeStr;
}

// ================================================================
// HELPERS
// ================================================================
function calcDuration(mulai,selesai){if(!mulai||!selesai)return'—';var p=mulai.split(':').map(Number),q=selesai.split(':').map(Number);var t=(q[0]*60+q[1])-(p[0]*60+p[1]);if(t<0)t+=1440;return Math.floor(t/60)+'j '+t%60+'m'}
function setText(id,v){var el=document.getElementById(id);if(el)el.textContent=v}
function setBar(id,p){var el=document.getElementById(id);if(el)el.style.width=Math.min(100,p)+'%'}
function setBarH(id,p){var el=document.getElementById(id);if(el)el.style.height=Math.min(100,Math.max(4,p))+'%'}
function setVal(id,v){var el=document.getElementById(id);if(el&&v!==undefined&&v!==null)el.value=v}
function getVal(id){var el=document.getElementById(id);return el?el.value:''}
function getNum(id){return Number(getVal(id))||0}

// ================================================================
// TOAST
// ================================================================
function toast(msg,type){
  type=type||'success';
  var icons={success:'&#x2705;',error:'&#x26a0;&#xfe0f;',info:'&#x2139;&#xfe0f;'};
  var c=document.getElementById('toastContainer');
  var t=document.createElement('div');t.className='toast '+type;
  t.innerHTML='<span class="toast-icon">'+icons[type]+'</span><span>'+msg+'</span>';
  c.appendChild(t);
  setTimeout(function(){t.style.opacity='0';t.style.transform='translateY(16px)';t.style.transition='all .3s';setTimeout(function(){t.remove()},300)},3000);
}

// ================================================================
// RENDER ALL
// ================================================================
function renderAll(){
  var d=data,total=d.totalKarkas||0,abf=d.abfKeluar||0,cacah=d.cacah||0,box=d.packBox||0,pack=d.packPack||0,packTotal=box+pack;
  var distribList=d.distribusi||[],distribSelesai=distribList.filter(function(x){return x.status==='selesai'}).length;
  var distribProses=distribList.filter(function(x){return x.status==='proses'}).length,distribTotal=distribList.length;
  var pA=total>0?Math.min(100,Math.round(abf/total*100)):0;
  var pC=total>0?Math.min(100,Math.round(cacah/total*100)):0;
  var pP=cacah>0?Math.min(100,Math.round(packTotal/cacah*100)):0;
  var pD=distribTotal>0?Math.min(100,Math.round(distribSelesai/distribTotal*100)):0;
  var overall=Math.round((pA+pC+pP+pD)/4);

  // Dashboard stats
  document.getElementById('dash-stats').innerHTML=
    sc('blue','&#x1f411;',total,'Total Karkas','Keseluruhan tersedia','color-blue')+
    sc('green','&#x1f9ca;',abf,'Keluar ABF','Sudah diambil dari cold storage','color-green')+
    sc('blue','&#x2744;&#xfe0f;',Math.max(0,total-abf),'Sisa Karkas di ABF','Total Karkas - Keluar ABF','color-blue')+
    sc('orange','&#x1f52a;',cacah,'Dicacah','Proses pencacahan selesai','color-orange')+
    sc('yellow','&#x1f4e6;',packTotal,'Dipacking','Total paket packing','','color:var(--yellow)')+
    sc('maroon','&#x1f69a;',distribSelesai,'Distribusi Selesai','Terkirim ke penerima','color-maroon')+
    sc('purple','&#x1f4c8;',overall+'%','Progress Keseluruhan','Dari ABF &rarr; Distribusi','','color:var(--purple)');

  // Dashboard progress
  document.getElementById('dash-progress').innerHTML='<div class="progress-title">Progress Per Proses</div>'+
    pb('green','ABF / Karkas Keluar',pA,abf+' dari '+total+' karkas')+
    pb('orange','Pencacahan',pC,cacah+' dari '+total+' karkas')+
    pb('yellow','Packing',pP,box+' box, '+pack+' pack')+
    pb('maroon','Distribusi',pD,distribSelesai+' dari '+distribTotal+' lokasi');

  setBarH('chart-abf',pA);setBarH('chart-cacah',pC);setBarH('chart-pack',pP);setBarH('chart-dist',pD);
  setText('d-total-durasi',calcDuration(d.mulai,d.selesai));
  setText('d-mulai',d.mulai||'—');setText('d-selesai',d.selesai||'—');setText('d-tanggal',d.tanggal||'—');

  // Timeline
  [{id:'tl-abf',val:abf,pct:pA,time:d.abfMulai,vId:'tl-abf-val',tId:'tl-abf-time'},
   {id:'tl-cacah',val:cacah,pct:pC,time:d.cacahMulai,vId:'tl-cacah-val',tId:'tl-cacah-time'},
   {id:'tl-pack',val:packTotal,pct:pP,time:d.packMulai,vId:'tl-pack-val',tId:'tl-pack-time'},
   {id:'tl-dist',val:distribSelesai,pct:pD,time:d.distribMulai,vId:'tl-dist-val',tId:'tl-dist-time'}
  ].forEach(function(s){var el=document.getElementById(s.id);if(!el)return;el.classList.remove('done','active');if(s.pct>=100)el.classList.add('done');else if(s.pct>0)el.classList.add('active');setText(s.vId,s.val);setText(s.tId,s.time||'—')});

  // ABF page
  document.getElementById('abf-stats').innerHTML=sc('blue','&#x1f411;',total,'Total Karkas Tersedia','Di cold storage / ABF','color-blue')+sc('green','&#x2705;',abf,'Karkas Diambil','Sudah keluar dari ABF','color-green')+sc('orange','&#x2744;&#xfe0f;',Math.max(0,total-abf),'Sisa di ABF','Belum diambil','color-orange')+sc('maroon','&#x1f4ca;',pA+'%','Progress ABF','Persentase pengambilan','color-maroon');
  document.getElementById('abf-progress').innerHTML='<div class="progress-title">Progress Pengambilan Karkas dari ABF</div>'+pb('green','Karkas Keluar ABF',pA,abf+' dari '+total+' karkas diambil');
  document.getElementById('abf-times').innerHTML=tc('blue','&#x1f550;','Mulai ABF',d.abfMulai)+tc('green','&#x1f554;','Selesai ABF',d.abfSelesai)+tc('orange','&#x23f1;&#xfe0f;','Durasi',calcDuration(d.abfMulai,d.abfSelesai));

  // Pencacahan page
  document.getElementById('cac-stats').innerHTML=sc('orange','&#x1f52a;',cacah,'Total Dicacah','Karkas selesai dicacah','color-orange')+sc('blue','&#x231b;',Math.max(0,total-cacah),'Sisa Karkas','Belum dicacah','color-blue')+sc('green','&#x1f4ca;',pC+'%','Progress','Pencacahan selesai','color-green');
  document.getElementById('cac-progress').innerHTML='<div class="progress-title">Progress Pencacahan</div>'+pb('orange','Pencacahan Karkas',pC,cacah+' dari '+total+' karkas');
  setBarH('cac-chart1',total>0?cacah/total*100:0);setBarH('cac-chart2',total>0?Math.max(0,total-cacah)/total*100:0);
  document.getElementById('cac-times').innerHTML=tc('orange','&#x1f550;','Mulai Pencacahan',d.cacahMulai)+tc('green','&#x1f554;','Selesai Pencacahan',d.cacahSelesai)+tc('blue','&#x23f1;&#xfe0f;','Durasi',calcDuration(d.cacahMulai,d.cacahSelesai));

  // Packing page
  var pB1=cacah>0?Math.min(100,Math.round(box/cacah*100)):0,pB2=cacah>0?Math.min(100,Math.round(pack/cacah*100)):0;
  document.getElementById('pack-stats').innerHTML=sc('yellow','&#x1f4e6;',box,'Total Box','Jumlah packing box','','color:var(--yellow)')+sc('blue','&#x1f6cd;&#xfe0f;',pack,'Total Pack','Jumlah packing pack','color-blue')+sc('green','&#x2705;',packTotal,'Total Packing Selesai','Box + Pack','color-green')+sc('maroon','&#x1f4ca;',pP+'%','Progress Packing','Dari total pencacahan','color-maroon');
  document.getElementById('pack-progress').innerHTML='<div class="progress-title">Progress Packing</div>'+pb('yellow','Packing Box',pB1,box+' box')+pb('blue','Packing Pack',pB2,pack+' pack');
  var mx=Math.max(box,pack,1);setBarH('pack-chart1',box/mx*100);setBarH('pack-chart2',pack/mx*100);
  document.getElementById('pack-times').innerHTML=tc('','&#x1f550;','Mulai Packing',d.packMulai,'background:var(--yellow-light)')+tc('green','&#x1f554;','Selesai Packing',d.packSelesai)+tc('blue','&#x23f1;&#xfe0f;','Durasi',calcDuration(d.packMulai,d.packSelesai));

  // Distribusi page
  document.getElementById('dist-stats').innerHTML=sc('green','&#x2705;',distribSelesai,'Distribusi Selesai','Lokasi terdistribusi','color-green')+sc('blue','&#x1f504;',distribProses,'Sedang Proses','Dalam perjalanan','color-blue')+sc('orange','&#x1f4cd;',distribTotal,'Total Lokasi','Semua titik distribusi','color-orange')+sc('maroon','&#x1f4ca;',pD+'%','Progress Distribusi','Persentase selesai','color-maroon');
  document.getElementById('dist-progress').innerHTML='<div class="progress-title">Progress Distribusi</div>'+pb('maroon','Lokasi Terkirim',pD,distribSelesai+' dari '+distribTotal+' lokasi');
  document.getElementById('dist-times').innerHTML=tc('','&#x1f550;','Mulai Distribusi',d.distribMulai,'background:var(--maroon-light)')+tc('green','&#x1f554;','Selesai Distribusi',d.distribSelesai)+tc('blue','&#x23f1;&#xfe0f;','Durasi',calcDuration(d.distribMulai,d.distribSelesai));
  renderDistribTable(distribList);

  var badge=document.getElementById('distrib-badge');if(badge)badge.textContent=distribTotal;
}

// HTML builders
function sc(color,icon,val,label,sub,cls,style){return'<div class="stat-card '+color+'"><div class="stat-icon">'+icon+'</div><div class="stat-value '+(cls||'')+'" '+(style?'style="'+style+'"':'')+'>'+val+'</div><div class="stat-label">'+label+'</div><div class="stat-sub">'+sub+'</div></div>'}
function pb(color,label,pct,info){return'<div class="progress-item"><div class="progress-header"><div class="progress-label"><span style="color:var(--'+color+')">&#x25cf;</span> '+label+'</div><div class="progress-pct" style="color:var(--'+color+')">'+pct+'%</div></div><div class="progress-bar-bg"><div class="progress-bar-fill '+color+'" style="width:'+pct+'%"></div></div><div class="progress-info"><span>'+info+'</span></div></div>'}
function tc(color,icon,label,val,style){return'<div class="time-card"><div class="time-icon '+(color||'')+'" '+(style?'style="'+style+'"':'')+'>'+icon+'</div><div><div class="time-label">'+label+'</div><div class="time-value">'+(val||'—')+'</div></div></div>'}

// ================================================================
// DISTRIB TABLE
// ================================================================
function renderDistribTable(list){var tbody=document.getElementById('distrib-tbody');if(!tbody)return;if(!list||!list.length){tbody.innerHTML='<tr><td colspan="5" style="text-align:center;color:var(--text3);padding:30px">Belum ada data distribusi</td></tr>';return}tbody.innerHTML=list.map(function(item,i){return'<tr><td class="font-mono" style="color:var(--text3)">'+String(i+1).padStart(2,'0')+'</td><td><strong>'+(item.nama||'—')+'</strong></td><td class="font-mono fw-700">'+(item.jumlah||0)+'</td><td><span class="badge '+(item.status==='selesai'?'badge-done':item.status==='proses'?'badge-process':'badge-wait')+'">'+(item.status==='selesai'?'Selesai':item.status==='proses'?'Proses':'Menunggu')+'</span></td><td style="color:var(--text3);font-size:12px">'+(item.catatan||'—')+'</td></tr>'}).join('')}

// ================================================================
// DISTRIB INPUT
// ================================================================
function addDistribRow(){data.distribusi.push({nama:'',jumlah:0,status:'proses',catatan:''});renderDistribInputs()}
function renderDistribInputs(){var c=document.getElementById('distrib-inputs');if(!c)return;var list=data.distribusi;if(!list||!list.length){c.innerHTML='<p style="color:var(--text3);font-size:12px;margin-bottom:12px">Belum ada lokasi. Klik "+ Tambah Lokasi".</p>';return}c.innerHTML=list.map(function(item,i){return'<div class="distrib-item"><span style="font-size:12px;color:var(--text3);min-width:22px">'+(i+1)+'.</span><input type="text" class="form-input" placeholder="Nama lokasi" value="'+(item.nama||'')+'" style="flex:2;min-width:150px" onchange="updateDistribRow('+i+',\'nama\',this.value)"><input type="number" class="form-input" placeholder="Jumlah" value="'+(item.jumlah||'')+'" style="width:80px" onchange="updateDistribRow('+i+',\'jumlah\',this.value)"><select class="form-input" style="width:120px" onchange="updateDistribRow('+i+',\'status\',this.value)"><option value="proses" '+(item.status==='proses'?'selected':'')+'>Proses</option><option value="selesai" '+(item.status==='selesai'?'selected':'')+'>Selesai</option><option value="menunggu" '+(item.status==='menunggu'?'selected':'')+'>Menunggu</option></select><input type="text" class="form-input" placeholder="Catatan" value="'+(item.catatan||'')+'" style="flex:1;min-width:100px" onchange="updateDistribRow('+i+',\'catatan\',this.value)"><button class="distrib-remove" onclick="removeDistribRow('+i+')">&#x2715;</button></div>'}).join('')}
function updateDistribRow(i,f,v){if(data.distribusi[i])data.distribusi[i][f]=f==='jumlah'?Number(v):v}
function removeDistribRow(i){data.distribusi.splice(i,1);renderDistribInputs()}
function saveDistrib(){data.distribMulai=getVal('inp-dist-mulai');data.distribSelesai=getVal('inp-dist-selesai');saveStateToAPI();renderAll();toast('Data Distribusi disimpan','success')}

// ================================================================
// INPUT FORM
// ================================================================
function fillInputFields(){var d=data;setVal('inp-total-karkas',d.totalKarkas);setVal('inp-abf-keluar',d.abfKeluar);setVal('inp-abf-mulai',d.abfMulai);setVal('inp-abf-selesai',d.abfSelesai);renderMejaTable();setVal('inp-pack-box',d.packBox);setVal('inp-pack-pack',d.packPack);setVal('inp-pack-mulai',d.packMulai);setVal('inp-pack-selesai',d.packSelesai);setVal('inp-dist-mulai',d.distribMulai);setVal('inp-dist-selesai',d.distribSelesai);setVal('inp-tanggal',d.tanggal);setVal('inp-mulai',d.mulai);setVal('inp-selesai',d.selesai);renderDistribInputs()}

function renderMejaTable(){var tbody=document.getElementById('meja-tbody');if(!tbody)return;if(!data.mejaCacah||!data.mejaCacah.length)data.mejaCacah=Array.from({length:6},function(_,i){return{nama:'Meja '+(i+1),jumlah:0,mulai:'',selesai:''}});tbody.innerHTML=data.mejaCacah.map(function(m,i){var dur=calcDuration(m.mulai,m.selesai);return'<tr><td style="border:1px solid var(--border);padding:8px 12px;font-weight:700;font-size:13px;background:var(--surface2)"><span style="display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;background:var(--orange-light);color:var(--orange);border-radius:8px;font-weight:800;font-size:12px">'+(i+1)+'</span>&nbsp;'+m.nama+'</td><td style="border:1px solid var(--border);padding:6px 10px"><input type="number" id="meja-jumlah-'+i+'" class="form-input" value="'+(m.jumlah||'')+'" placeholder="0" min="0" style="width:90px;padding:7px 10px"></td><td style="border:1px solid var(--border);padding:6px 10px"><input type="time" id="meja-mulai-'+i+'" class="form-input" value="'+(m.mulai||'')+'" style="width:120px;padding:7px 10px"></td><td style="border:1px solid var(--border);padding:6px 10px"><input type="time" id="meja-selesai-'+i+'" class="form-input" value="'+(m.selesai||'')+'" style="width:120px;padding:7px 10px"></td><td style="border:1px solid var(--border);padding:8px 12px;font-family:var(--mono);font-weight:700;font-size:13px;color:'+(dur!=='—'?'var(--green)':'var(--text3)')+'" id="meja-durasi-'+i+'">'+dur+'</td></tr>'}).join('');updateMejaTotalDisplay()}

function updateMejaTotalDisplay(){var t=0;if(!data.mejaCacah)return;data.mejaCacah.forEach(function(_,i){t+=Number(document.getElementById('meja-jumlah-'+i)?.value)||0});var el=document.getElementById('meja-total-display');if(el)el.textContent=t}

// ================================================================
// MONITOR MODE — Grid Dashboard
// ================================================================
var monitorMode=false,monitorInterval2=null;

function renderMonitorDashboard(){
  var d=data,total=d.totalKarkas||0,abf=d.abfKeluar||0,cacah=d.cacah||0,box=d.packBox||0,pack=d.packPack||0,packTotal=box+pack;
  var distribList=d.distribusi||[],distribSelesai=distribList.filter(function(x){return x.status==='selesai'}).length;
  var distribProses=distribList.filter(function(x){return x.status==='proses'}).length,distribTotal=distribList.length;
  var pA=total>0?Math.min(100,Math.round(abf/total*100)):0;
  var pC=total>0?Math.min(100,Math.round(cacah/total*100)):0;
  var pP=cacah>0?Math.min(100,Math.round(packTotal/cacah*100)):0;
  var pD=distribTotal>0?Math.min(100,Math.round(distribSelesai/distribTotal*100)):0;
  var overall=Math.round((pA+pC+pP+pD)/4);

  // Stats grid
  document.getElementById('monitorStats').innerHTML=
    sc('blue','&#x1f411;',total,'Total Karkas','Keseluruhan tersedia','color-blue')+
    sc('green','&#x1f9ca;',abf,'Keluar ABF',pA+'% dari total','color-green')+
    sc('blue','&#x2744;&#xfe0f;',Math.max(0,total-abf),'Sisa di ABF','Belum diambil','color-blue')+
    sc('orange','&#x1f52a;',cacah,'Dicacah',pC+'% selesai','color-orange')+
    sc('yellow','&#x1f4e6;',packTotal,'Dipacking',box+' box, '+pack+' pack','','color:var(--yellow)')+
    sc('maroon','&#x1f69a;',distribSelesai,'Distribusi',pD+'% selesai','color-maroon')+
    sc('purple','&#x1f4c8;',overall+'%','Progress Total','ABF &rarr; Distribusi','','color:var(--purple)');

  // Timeline
  var tlSteps=[
    {pct:pA,icon:'&#x1f9ca;',label:'ABF Keluar',val:abf,time:d.abfMulai},
    {pct:pC,icon:'&#x1f52a;',label:'Pencacahan',val:cacah,time:d.cacahMulai},
    {pct:pP,icon:'&#x1f4e6;',label:'Packing',val:packTotal,time:d.packMulai},
    {pct:pD,icon:'&#x1f69a;',label:'Distribusi',val:distribSelesai,time:d.distribMulai}
  ];
  document.getElementById('monitorTimeline').innerHTML='<div class="timeline-card"><div class="table-header" style="border:none;padding:0 0 16px"><div class="table-title">Alur Proses</div><div style="font-family:var(--mono);font-size:13px;color:var(--text2)">Mulai: '+(d.mulai||'—')+' &mdash; Selesai: '+(d.selesai||'—')+' &mdash; Durasi: '+calcDuration(d.mulai,d.selesai)+'</div></div><div class="timeline">'+tlSteps.map(function(s){var cls=s.pct>=100?'done':s.pct>0?'active':'';return'<div class="timeline-step '+cls+'"><div class="tl-node">'+s.icon+'</div><div class="tl-label">'+s.label+'</div><div class="tl-value">'+s.val+'</div><div class="tl-time">'+(s.time||'—')+'</div></div>'}).join('')+'</div></div>';

  // Bottom grid: progress + distribusi summary
  document.getElementById('monitorBottom').innerHTML=
    '<div class="progress-section" style="margin-bottom:0"><div class="progress-title">Progress Per Proses</div>'+
    pb('green','ABF / Karkas Keluar',pA,abf+' dari '+total+' karkas')+
    pb('orange','Pencacahan',pC,cacah+' dari '+total+' karkas')+
    pb('yellow','Packing',pP,box+' box + '+pack+' pack')+
    pb('maroon','Distribusi',pD,distribSelesai+' dari '+distribTotal+' lokasi')+'</div>'+
    '<div class="progress-section" style="margin-bottom:0"><div class="progress-title">Waktu Per Proses</div>'+
    '<div class="time-grid" style="margin-bottom:0">'+
    tc('blue','&#x1f9ca;','ABF',d.abfMulai?d.abfMulai+' - '+(d.abfSelesai||'...'):'—')+
    tc('orange','&#x1f52a;','Cacah',d.cacahMulai?d.cacahMulai+' - '+(d.cacahSelesai||'...'):'—')+
    tc('','&#x1f4e6;','Pack',d.packMulai?d.packMulai+' - '+(d.packSelesai||'...'):'—','background:var(--yellow-light)')+
    tc('','&#x1f69a;','Distrib',d.distribMulai?d.distribMulai+' - '+(d.distribSelesai||'...'):'—','background:var(--maroon-light)')+
    '</div></div>';

  // Distribusi table
  if(distribList.length>0){
    document.getElementById('monitorDistrib').innerHTML='<div class="table-card"><div class="table-header"><div class="table-title">Daftar Distribusi ('+distribSelesai+'/'+distribTotal+' selesai)</div><div class="live-badge"><div class="live-dot"></div>Realtime</div></div><div style="overflow-x:auto"><table><thead><tr><th>#</th><th>Lokasi</th><th>Jumlah</th><th>Status</th><th>Catatan</th></tr></thead><tbody>'+distribList.map(function(item,i){return'<tr><td class="font-mono" style="color:var(--text3)">'+String(i+1).padStart(2,'0')+'</td><td><strong>'+(item.nama||'—')+'</strong></td><td class="font-mono fw-700">'+(item.jumlah||0)+'</td><td><span class="badge '+(item.status==='selesai'?'badge-done':item.status==='proses'?'badge-process':'badge-wait')+'">'+(item.status==='selesai'?'Selesai':item.status==='proses'?'Proses':'Menunggu')+'</span></td><td style="color:var(--text3);font-size:12px">'+(item.catatan||'—')+'</td></tr>'}).join('')+'</tbody></table></div></div>';
  } else {
    document.getElementById('monitorDistrib').innerHTML='';
  }

  // Clock
  var now=new Date(),wib=new Date(now.toLocaleString('en-US',{timeZone:'Asia/Jakarta'}));
  document.getElementById('monitorClock').textContent=String(wib.getHours()).padStart(2,'0')+':'+String(wib.getMinutes()).padStart(2,'0')+':'+String(wib.getSeconds()).padStart(2,'0')+' WIB';
  document.getElementById('monitorDate').textContent=wib.toLocaleDateString('id-ID',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
}

function enterMonitorMode(){
  if(monitorMode)return;monitorMode=true;
  document.documentElement.classList.add('monitoring');document.body.classList.add('monitoring');
  document.getElementById('monitorOverlay').classList.add('visible');
  renderMonitorDashboard();
  if(document.documentElement.requestFullscreen)document.documentElement.requestFullscreen().catch(function(){});
  monitorInterval2=setInterval(function(){renderMonitorDashboard()},1000);
}
function exitMonitorMode(){
  if(!monitorMode)return;monitorMode=false;
  document.documentElement.classList.remove('monitoring');document.body.classList.remove('monitoring');
  document.getElementById('monitorOverlay').classList.remove('visible');
  if(monitorInterval2){clearInterval(monitorInterval2);monitorInterval2=null}
  if(document.fullscreenElement)document.exitFullscreen().catch(function(){});
}

document.addEventListener('keydown',function(e){if(!monitorMode)return;if(e.key==='Escape'){e.preventDefault();exitMonitorMode()}});
document.addEventListener('fullscreenchange',function(){if(!document.fullscreenElement&&monitorMode)exitMonitorMode()});

// ================================================================
// EXPORT XLSX
// ================================================================
function exportXLSX(){
  if(typeof XLSX==='undefined'){toast('Library XLSX belum dimuat','error');return}
  var d=data,wb=XLSX.utils.book_new();
  var summary=[['Qurban Day 2 — Laporan Monitoring'],['Tanggal',d.tanggal||'—'],['Waktu',d.mulai+' - '+d.selesai],[],['KARKAS & ABF'],['Total Karkas',d.totalKarkas],['Keluar ABF',d.abfKeluar],['Sisa',Math.max(0,d.totalKarkas-d.abfKeluar)],['Waktu ABF',d.abfMulai+' - '+d.abfSelesai],[],['PENCACAHAN'],['Total Dicacah',d.cacah],['Waktu',d.cacahMulai+' - '+d.cacahSelesai],[],['PACKING'],['Total Box',d.packBox],['Total Pack',d.packPack],['Total Packing',d.packBox+d.packPack],['Waktu',d.packMulai+' - '+d.packSelesai]];
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(summary),'Ringkasan');
  var mejaData=[['Meja','Jumlah','Mulai','Selesai','Durasi']];
  (d.mejaCacah||[]).forEach(function(m){mejaData.push([m.nama,m.jumlah,m.mulai,m.selesai,calcDuration(m.mulai,m.selesai)])});
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(mejaData),'Pencacahan');
  var distData=[['No','Lokasi','Jumlah','Status','Catatan']];
  (d.distribusi||[]).forEach(function(x,i){distData.push([i+1,x.nama,x.jumlah,x.status,x.catatan])});
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(distData),'Distribusi');
  XLSX.writeFile(wb,'Qurban_Day2_'+(d.tanggal||'laporan')+'.xlsx');
  toast('File Excel berhasil diunduh','success');
}

// ================================================================
// RESET
// ================================================================
function resetAll(){
  if(!confirm('Reset semua data Day 2? Tindakan ini tidak bisa dibatalkan.'))return;
  data={totalKarkas:0,abfKeluar:0,abfMulai:'',abfSelesai:'',cacah:0,cacahMulai:'',cacahSelesai:'',mejaCacah:Array.from({length:6},function(_,i){return{nama:'Meja '+(i+1),jumlah:0,mulai:'',selesai:''}}),packBox:0,packPack:0,packMulai:'',packSelesai:'',distribMulai:'',distribSelesai:'',tanggal:'',mulai:'',selesai:'',distribusi:[]};
  saveStateToAPI();renderAll();fillInputFields();toast('Semua data berhasil direset','success');
}

// ================================================================
// REFRESH
// ================================================================
async function refreshData(){await loadStateFromAPI();renderAll();toast('Data diperbarui','info')}

// ================================================================
// AUTO REFRESH
// ================================================================
function startAutoRefresh(){
  if(autoRefreshInterval)clearInterval(autoRefreshInterval);
  autoRefreshInterval=setInterval(async function(){
    await loadSettingsFromAPI();
    var shouldDark=!!settings.darkMode;
    if(shouldDark!==document.body.classList.contains('dark')){document.body.classList.toggle('dark',shouldDark);updateDarkUI()}
    applyTheme(loadTheme());
    await loadStateFromAPI();
    renderAll();
  },30000);
}
function toggleAutoRefresh(btn){
  autoRefreshEnabled=!autoRefreshEnabled;
  btn.classList.toggle('on',autoRefreshEnabled);
  if(autoRefreshEnabled)startAutoRefresh();
  else{clearInterval(autoRefreshInterval);autoRefreshInterval=null}
  toast(autoRefreshEnabled?'Auto refresh aktif':'Auto refresh nonaktif','info');
}

// ================================================================
// INIT
// ================================================================
document.addEventListener('DOMContentLoaded',async function(){
  updateClock();setInterval(updateClock,1000);
  await loadSettingsFromAPI();
  if(settings.darkMode)document.body.classList.add('dark');
  updateDarkUI();
  await loadStateFromAPI();
  setupThemeUI();
  renderAll();
  renderDistribInputs();
  renderMejaTable();
  setupAutoSave();
  if(autoRefreshEnabled)startAutoRefresh();

  // Settings page event listeners
  var ds=document.getElementById('darkModeSwitch');if(ds)ds.addEventListener('click',toggleDark);
  var ar=document.getElementById('autoRefreshSwitch');if(ar)ar.addEventListener('click',function(){toggleAutoRefresh(this)});

  // Monitor mode event listeners
  document.getElementById('monitorExitBtn').addEventListener('click',exitMonitorMode);

  setTimeout(renderAll,100);
});
</script>
</body>
</html>
