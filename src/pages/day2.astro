  {id:'overall',name:'Progress Total',desc:'Overall progress besar dengan detail',on:false}
];

function loadMonitorWidgets(){
  var saved=settings.monitorWidgets;
  if(saved&&typeof saved==='object'){
    monitorWidgetRegistry.forEach(function(w){if(saved[w.id]!==undefined)w.on=!!saved[w.id]});
  }
  var order=settings.monitorOrder;
  if(order&&Array.isArray(order)&&order.length){
    var sorted=[];
    order.forEach(function(id){var w=monitorWidgetRegistry.find(function(x){return x.id===id});if(w)sorted.push(w)});
    monitorWidgetRegistry.forEach(function(w){if(!sorted.includes(w))sorted.push(w)});
    monitorWidgetRegistry.length=0;sorted.forEach(function(w){monitorWidgetRegistry.push(w)});
  }
}
function saveMonitorWidgets(){
  var obj={};monitorWidgetRegistry.forEach(function(w){obj[w.id]=w.on});
  settings.monitorWidgets=obj;
  settings.monitorOrder=monitorWidgetRegistry.map(function(w){return w.id});
  queueSettingsSave();
}

var mwDragEl=null;
function renderMonitorWidgetBar(){
  var bar=document.getElementById('monitorWidgetBar');
  bar.innerHTML='<span style="font-size:12px;font-weight:700;color:var(--text-secondary);margin-right:4px">Widgets:</span>'+
    monitorWidgetRegistry.map(function(w){
      return'<div class="mw-toggle'+(w.on?' on':'')+'" data-mw="'+w.id+'" title="'+w.desc+'" draggable="true"><span class="mw-toggle-dot"></span>'+w.name+'</div>';
    }).join('');
  bar.querySelectorAll('.mw-toggle').forEach(function(el){
    el.addEventListener('dragstart',function(e){mwDragEl=el;el.classList.add('dragging');e.dataTransfer.effectAllowed='move'});
    el.addEventListener('dragend',function(){if(mwDragEl)mwDragEl.classList.remove('dragging');mwDragEl=null;bar.querySelectorAll('.mw-toggle').forEach(function(t){t.classList.remove('drag-over')})});
    el.addEventListener('dragover',function(e){if(!mwDragEl||mwDragEl===el)return;e.preventDefault();e.dataTransfer.dropEffect='move';bar.querySelectorAll('.mw-toggle').forEach(function(t){t.classList.remove('drag-over')});el.classList.add('drag-over')});
    el.addEventListener('dragleave',function(){el.classList.remove('drag-over')});
    el.addEventListener('drop',function(e){e.preventDefault();el.classList.remove('drag-over');if(!mwDragEl||mwDragEl===el)return;
      var fromId=mwDragEl.dataset.mw,toId=el.dataset.mw;
      var fromIdx=monitorWidgetRegistry.findIndex(function(w){return w.id===fromId});
      var toIdx=monitorWidgetRegistry.findIndex(function(w){return w.id===toId});
      if(fromIdx<0||toIdx<0)return;
      var item=monitorWidgetRegistry.splice(fromIdx,1)[0];monitorWidgetRegistry.splice(toIdx,0,item);
      saveMonitorWidgets();renderMonitorWidgetBar();renderMonitorDashboard();
    });
  });
}

var monChartTypes = {};
function getChartType(chartId) { return monChartTypes[chartId] || 'bar'; }
function toggleChartType(chartId) {
  monChartTypes[chartId] = getChartType(chartId) === 'bar' ? 'pie' : 'bar';
  renderMonitorDashboard();
}

function monPieChart(segments, centerVal, centerLabel) {
  var total = segments.reduce(function(s,x){return s+x.val},0);
  if (!total) total = 1;
  var gradParts = [], cumPct = 0;
  segments.forEach(function(seg) {
    var pct = seg.val / total * 100;
    gradParts.push(seg.color + ' ' + cumPct + '% ' + (cumPct + pct) + '%');
    cumPct += pct;
  });
  return '<div class="mon-pie-wrap">' +
    '<div class="mon-pie" style="background:conic-gradient(' + gradParts.join(',') + ')"><div class="mon-pie-center"><div class="mon-pie-center-val">' + centerVal + '</div><div class="mon-pie-center-label">' + centerLabel + '</div></div></div>' +
    '<div class="mon-pie-legend">' + segments.map(function(seg) {
      return '<div class="mon-pie-legend-item"><div class="mon-pie-legend-dot" style="background:' + seg.color + '"></div>' + seg.label + '<span class="mon-pie-legend-val">' + seg.val + '</span></div>';
    }).join('') + '</div></div>';
}

function monBarChart(bars, height) {
  height = height || 220;
  var maxVal = Math.max.apply(null, bars.map(function(b){return b.val})) || 1;
  return '<div class="mon-bar-area" style="height:' + height + 'px">' + bars.map(function(b) {
    var h = Math.max(4, b.val / maxVal * 100);
    var pctText = b.pct !== undefined ? b.pct + '%' : '';
    return '<div class="mon-bar-col"><div class="mon-bar-fill" style="background:' + b.color + ';height:' + h + '%">' + (pctText ? '<span class="mon-bar-pct">' + pctText + '</span>' : '') + '</div><div class="mon-bar-val">' + b.val + '</div><div class="mon-bar-label">' + b.label + '</div></div>';
  }).join('') + '</div>';
}

function monChartCard(chartId, title, barsData, pieData) {
  var type = getChartType(chartId);
  return '<div class="mon-chart-card"><div class="mon-chart-header"><div class="mon-chart-title">' + title + '</div>' +
    '<div class="mon-chart-toggle"><button class="mon-chart-toggle-btn' + (type === 'bar' ? ' active' : '') + '" onclick="toggleChartType(\'' + chartId + '\')">Bar</button>' +
    '<button class="mon-chart-toggle-btn' + (type === 'pie' ? ' active' : '') + '" onclick="toggleChartType(\'' + chartId + '\')">Pie</button></div></div>' +
    (type === 'bar' ? monBarChart(barsData) : monPieChart(pieData.segments, pieData.centerVal, pieData.centerLabel)) + '</div>';
}

function mwRender_stats(v){return'<div class="monitor-stats-grid">'+sc('blue',v.total,'Total Karkas','Keseluruhan tersedia')+sc('green',v.abf,'Keluar ABF',v.pA+'% dari total')+sc('blue',Math.max(0,v.total-v.abf),'Sisa di ABF','Belum diambil')+sc('orange',v.cacah,'Dicacah',v.pC+'% selesai')+sc('amber',v.packTotal,'Dipacking',v.box+' box, '+v.pack+' pack')+sc('maroon',v.distribSelesai,'Distribusi',v.pD+'% selesai')+sc('purple',v.overall+'%','Progress Total','ABF &rarr; Distribusi')+'</div>'}
function mwRender_clock(v){var now2=new Date(),wib2=new Date(now2.toLocaleString('en-US',{timeZone:'Asia/Jakarta'}));var t=String(wib2.getHours()).padStart(2,'0')+':'+String(wib2.getMinutes()).padStart(2,'0')+':'+String(wib2.getSeconds()).padStart(2,'0');return'<div style="background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius);padding:32px;text-align:center;margin-bottom:24px"><div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px">Waktu WIB</div><div style="font-size:72px;font-weight:800;font-family:\'JetBrains Mono\',monospace;color:var(--green);line-height:1">'+t+'</div><div style="font-size:14px;color:var(--text-secondary);margin-top:8px">'+(v.d.tanggal||'—')+'</div></div>'}
function mwRender_timeline(v){var steps=[{pct:v.pA,label:'ABF Keluar',val:v.abf,time:v.d.abfMulai},{pct:v.pC,label:'Pencacahan',val:v.cacah,time:v.d.cacahMulai},{pct:v.pP,label:'Packing',val:v.packTotal,time:v.d.packMulai},{pct:v.pD,label:'Distribusi',val:v.distribSelesai,time:v.d.distribMulai}];return'<div class="timeline-card" style="margin-bottom:24px"><div class="table-header" style="border:none;padding:0 0 16px"><div class="table-title">Alur Proses</div><div style="font-family:\'JetBrains Mono\',monospace;font-size:13px;color:var(--text-secondary)">Mulai: '+(v.d.mulai||'—')+' &mdash; Selesai: '+(v.d.selesai||'—')+' &mdash; Durasi: '+calcDuration(v.d.mulai,v.d.selesai)+'</div></div><div class="timeline">'+steps.map(function(s){var cls=s.pct>=100?'done':s.pct>0?'active':'';return'<div class="timeline-step '+cls+'"><div class="tl-node"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg></div><div class="tl-label">'+s.label+'</div><div class="tl-value">'+s.val+'</div><div class="tl-time">'+(s.time||'—')+'</div></div>'}).join('')+'</div></div>'}
function mwRender_progress(v){return'<div class="progress-section" style="margin-bottom:24px"><div class="progress-title">Progress Per Proses</div>'+pb('green','ABF / Karkas Keluar',v.pA,v.abf+' dari '+v.total+' karkas')+pb('orange','Pencacahan',v.pC,v.cacah+' dari '+v.total+' karkas')+pb('amber','Packing',v.pP,v.box+' box + '+v.pack+' pack')+pb('maroon','Distribusi',v.pD,v.distribSelesai+' dari '+v.distribTotal+' lokasi')+'</div>'}
function mwRender_times(v){return'<div class="progress-section" style="margin-bottom:24px"><div class="progress-title">Waktu Per Proses</div><div class="time-grid" style="margin-bottom:0">'+tc('blue','ABF',v.d.abfMulai?v.d.abfMulai+' - '+(v.d.abfSelesai||'...'):'—')+tc('orange','Cacah',v.d.cacahMulai?v.d.cacahMulai+' - '+(v.d.cacahSelesai||'...'):'—')+tc('amber','Pack',v.d.packMulai?v.d.packMulai+' - '+(v.d.packSelesai||'...'):'—')+tc('maroon','Distrib',v.d.distribMulai?v.d.distribMulai+' - '+(v.d.distribSelesai||'...'):'—')+'</div></div>'}
function mwRender_meja(v){var h='<div class="table-card" style="margin-bottom:24px"><div class="table-header"><div class="table-title">Pencacahan per Meja</div></div><div style="overflow-x:auto"><table><thead><tr><th>Meja</th><th>Jumlah</th><th>Mulai</th><th>Selesai</th><th>Durasi</th></tr></thead><tbody>';(v.d.mejaCacah||[]).forEach(function(m){h+='<tr><td class="fw-700">'+m.nama+'</td><td class="font-mono fw-700">'+(m.jumlah||0)+'</td><td class="font-mono">'+(m.mulai||'—')+'</td><td class="font-mono">'+(m.selesai||'—')+'</td><td class="font-mono" style="color:var(--green)">'+calcDuration(m.mulai,m.selesai)+'</td></tr>'});return h+'</tbody></table></div></div>'}
function mwRender_distrib(v){if(!v.distribList.length)return'';return'<div class="table-card" style="margin-bottom:24px"><div class="table-header"><div class="table-title">Daftar Distribusi ('+v.distribSelesai+'/'+v.distribTotal+' selesai)</div><div class="monitor-live-badge"><span class="monitor-live-dot"></span> Realtime</div></div><div style="overflow-x:auto"><table><thead><tr><th>#</th><th>Lokasi</th><th>Jumlah</th><th>Status</th><th>Catatan</th></tr></thead><tbody>'+v.distribList.map(function(item,i){return'<tr><td class="font-mono" style="color:var(--text-muted)">'+String(i+1).padStart(2,'0')+'</td><td><strong>'+(item.nama||'—')+'</strong></td><td class="font-mono fw-700">'+(item.jumlah||0)+'</td><td><span class="badge '+(item.status==='selesai'?'badge-done':item.status==='proses'?'badge-process':'badge-wait')+'">'+(item.status==='selesai'?'Selesai':item.status==='proses'?'Proses':'Menunggu')+'</span></td><td style="color:var(--text-muted);font-size:12px">'+(item.catatan||'—')+'</td></tr>'}).join('')+'</tbody></table></div></div>'}

