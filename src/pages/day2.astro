---
import { COOKIE_NAME, getRole } from '../lib/auth';
const auth = Astro.cookies.get(COOKIE_NAME)?.value;
const role = getRole(auth) || 'viewer';
---
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Qurban Day 2 — Command Center | Yayasan Al-Fatihah</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link href="https://fonts.googleapis.com/css2?family=Cabin:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&family=Lato:wght@300;400;700&family=Lexend:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600;700;800&family=Nunito:wght@300;400;500;600;700;800&family=Open+Sans:wght@300;400;500;600;700&family=Poppins:wght@300;400;500;600;700;800&family=Quicksand:wght@300;400;500;600;700&family=Raleway:wght@300;400;500;600;700;800&family=Roboto:wght@300;400;500;700&family=Rubik:wght@300;400;500;600;700&family=Source+Sans+3:wght@300;400;500;600;700&family=Ubuntu:wght@300;400;500;700&display=swap" rel="stylesheet" />
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style is:global>
:root {
  --bg: #f8f9fc;
  --surface: #ffffff;
  --surface2: #f1f3f9;
  --surface-glass: rgba(255,255,255,.7);
  --border: #e5e7ef;
  --border-light: #eef0f6;
  --text-primary: #111827;
  --text-secondary: #4b5563;
  --text-muted: #9ca3af;
  --green: #10b981;
  --green-light: #d1fae5;
  --green-dark: #059669;
  --blue: #3b82f6;
  --blue-light: #dbeafe;
  --blue-dark: #2563eb;
  --maroon: #e11d48;
  --maroon-light: #ffe4e6;
  --maroon-dark: #be123c;
  --amber: #f59e0b;
  --amber-light: #fef3c7;
  --purple: #8b5cf6;
  --purple-light: #ede9fe;
  --teal: #06b6d4;
  --orange: #f97316;
  --sidebar-w: 250px;
  --sidebar-w-collapsed: 68px;
  --header-h: 60px;
  --radius: 16px;
  --radius-sm: 10px;
  --shadow: 0 1px 3px rgba(0,0,0,.04), 0 1px 2px rgba(0,0,0,.06);
  --shadow-md: 0 4px 20px rgba(0,0,0,.08);
  --shadow-lg: 0 10px 40px rgba(0,0,0,.12);
  --transition: .2s cubic-bezier(.4,0,.2,1);
}
.dark {
  --bg: #0c0f1a;
  --surface: #161b2e;
  --surface2: #1e2438;
  --surface-glass: rgba(22,27,46,.8);
  --border: #2a3150;
  --border-light: #232945;
  --text-primary: #f1f5f9;
  --text-secondary: #94a3b8;
  --text-muted: #64748b;
  --shadow: 0 1px 3px rgba(0,0,0,.3);
  --shadow-md: 0 4px 20px rgba(0,0,0,.4);
  --shadow-lg: 0 10px 40px rgba(0,0,0,.5);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text-primary);min-height:100vh;transition:background var(--transition),color var(--transition);overflow-x:hidden}
button{cursor:pointer;font-family:inherit}
input,select,textarea{font-family:inherit}
.mono{font-family:'JetBrains Mono',monospace}

.app-layout{display:flex;min-height:100vh}

/* Sidebar */
.sidebar{width:var(--sidebar-w);background:var(--surface-glass);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-right:1px solid var(--border-light);position:fixed;top:0;left:0;bottom:0;z-index:100;display:flex;flex-direction:column;transition:width var(--transition),transform var(--transition);overflow:hidden}
.sidebar.collapsed{width:var(--sidebar-w-collapsed)}
.sidebar-brand{height:var(--header-h);display:flex;align-items:center;gap:12px;padding:0 18px;border-bottom:1px solid var(--border-light);flex-shrink:0}
.brand-icon{width:36px;height:36px;background:#EA7E8F;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 2px 8px rgba(234,126,143,.3)}
.brand-text{display:flex;flex-direction:column;overflow:hidden;white-space:nowrap;opacity:1;transition:opacity var(--transition)}
.brand-title{font-weight:800;font-size:14px;color:var(--text-primary);line-height:1.2}
.brand-sub{font-size:10px;color:var(--text-muted);font-weight:500}
.sidebar.collapsed .brand-text{opacity:0;pointer-events:none}
.sidebar-nav{flex:1;overflow-y:auto;padding:12px 0}
.sidebar-nav::-webkit-scrollbar{width:3px}
.sidebar-nav::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.nav-section-label{font-size:10px;font-weight:700;letter-spacing:.1em;color:var(--text-muted);text-transform:uppercase;padding:16px 20px 6px;white-space:nowrap;opacity:1;transition:opacity var(--transition)}
.sidebar.collapsed .nav-section-label{opacity:0}
.day-switcher{display:flex;gap:4px;padding:0 10px 14px;margin-bottom:4px;border-bottom:1px solid var(--border-light)}
.day-tab{flex:1;text-align:center;padding:8px 0;border-radius:var(--radius-sm);font-size:12px;font-weight:700;text-decoration:none;transition:all var(--transition);color:var(--text-muted);background:transparent;border:1px solid transparent}
.day-tab:hover{color:var(--text-primary);background:var(--surface2)}
.day-tab.active{background:#EA7E8F;color:#fff;border-color:transparent;box-shadow:0 2px 8px rgba(234,126,143,.25)}
.sidebar.collapsed .day-switcher{flex-direction:column;padding:0 6px 10px}
.sidebar.collapsed .day-tab{font-size:10px;padding:6px 0}
.nav-item{display:flex;align-items:center;gap:12px;padding:10px 20px;cursor:pointer;transition:all var(--transition);color:var(--text-secondary);font-size:13px;font-weight:500;white-space:nowrap;position:relative;border-radius:0;margin:1px 0;text-decoration:none}
.nav-item:hover{background:var(--surface2);color:var(--text-primary)}
.nav-item.active{background:linear-gradient(90deg,rgba(16,185,129,.1),rgba(16,185,129,.05));color:var(--green-dark)}
.dark .nav-item.active{background:linear-gradient(90deg,rgba(16,185,129,.15),rgba(16,185,129,.05));color:var(--green)}
.nav-item.active::before{content:'';position:absolute;left:0;top:6px;bottom:6px;width:3px;background:linear-gradient(180deg,var(--green),var(--teal));border-radius:0 3px 3px 0}
.nav-icon{width:22px;display:flex;align-items:center;justify-content:center;flex-shrink:0;opacity:.7}
.nav-item.active .nav-icon{opacity:1}
.nav-item:hover .nav-icon{opacity:1}
.nav-label{opacity:1;transition:opacity var(--transition)}
.sidebar.collapsed .nav-label{opacity:0;pointer-events:none}
.nav-badge{margin-left:auto;background:var(--green);color:#fff;font-size:10px;font-weight:700;padding:2px 7px;border-radius:99px;white-space:nowrap}
.sidebar.collapsed .nav-badge{display:none}

/* Main */
.main-content{margin-left:var(--sidebar-w);width:calc(100% - var(--sidebar-w));flex:0 0 auto;display:flex;flex-direction:column;transition:margin-left var(--transition),width var(--transition);min-width:0}
.sidebar.collapsed ~ .main-content{margin-left:var(--sidebar-w-collapsed);width:calc(100% - var(--sidebar-w-collapsed))}

/* Header */
.header{height:var(--header-h);background:var(--surface-glass);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border-light);display:flex;align-items:center;padding:0 24px;gap:16px;position:sticky;top:0;z-index:90;flex-shrink:0}
.header-toggle{background:none;border:1px solid var(--border);border-radius:var(--radius-sm);width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:var(--text-secondary);transition:all var(--transition)}
.header-toggle:hover{background:var(--surface2);color:var(--text-primary)}
.header-title{font-weight:700;font-size:16px;flex:1}
.header-clock{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text-secondary);background:var(--surface2);padding:6px 14px;border-radius:20px;font-weight:500;border:1px solid var(--border-light)}
.header-actions{display:flex;align-items:center;gap:6px}
.btn-icon{background:none;border:1px solid var(--border);border-radius:var(--radius-sm);width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:var(--text-secondary);transition:all var(--transition)}
.btn-icon:hover{background:var(--surface2);color:var(--text-primary);border-color:var(--text-muted)}

/* Save indicator */
.save-indicator{position:fixed;top:12px;right:24px;z-index:200;background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:6px 14px;font-size:12px;font-weight:600;color:var(--blue);display:none;align-items:center;gap:8px;box-shadow:var(--shadow-md);animation:fadeIn .2s ease}
.save-indicator.visible{display:flex}
.save-dot{width:6px;height:6px;border-radius:50%;background:var(--blue);animation:pulse 1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* Autosave badge */
.autosave-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:20px;font-size:12px;font-weight:600;color:var(--green-dark);background:var(--green-light);border:1px solid rgba(16,185,129,.2)}
.dark .autosave-badge{background:rgba(16,185,129,.15);color:var(--green);border-color:rgba(16,185,129,.2)}
.autosave-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}

/* Pages */
.page-section{display:none;padding:24px;flex:1;animation:fadeIn .3s ease}
.page-section.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px}
.page-title{font-size:22px;font-weight:800;letter-spacing:-.02em}
.page-subtitle{font-size:12px;color:var(--text-muted);margin-top:3px;font-weight:500}
.page-actions{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

/* Buttons */
.btn{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:var(--radius-sm);font-size:13px;font-weight:600;border:none;transition:all var(--transition);cursor:pointer;letter-spacing:-.01em}
.btn-primary{background:linear-gradient(135deg,var(--green),var(--green-dark));color:#fff;box-shadow:0 2px 8px rgba(16,185,129,.25)}
.btn-primary:hover{box-shadow:0 4px 16px rgba(16,185,129,.35);transform:translateY(-1px)}
.btn-secondary{background:linear-gradient(135deg,var(--blue),var(--blue-dark));color:#fff;box-shadow:0 2px 8px rgba(59,130,246,.25)}
.btn-secondary:hover{box-shadow:0 4px 16px rgba(59,130,246,.35);transform:translateY(-1px)}
.btn-danger{background:linear-gradient(135deg,var(--maroon),var(--maroon-dark));color:#fff;box-shadow:0 2px 8px rgba(225,29,72,.2)}
.btn-danger:hover{box-shadow:0 4px 16px rgba(225,29,72,.3);transform:translateY(-1px)}
.btn-ghost{background:var(--surface2);color:var(--text-primary);border:1px solid var(--border)}
.btn-ghost:hover{background:var(--border);border-color:var(--text-muted)}
.btn-sm{padding:7px 14px;font-size:12px}

/* Cards */
.card{background:var(--surface);border-radius:var(--radius);box-shadow:var(--shadow);border:1px solid var(--border-light);padding:22px;transition:all var(--transition)}
.card:hover{box-shadow:var(--shadow-md)}

/* Stat cards */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(185px,1fr));gap:16px;margin-bottom:20px}
.stat-card{background:var(--surface);border-radius:var(--radius);box-shadow:var(--shadow);border:1px solid var(--border-light);padding:20px;display:flex;flex-direction:column;gap:10px;transition:all var(--transition);position:relative;overflow:hidden}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.stat-card.green::before{background:linear-gradient(90deg,var(--green),var(--teal))}
.stat-card.blue::before{background:linear-gradient(90deg,var(--blue),var(--purple))}
.stat-card.maroon::before{background:linear-gradient(90deg,var(--maroon),var(--orange))}
.stat-card.amber::before{background:linear-gradient(90deg,var(--amber),var(--orange))}
.stat-card.purple::before{background:linear-gradient(90deg,var(--purple),var(--blue))}
.stat-card.orange::before{background:linear-gradient(90deg,var(--orange),var(--amber))}
.stat-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-md)}
.stat-label{font-size:12px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.08em}
.stat-value{font-size:36px;font-weight:800;font-family:'JetBrains Mono',monospace;line-height:1}
.stat-sub{font-size:11px;color:var(--text-muted);margin-top:2px}
.stat-badge{font-size:11px;padding:3px 10px;border-radius:20px;font-weight:600;position:absolute;bottom:12px;right:14px}
.stat-badge.green{background:var(--green-light);color:var(--green-dark)}
.stat-badge.blue{background:var(--blue-light);color:var(--blue-dark)}
.stat-badge.maroon{background:var(--maroon-light);color:var(--maroon)}
.dark .stat-badge.green{background:rgba(16,185,129,.15);color:var(--green)}
.dark .stat-badge.blue{background:rgba(59,130,246,.15);color:var(--blue)}
.dark .stat-badge.maroon{background:rgba(225,29,72,.15);color:#fb7185}

/* Progress */
.progress-section{background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius);padding:22px;box-shadow:var(--shadow);margin-bottom:20px}
.progress-title{font-size:15px;font-weight:700;margin-bottom:18px}
.progress-item{margin-bottom:16px}
.progress-item:last-child{margin-bottom:0}
.progress-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.progress-label{font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px}
.progress-pct{font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:700}
.progress-bar-bg{height:8px;background:var(--surface2);border-radius:99px;overflow:hidden}
.progress-bar-fill{height:100%;border-radius:99px;transition:width 1s cubic-bezier(0.4,0,0.2,1);position:relative;overflow:hidden}
.progress-bar-fill::after{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);animation:shimmer 2s infinite}
@keyframes shimmer{to{left:200%}}
.progress-bar-fill.blue{background:linear-gradient(90deg,var(--blue),#60a5fa)}
.progress-bar-fill.green{background:linear-gradient(90deg,var(--green),#34d399)}
.progress-bar-fill.orange{background:linear-gradient(90deg,var(--orange),#fb923c)}
.progress-bar-fill.maroon{background:linear-gradient(90deg,var(--maroon),#f43f5e)}
.progress-bar-fill.amber{background:linear-gradient(90deg,var(--amber),#fbbf24)}
.progress-bar-fill.purple{background:linear-gradient(90deg,var(--purple),#a78bfa)}
.progress-info{display:flex;gap:16px;margin-top:5px}
.progress-info span{font-size:11px;color:var(--text-muted)}

/* Timeline */
.timeline-card{background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius);padding:22px;box-shadow:var(--shadow);margin-bottom:20px}
.timeline{display:flex;gap:0;overflow-x:auto;padding-bottom:8px}
.timeline-step{flex:1;min-width:120px;display:flex;flex-direction:column;align-items:center;position:relative}
.timeline-step:not(:last-child)::after{content:'';position:absolute;top:20px;left:50%;width:100%;height:3px;background:var(--border);z-index:0}
.timeline-step.done:not(:last-child)::after{background:var(--green)}
.timeline-step.active:not(:last-child)::after{background:linear-gradient(90deg,var(--green),var(--border))}
.tl-node{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;z-index:1;position:relative;border:3px solid var(--border);background:var(--surface2);transition:all var(--transition)}
.timeline-step.done .tl-node{background:var(--green-light);border-color:var(--green);color:var(--green)}
.timeline-step.active .tl-node{background:var(--blue-light);border-color:var(--blue);color:var(--blue);animation:ring 2s infinite}
@keyframes ring{0%,100%{box-shadow:0 0 0 0 rgba(16,185,129,0.3)}50%{box-shadow:0 0 0 8px rgba(16,185,129,0)}}
.tl-label{font-size:11px;font-weight:600;margin-top:8px;text-align:center}
.tl-value{font-size:13px;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--text-primary)}
.tl-time{font-size:10px;color:var(--text-muted);margin-top:2px}

/* Table */
.table-card{background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow)}
.table-header{padding:16px 20px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border-light)}
.table-title{font-size:14px;font-weight:700}
table{width:100%;border-collapse:collapse}
th{background:var(--surface2);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-secondary);padding:12px 16px;text-align:left;border-bottom:1px solid var(--border-light)}
td{padding:12px 16px;font-size:13px;border-bottom:1px solid var(--border-light);transition:background var(--transition)}
tr:hover td{background:var(--surface2)}
tr:last-child td{border-bottom:none}
.badge{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:700;padding:4px 10px;border-radius:99px}
.badge-done{background:var(--green-light);color:var(--green-dark)}
.badge-process{background:var(--blue-light);color:var(--blue-dark)}
.badge-wait{background:var(--amber-light);color:#92400e}
.dark .badge-done{background:rgba(16,185,129,.15);color:#34d399}
.dark .badge-process{background:rgba(59,130,246,.15);color:#60a5fa}
.dark .badge-wait{background:rgba(245,158,11,.15);color:var(--amber)}

/* Time cards */
.time-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:20px}
.time-card{background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius);padding:18px;box-shadow:var(--shadow);display:flex;align-items:center;gap:14px}
.time-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.time-icon.blue{background:var(--blue-light)}
.time-icon.green{background:var(--green-light)}
.time-icon.orange{background:rgba(249,115,22,.1)}
.time-label{font-size:11px;color:var(--text-secondary);font-weight:500}
.time-value{font-size:15px;font-weight:700;font-family:'JetBrains Mono',monospace;margin-top:3px}

/* Chart */
.chart-card{background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius);padding:22px;box-shadow:var(--shadow)}
.chart-bars{display:flex;align-items:flex-end;gap:10px;height:100px;padding-top:10px}
.chart-bar-wrap{display:flex;flex-direction:column;align-items:center;flex:1;gap:6px}
.chart-bar{width:100%;border-radius:6px 6px 0 0;transition:height 1s cubic-bezier(0.4,0,0.2,1);min-height:4px}
.chart-bar-label{font-size:10px;color:var(--text-muted);font-weight:600;text-align:center}
.overview-grid{display:grid;grid-template-columns:2fr 1fr;gap:20px}

/* Forms */
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px}
.form-card{background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius);padding:22px;box-shadow:var(--shadow)}
.form-card-title{font-size:14px;font-weight:700;margin-bottom:18px;display:flex;align-items:center;gap:8px;color:var(--text-primary)}
.form-group{margin-bottom:14px}
.form-group:last-child{margin-bottom:0}
.form-label{font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:6px;display:block}
.form-input{width:100%;background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 14px;font-size:13px;color:var(--text-primary);transition:all var(--transition);outline:none}
.form-input:focus{border-color:var(--green);box-shadow:0 0 0 3px rgba(16,185,129,.1)}
.form-input:hover{border-color:var(--text-muted)}
.form-input::placeholder{color:var(--text-muted)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.btn-group{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px}

/* Distrib form */
.distrib-item{background:var(--surface2);border:1px solid var(--border-light);border-radius:var(--radius-sm);padding:14px;margin-bottom:10px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.distrib-item input{flex:1;min-width:120px}
.distrib-item select{width:130px}
.distrib-remove{background:var(--maroon-light);color:var(--maroon);border:none;border-radius:6px;padding:6px 10px;font-size:12px;cursor:pointer;flex-shrink:0;font-weight:700;transition:all var(--transition)}
.distrib-remove:hover{background:var(--maroon);color:#fff}

/* Toast */
.toast-container{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px}
.toast{background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius-sm);padding:12px 18px;box-shadow:var(--shadow-lg);display:flex;align-items:center;gap:10px;font-size:13px;font-weight:500;min-width:260px;animation:slideUp .3s ease;backdrop-filter:blur(10px)}
@keyframes slideUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.toast.success{border-left:3px solid var(--green)}
.toast.error{border-left:3px solid var(--maroon)}
.toast.info{border-left:3px solid var(--blue)}
.toast-icon{font-size:16px;flex-shrink:0}

/* Settings */
.settings-row{display:flex;align-items:center;justify-content:space-between;padding:16px 0;border-bottom:1px solid var(--border-light)}
.settings-row:last-child{border-bottom:none}
.settings-label{font-size:13px;font-weight:600}
.settings-desc{font-size:12px;color:var(--text-muted);margin-top:3px}
.toggle-switch{width:44px;height:24px;background:var(--border);border-radius:12px;cursor:pointer;position:relative;transition:background var(--transition);border:none;flex-shrink:0}
.toggle-switch.on{background:var(--green)}
.toggle-switch::after{content:'';position:absolute;width:18px;height:18px;background:#fff;border-radius:50%;top:3px;left:3px;transition:left var(--transition);box-shadow:0 1px 4px rgba(0,0,0,.2)}
.toggle-switch.on::after{left:23px}
.color-picker{width:44px;height:34px;border:2px solid var(--border);border-radius:var(--radius-sm);padding:2px;cursor:pointer;background:var(--surface)}
.color-picker::-webkit-color-swatch-wrapper{padding:0}
.color-picker::-webkit-color-swatch{border:none;border-radius:4px}

/* Monitor mode */
html.monitoring,body.monitoring{height:100%;overflow:hidden}
.monitor-overlay{display:none;position:fixed;inset:0;z-index:500;background:var(--bg);flex-direction:column;overflow-y:auto;padding:24px 32px}
.monitor-overlay.visible{display:flex}
.monitor-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-shrink:0}
.monitor-header-left{display:flex;align-items:center;gap:16px}
.monitor-header-title{font-size:20px;font-weight:800}
.monitor-header-clock{font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:700;color:var(--green)}
.monitor-header-date{font-size:13px;color:var(--text-secondary);font-weight:500}
.monitor-exit{background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius-sm);padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;transition:all var(--transition)}
.monitor-exit:hover{background:var(--green);color:#fff;border-color:var(--green)}
.monitor-live-badge{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;color:var(--green);letter-spacing:.04em;animation:monLiveText 3s ease-in-out infinite}
.monitor-live-dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 4px var(--green),0 0 8px rgba(34,197,94,.4);animation:monLiveDot 2s ease-in-out infinite}
@keyframes monLiveDot{0%,100%{box-shadow:0 0 4px var(--green),0 0 8px rgba(34,197,94,.3);opacity:.85}50%{box-shadow:0 0 8px var(--green),0 0 16px rgba(34,197,94,.5);opacity:1}}
@keyframes monLiveText{0%,100%{opacity:.8;letter-spacing:.04em}50%{opacity:1;letter-spacing:.06em}}
.monitor-stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:24px}
.monitor-stats-grid .stat-card{padding:26px}
.monitor-stats-grid .stat-card:hover{transform:none}
.monitor-stats-grid .stat-value{font-size:38px}
.monitor-stats-grid .stat-label{font-size:14px}
.monitor-overlay .progress-title{font-size:18px}
.monitor-overlay .table-title{font-size:16px}
.monitor-overlay .progress-pct{font-size:15px}
.monitor-overlay .tl-value{font-size:16px}
.monitor-overlay .tl-label{font-size:13px}
.monitor-overlay .time-value{font-size:18px}
.monitor-overlay .progress-bar-bg{height:14px}
.monitor-overlay .badge{font-size:13px;padding:5px 12px}
.monitor-overlay .table-card td{font-size:15px;padding:14px 18px}
.monitor-overlay .table-card th{font-size:13px;padding:14px 18px}
.monitor-bottom-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px}
.monitor-bottom-grid .progress-section{margin-bottom:0}
.monitor-widget-bar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:20px;padding:12px 16px;background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius-sm)}
.mw-toggle{display:flex;align-items:center;gap:6px;padding:5px 12px;border-radius:20px;font-size:12px;font-weight:600;cursor:grab;border:1px solid var(--border);background:var(--surface2);color:var(--text-secondary);transition:all var(--transition);user-select:none}
.mw-toggle:active{cursor:grabbing}
.mw-toggle.on{background:var(--green);border-color:var(--green);color:#fff}
.mw-toggle:hover{border-color:var(--green)}
.mw-toggle.drag-over{margin-left:24px}
.mw-toggle.dragging{opacity:.4}
.mw-toggle-dot{width:8px;height:8px;border-radius:50%;background:var(--border);transition:background var(--transition)}
.mw-toggle.on .mw-toggle-dot{background:#fff}
.mon-chart-card{background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius);padding:28px;margin-bottom:24px}
.mon-chart-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.mon-chart-title{font-size:16px;font-weight:700}
.mon-chart-toggle{display:flex;gap:4px;background:var(--surface2);border-radius:8px;padding:3px}
.mon-chart-toggle-btn{padding:5px 12px;border-radius:6px;border:none;font-size:12px;font-weight:600;cursor:pointer;background:transparent;color:var(--text-secondary);transition:all .2s}
.mon-chart-toggle-btn.active{background:var(--green);color:#fff}
.mon-pie-wrap{display:flex;align-items:center;justify-content:center;gap:32px;padding:16px 0;flex-wrap:wrap}
.mon-pie{width:200px;height:200px;border-radius:50%;position:relative;flex-shrink:0}
.mon-pie-center{position:absolute;inset:22%;background:var(--surface);border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center}
.mon-pie-center-val{font-size:28px;font-weight:800;font-family:'JetBrains Mono',monospace}
.mon-pie-center-label{font-size:11px;color:var(--text-secondary);font-weight:600}
.mon-pie-legend{display:flex;flex-direction:column;gap:10px}
.mon-pie-legend-item{display:flex;align-items:center;gap:10px;font-size:14px;font-weight:500}
.mon-pie-legend-dot{width:12px;height:12px;border-radius:3px;flex-shrink:0}
.mon-pie-legend-val{font-family:'JetBrains Mono',monospace;font-weight:700;margin-left:auto}
.mon-bar-area{display:flex;align-items:flex-end;gap:16px;height:220px;padding:16px 0}
.mon-bar-col{display:flex;flex-direction:column;align-items:center;flex:1;gap:8px}
.mon-bar-fill{width:100%;border-radius:8px 8px 0 0;min-height:4px;transition:height .8s cubic-bezier(.4,0,.2,1);display:flex;align-items:flex-end;justify-content:center;padding-bottom:6px}
.mon-bar-pct{font-size:11px;font-weight:700;color:#fff;text-shadow:0 1px 2px rgba(0,0,0,.3)}
.mon-bar-val{font-size:15px;font-weight:700;font-family:'JetBrains Mono',monospace}
.mon-bar-label{font-size:12px;color:var(--text-secondary);font-weight:600;text-align:center}
.monitor-editor-bar{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius-sm);margin-bottom:20px;flex-wrap:wrap;gap:12px}
.monitor-editor-bar .btn{flex-shrink:0}
.monitor-editor-label{font-size:13px;font-weight:700;color:var(--text-muted)}
.monitor-mode-live .monitor-editor-bar{display:none}
.monitor-mode-live .monitor-widget-bar{display:none}
.monitor-mode-live .monitor-header{padding:0 0 16px}

/* Utility */
.color-green{color:var(--green)}
.color-orange{color:var(--orange)}
.color-maroon{color:var(--maroon)}
.color-blue{color:var(--blue)}
.font-mono{font-family:'JetBrains Mono',monospace}
.fw-700{font-weight:700}

/* Sidebar overlay (mobile) */
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);z-index:99}

/* Auth role */
body[data-role="viewer"] .editor-only{display:none!important}
.role-badge{font-size:11px;font-weight:600;padding:4px 12px;border-radius:20px;white-space:nowrap}
.role-badge.editor{background:var(--green-light);color:var(--green-dark)}
.role-badge.viewer{background:var(--blue-light);color:var(--blue-dark)}
.dark .role-badge.editor{background:rgba(16,185,129,.15);color:var(--green)}
.dark .role-badge.viewer{background:rgba(59,130,246,.15);color:var(--blue)}

/* Monitor responsive */
@media(min-width:1600px){
  .monitor-stats-grid{grid-template-columns:repeat(7,1fr)}
  .monitor-stats-grid .stat-value{font-size:52px}
  .monitor-stats-grid .stat-label{font-size:17px}
  .monitor-stats-grid .stat-card{padding:36px}
  .monitor-header-title{font-size:26px}
  .monitor-header-clock{font-size:22px}
  .mon-pie{width:240px;height:240px}
  .mon-pie-center-val{font-size:34px}
  .mon-bar-area{height:260px}
  .mon-bar-val{font-size:18px}
  .mon-chart-title{font-size:18px}
}
@media(min-width:2400px){
  .monitor-overlay{padding:40px 60px}
  .monitor-stats-grid .stat-card{padding:44px}
  .monitor-stats-grid .stat-value{font-size:68px}
  .monitor-stats-grid .stat-label{font-size:20px}
  .monitor-header-title{font-size:34px}
  .monitor-header-clock{font-size:28px}
  .mon-pie{width:300px;height:300px}
  .mon-pie-center-val{font-size:42px}
  .mon-bar-area{height:320px}
  .mon-bar-val{font-size:22px}
  .mon-chart-title{font-size:22px}
  .mon-pie-legend-item{font-size:17px}
  .monitor-live-badge{font-size:14px}
  .monitor-live-dot{width:10px;height:10px}
}
@media(max-width:900px){.monitor-bottom-grid{grid-template-columns:1fr}.overview-grid{grid-template-columns:1fr}}
@media(max-width:768px){
  .main-content{margin-left:0!important;width:100%!important}
  .sidebar{transform:translateX(-100%)}
  .sidebar.mobile-open{transform:translateX(0)}
  .sidebar-overlay.active{display:block}
  .page-section{padding:16px}
  .stats-grid{grid-template-columns:1fr 1fr}
  .form-grid{grid-template-columns:1fr}
  .overview-grid{grid-template-columns:1fr}
}
@media(max-width:480px){
  .stats-grid{grid-template-columns:1fr}
  .form-row{grid-template-columns:1fr}
  .time-grid{grid-template-columns:1fr 1fr}
}
@media print{
  .sidebar,.header,.save-indicator,.toast-container,.page-actions,.header-actions{display:none!important}
  .main-content{margin-left:0!important;width:100%!important}
  .page-section.active{padding:16px}
}
</style>
</head>
<body data-role={role}>

<!-- Toast Container -->
<div class="toast-container" id="toastContainer"></div>

<!-- Monitor Overlay — Grid Dashboard -->
<div class="monitor-overlay" id="monitorOverlay">
  <div class="monitor-header">
    <div class="monitor-header-left">
      <div class="monitor-header-title">Qurban Day 2 — Command Center</div>
      <div class="monitor-live-badge"><span class="monitor-live-dot"></span> LIVE</div>
    </div>
    <div style="display:flex;align-items:center;gap:16px">
      <div class="monitor-header-date" id="monitorDate">—</div>
      <div class="monitor-header-clock" id="monitorClock">00:00:00</div>
      <button class="monitor-exit" id="monitorExitBtn">&#x2715; Keluar</button>
    </div>
  </div>
  <div class="monitor-editor-bar" id="monitorEditorBar">
    <div class="monitor-editor-label">Editor Mode — Atur widget dan layout monitor</div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-primary btn-sm" onclick="startLiveMonitor()">Tampilkan Monitor</button>
    </div>
  </div>
  <div class="monitor-widget-bar" id="monitorWidgetBar"></div>
  <div id="monitorContent"></div>
</div>

<!-- Sidebar Overlay (Mobile) -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- App Layout -->
<div class="app-layout">

  <!-- Sidebar -->
  <nav class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <div class="brand-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
      </div>
      <div class="brand-text">
        <span class="brand-title">Alfatihah Farm</span>
        <span class="brand-sub">Qurban Day 2 Monitor</span>
      </div>
    </div>
    <div class="sidebar-nav">
      <div class="day-switcher">
        <a class="day-tab" href="/">Day 1</a>
        <a class="day-tab active" href="/day2">Day 2</a>
      </div>
      <div class="nav-section-label">Monitoring</div>
      <div class="nav-item active" onclick="showPage('dashboard',this)">
        <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg></span>
        <span class="nav-label">Dashboard</span>
      </div>
      <div class="nav-item" onclick="showPage('abf',this)">
        <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 6v12"/><path d="M2 12h20"/></svg></span>
        <span class="nav-label">ABF / Karkas</span>
      </div>
      <div class="nav-item" onclick="showPage('pencacahan',this)">
        <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg></span>
        <span class="nav-label">Pencacahan</span>
      </div>
      <div class="nav-item" onclick="showPage('packing',this)">
        <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg></span>
        <span class="nav-label">Packing</span>
      </div>
      <div class="nav-item" onclick="showPage('distribusi',this)">
        <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></span>
        <span class="nav-label">Distribusi</span>
        <span class="nav-badge" id="distrib-badge">0</span>
      </div>
      <div class="nav-section-label editor-only">Manajemen</div>
      <div class="nav-item editor-only" onclick="showPage('input',this)">
        <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></span>
        <span class="nav-label">Input Data</span>
      </div>
      <div class="nav-item editor-only" onclick="showPage('pengaturan',this)">
        <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/></svg></span>
        <span class="nav-label">Pengaturan</span>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="main-content">
    <!-- Header -->
    <header class="header">
      <button class="header-toggle" id="sidebarToggle" onclick="toggleSidebar()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div>
        <div class="header-title" id="topbar-title">Dashboard Utama</div>
      </div>
      <div style="flex:1"></div>
      <div class="header-clock" id="clockDisplay">--:--:-- WIB</div>
      <span class={`role-badge ${role}`}>{role === 'editor' ? 'Editor' : 'Viewer'}</span>
      <div class="header-actions">
        <button class="btn-icon" onclick="exportXLSX()" title="Export Excel">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </button>
        <button class="btn-icon" onclick="window.print()" title="Print">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        </button>
        <button class="btn-icon editor-only" id="darkToggleBtn" onclick="toggleDark()" title="Dark Mode">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-moon"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-sun" style="display:none"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button>
        <button class="btn-icon" onclick="logoutUser()" title="Logout">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </header>

    <div class="save-indicator" id="saveIndicator"><div class="save-dot"></div><span>Menyimpan...</span></div>

    <!-- ============ PAGE: DASHBOARD ============ -->
    <section class="page-section active" id="page-dashboard">
      <div class="page-header">
        <div>
          <div class="page-title">Dashboard Utama</div>
          <div class="page-subtitle">Monitoring Realtime Qurban Day 2</div>
        </div>
        <div class="page-actions">
          <button class="btn btn-secondary btn-sm" onclick="enterMonitorMode()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Mode Monitor
          </button>
          <button class="btn btn-ghost btn-sm" onclick="refreshData()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
            Refresh
          </button>
          <button class="btn btn-primary btn-sm" onclick="exportXLSX()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export Excel
          </button>
        </div>
      </div>
