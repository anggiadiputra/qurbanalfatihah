function navItem(page, label, icon, cls) {
  var active = currentPage === page ? ' active' : '';
  return '<div class="nav-item' + active + (cls ? ' ' + cls : '') + '" data-page="' + page + '"><span class="nav-icon">' + icon + '</span><span class="nav-label">' + label + '</span></div>';
}

// ================================================================
// HELPERS
// ================================================================
function getState() { return currentView !== 'all' ? (dayStates[currentView] || defaultDayState()) : null; }
function pct(val, total) { if (!total) return 0; return Math.min(100, Math.round(val / total * 100)); }

function durationStr(mulai, selesai) {
  if (!mulai) return '-';
  var p = mulai.split(':').map(Number);
  var start = p[0]*60+p[1];
  var end = null;
  if (selesai) { var p2 = selesai.split(':').map(Number); end = p2[0]*60+p2[1]; }
  var now = new Date(); var nowMin = now.getHours()*60+now.getMinutes();
  var diff = (end !== null ? end : nowMin) - start;
  if (diff < 0) return '-';
  return String(Math.floor(diff/60)).padStart(2,'0')+':'+String(diff%60).padStart(2,'0')+' jam';
}

function statusClass(st) { return st==='selesai'?'status-selesai':st==='berjalan'?'status-berjalan':st==='menunggu'?'status-menunggu':'status-belum'; }
function statusLabel(st) { return st==='selesai'?'Selesai':st==='berjalan'?'Berjalan':st==='menunggu'?'Menunggu':'Belum'; }
function statusOpts(current) {
  return ['belum','menunggu','berjalan','selesai'].map(function(s){
    return '<option value="'+s+'"'+(current===s?' selected':'')+'>'+statusLabel(s)+'</option>';
  }).join('');
}

function totalKeluarDay(s) { return (s.kandang||[]).reduce(function(a,k){return a+(k.keluar||0);},0); }
function totalDipotongDay(s) { return (s.sembelih||[]).reduce(function(a,k){return a+(k.dipotong||0);},0); }
function totalDikulitiDay(s) { return (s.lane||s.kalet||[]).reduce(function(a,k){return a+(k.total||0);},0); }
function totalDicacahDay(s) { return (s.cacah||[]).reduce(function(a,k){return a+(k.total||0);},0); }

function sumAllDays(fn) {
  var total = 0;
  for (var i = 1; i <= 4; i++) { var s = dayStates[i]; if (s) total += fn(s); }
  return total;
}

function infoChip(label,val) {
  return '<div class="info-chip"><div class="info-chip-label">'+label+'</div><div class="info-chip-val mono">'+(val||'-')+'</div></div>';
}

function tlItem(color,title,meta,last) {
  return '<div class="timeline-item'+(last?' style="padding-bottom:0"':'')+'"><div class="timeline-dot '+color+'"></div><div class="timeline-content"><div class="timeline-title">'+title+'</div><div class="timeline-meta">'+meta+'</div></div></div>';
}

function statCardHtml(color, label, value, badge, badgeColor) {
  badgeColor = badgeColor || color;
  return '<div class="stat-card '+color+'"><div class="stat-label">'+label+'</div><div class="stat-value" style="color:var(--'+color+')">'+value+'</div><div class="stat-badge '+badgeColor+'">'+badge+'</div></div>';
}

// ================================================================
// PIPELINE
// ================================================================
function calcPipeline(state) {
  var total = state.totalHewan || 0;
  var keluar = totalKeluarDay(state);
  var dipotong = Math.min(totalDipotongDay(state), keluar);
  var dikuliti = Math.min(totalDikulitiDay(state), dipotong);
  var karkasTotal = state.karkas ? state.karkas.total || 0 : 0;
  var abfKeluar = state.abf ? state.abf.keluar || 0 : 0;
  var dicacah = totalDicacahDay(state) + (state.cacahDariAbf || 0);
  var packKecil = state.packingKecil ? state.packingKecil.total || 0 : 0;
  var packKarkas = state.packingKarkas ? (state.packingKarkas.domba||0)+(state.packingKarkas.sapi||0) : 0;
  var dkLokasi = state.distribusiKecil && state.distribusiKecil.lokasi ? state.distribusiKecil.lokasi : [];
  var distKecil = dkLokasi.filter(function(x){return x.status==='selesai'}).length;
  var distKarkas = state.distribusiKarkas ? (state.distribusiKarkas.selesaiDomba||0)+(state.distribusiKarkas.selesaiSapi||0) : 0;
  return {total:total,keluar:keluar,dipotong:dipotong,dikuliti:dikuliti,karkasTotal:karkasTotal,abfKeluar:abfKeluar,dicacah:dicacah,packKecil:packKecil,packKarkas:packKarkas,distKecil:distKecil,distKarkas:distKarkas};
}

function renderPipelineHtml(p, feat) {
  feat = feat || defaultFeatures;
  var items = [];
  var num = 1;
  function addProc(name, done, of, color, sub) {
    var p2 = pct(done, of || 1);
    var st = p2 >= 100 ? 'selesai' : done > 0 ? 'berjalan' : 'belum';
    items.push('<div class="process-item"><div class="process-num">'+String(num++).padStart(2,'0')+'</div><div class="process-info"><div class="process-name">'+name+'</div><div class="process-sub">'+done+' '+sub+'</div></div><div class="process-progress"><div class="progress-bar"><div class="progress-fill '+color+'" style="width:'+p2+'%"></div></div></div><div class="process-count">'+p2+'%</div><div class="process-status"><span class="status-badge '+statusClass(st)+'">'+statusLabel(st)+'</span></div></div>');
  }
  if (feat.kandang) addProc('Keluar Kandang', p.keluar, p.total, 'green', 'dari '+p.total+' total');
  if (feat.sembelih) addProc('Penyembelihan', p.dipotong, p.keluar, 'maroon', 'dari '+p.keluar+' keluar');
  if (feat.pengulitan) addProc('Pengulitan', p.dikuliti, p.dipotong, 'blue', 'dari '+p.dipotong+' disembelih');
  if (feat.karkas) addProc('Karkas', p.karkasTotal, p.dikuliti, 'amber', 'dari '+p.dikuliti+' dikuliti');
  if (feat.abf) addProc('Keluar ABF', p.abfKeluar, p.karkasTotal, 'purple', 'dari '+p.karkasTotal+' karkas');
  if (feat.cacah) addProc('Pencacahan', p.dicacah, p.dikuliti, 'purple', 'dari '+p.dikuliti+' dikuliti');
  if (feat.packingKecil) addProc('Packing Kecil', p.packKecil, p.dicacah, 'blue', 'dari '+p.dicacah+' dicacah');
  if (feat.packingKarkas) addProc('Packing Karkas', p.packKarkas, p.karkasTotal, 'blue', 'dari '+p.karkasTotal+' karkas');
  if (feat.distribusiKecil) addProc('Distribusi Kecil', p.distKecil, p.packKecil, 'green', 'dari '+p.packKecil+' packing');
  if (feat.distribusiKarkas) addProc('Distribusi Karkas', p.distKarkas, p.packKarkas, 'green', 'dari '+p.packKarkas+' packing');
  return '<div class="process-row">' + items.join('') + '</div>';
}

// ================================================================
// PAGE RENDERING
// ================================================================
function renderCurrentPage() {
  var container = document.getElementById('pageContent');
  if (currentView === 'all') {
    if (currentPage === 'dashboard') container.innerHTML = renderAllDayDashboard();
    else if (currentPage === 'ringkasan') container.innerHTML = renderRingkasan();
    else if (currentPage === 'pengaturan') container.innerHTML = renderPengaturan();
    else container.innerHTML = '';
  } else {
    var state = getState();
    if (!state) { container.innerHTML = '<p>Loading...</p>'; return; }
    if (currentPage === 'dashboard') container.innerHTML = renderDayDashboard(state);
    else if (currentPage === 'kandang') container.innerHTML = renderKandangPage(state);
    else if (currentPage === 'sembelih') container.innerHTML = renderSembelihPage(state);
    else if (currentPage === 'transit') container.innerHTML = renderTransitPage(state);
    else if (currentPage === 'pengulitan') container.innerHTML = renderPengulitanPage(state);
    else if (currentPage === 'karkas') container.innerHTML = renderKarkasPage(state);
    else if (currentPage === 'cacah') container.innerHTML = renderCacahPage(state);
    else if (currentPage === 'packing') container.innerHTML = renderPackingPage(state);
    else if (currentPage === 'distKecil') container.innerHTML = renderDistKecilPage(state);
    else if (currentPage === 'distKarkas') container.innerHTML = renderDistKarkasPage(state);
    else if (currentPage === 'input') container.innerHTML = renderInputPage(state);
    else if (currentPage === 'pengaturan') container.innerHTML = renderPengaturan();
    else container.innerHTML = '';
  }
  setupPageListeners();
}

function setupPageListeners() {
  // Auto-save for input page
  var pc = document.getElementById('pageContent');
  if (currentPage === 'input' && currentView !== 'all') {
    pc.addEventListener('input', function(e) { if (e.target.classList.contains('form-control')) { collectCurrentFormData(); queueDaySave(currentView); } });
    pc.addEventListener('change', function(e) { if (e.target.classList.contains('form-control')) { collectCurrentFormData(); queueDaySave(currentView); } });
  }
  // Kalet search/filter
  var searchEl = document.getElementById('searchKalet');
  var filterEl = document.getElementById('filterKaletStatus');
  if (searchEl) searchEl.addEventListener('input', filterKaletGrid);
  if (filterEl) filterEl.addEventListener('change', filterKaletGrid);
}

// ================================================================
// ALL DAY DASHBOARD
// ================================================================
function renderAllDayDashboard() {
  var totalTarget = 0, totalKeluar = 0, totalDipotong = 0, totalDikuliti = 0, totalDicacah = 0;
  var totalDistKecil = 0, totalDistKarkas = 0;
  for (var i = 1; i <= 4; i++) {
    var s = dayStates[i];
    if (!s) continue;
    totalTarget += s.totalHewan || 0;
    totalKeluar += totalKeluarDay(s);
    totalDipotong += totalDipotongDay(s);
    totalDikuliti += totalDikulitiDay(s);
    totalDicacah += totalDicacahDay(s) + (s.cacahDariAbf || 0);
    totalDistKecil += s.distribusiKecil ? s.distribusiKecil.selesai || 0 : 0;
    totalDistKarkas += s.distribusiKarkas ? (s.distribusiKarkas.selesaiDomba||0)+(s.distribusiKarkas.selesaiSapi||0) : 0;
  }
  var totalDist = totalDistKecil + totalDistKarkas;

  var html = '<div class="page-header"><div><div class="page-title">Dashboard Keseluruhan</div><div class="page-subtitle">Monitoring operasional qurban semua hari</div></div><div class="page-actions">';
  html += '<button class="btn btn-secondary btn-sm" onclick="enterMonitorMode()">Mode Monitor</button>';
  html += '<button class="btn btn-ghost btn-sm" onclick="refreshAll()">Refresh</button>';
  html += '</div></div>';

  // Stats
  html += '<div class="stats-grid">';
  html += statCardHtml('green','Total Target',totalTarget,'4 Hari','green');
  html += statCardHtml('blue','Keluar Kandang',totalKeluar,pct(totalKeluar,totalTarget)+'% dari total','blue');
  html += statCardHtml('maroon','Penyembelihan',totalDipotong,pct(totalDipotong,totalKeluar||1)+'% dari keluar','maroon');
  html += statCardHtml('maroon','Belum Tersembelih',Math.max(0,totalTarget-totalDipotong),'Sisa','maroon');
  html += statCardHtml('purple','Pengulitan',totalDikuliti,pct(totalDikuliti,totalDipotong||1)+'% dari sembelih','purple');
  html += statCardHtml('amber','Pencacahan',totalDicacah,pct(totalDicacah,totalDikuliti||1)+'% dari kuliti','amber');
  html += statCardHtml('blue','Distribusi',totalDist,pct(totalDist,totalTarget)+'% dari total','blue');
  html += '</div>';

  // Day summary cards
  html += '<div style="font-weight:700;font-size:15px;margin-bottom:16px">Progress per Hari</div>';
  html += '<div class="grid-4" style="margin-bottom:24px">';
  for (var i = 1; i <= 4; i++) {
    var s = dayStates[i] || defaultDayState();
    var p = calcPipeline(s);
    var dist = (s.distribusiKecil&&s.distribusiKecil.lokasi?s.distribusiKecil.lokasi.filter(function(x){return x.status==='selesai'}).length:0) + (s.distribusiKarkas?(s.distribusiKarkas.selesaiDomba||0)+(s.distribusiKarkas.selesaiSapi||0):0);
    var overPct = pct(dist, s.totalHewan || 1);
    html += '<div class="day-summary-card" onclick="document.getElementById(\'dayDropdown\').value=\''+i+'\';switchView(\''+i+'\')">';
    html += '<div class="day-summary-title"><span>Day '+i+'</span><span class="status-badge '+(overPct>=100?'status-selesai':overPct>0?'status-berjalan':'status-belum')+'">'+overPct+'%</span></div>';
    html += '<div style="margin-bottom:12px"><div class="progress-bar"><div class="progress-fill green" style="width:'+overPct+'%"></div></div></div>';
    html += '<div class="day-summary-stats">';
    html += '<div class="day-summary-stat"><span class="ds-label">Target</span><span class="ds-val">'+(s.totalHewan||0)+'</span></div>';
    html += '<div class="day-summary-stat"><span class="ds-label">Keluar</span><span class="ds-val">'+totalKeluarDay(s)+'</span></div>';
    html += '<div class="day-summary-stat"><span class="ds-label">Sembelih</span><span class="ds-val">'+totalDipotongDay(s)+'</span></div>';
    html += '<div class="day-summary-stat"><span class="ds-label">Distribusi</span><span class="ds-val">'+dist+'</span></div>';
    html += '</div></div>';
  }
  html += '</div>';

  // Overall pipeline
  var allPipeline = {total:totalTarget,keluar:totalKeluar,dipotong:totalDipotong,dikuliti:totalDikuliti,karkasTotal:0,abfKeluar:0,dicacah:totalDicacah,packKecil:0,packKarkas:0,distKecil:totalDistKecil,distKarkas:totalDistKarkas};
  for (var i = 1; i <= 4; i++) {
    var s = dayStates[i]; if (!s) continue;
    allPipeline.karkasTotal += s.karkas ? s.karkas.total || 0 : 0;
    allPipeline.abfKeluar += s.abf ? s.abf.keluar || 0 : 0;
    allPipeline.packKecil += s.packingKecil ? s.packingKecil.total || 0 : 0;
    allPipeline.packKarkas += s.packingKarkas ? (s.packingKarkas.domba||0)+(s.packingKarkas.sapi||0) : 0;
  }
  html += '<div class="card" style="margin-top:4px"><div style="font-weight:700;font-size:15px;margin-bottom:16px">Pipeline Keseluruhan</div>';
  html += renderPipelineHtml(allPipeline);
  html += '</div>';
  return html;
}

// ================================================================
// RINGKASAN PER DAY
// ================================================================
function renderRingkasan() {
  var html = '<div class="page-header"><div><div class="page-title">Ringkasan per Day</div><div class="page-subtitle">Perbandingan detail setiap hari</div></div></div>';
  for (var i = 1; i <= 4; i++) {
    var s = dayStates[i] || defaultDayState();
    var p = calcPipeline(s);
    var dist = (s.distribusiKecil&&s.distribusiKecil.lokasi?s.distribusiKecil.lokasi.filter(function(x){return x.status==='selesai'}).length:0)+(s.distribusiKarkas?(s.distribusiKarkas.selesaiDomba||0)+(s.distribusiKarkas.selesaiSapi||0):0);
    var overPct = pct(dist, s.totalHewan||1);
    html += '<div class="card" style="margin-bottom:20px"><div style="font-weight:700;font-size:16px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between"><span>Day '+i+' &mdash; Target: '+(s.totalHewan||0)+'</span><span class="status-badge '+(overPct>=100?'status-selesai':overPct>0?'status-berjalan':'status-belum')+'">'+overPct+'% Selesai</span></div>';
    html += '<div class="stats-grid" style="margin-bottom:16px">';
    html += statCardHtml('green','Keluar',p.keluar,pct(p.keluar,p.total)+'%','green');
    html += statCardHtml('maroon','Sembelih',p.dipotong,pct(p.dipotong,p.keluar||1)+'%','maroon');
    html += statCardHtml('blue','Pengulitan',p.dikuliti,pct(p.dikuliti,p.dipotong||1)+'%','blue');
    html += statCardHtml('purple','Cacah',p.dicacah,pct(p.dicacah,p.dikuliti||1)+'%','purple');
    html += statCardHtml('amber','Distribusi',dist,overPct+'%','amber');
    html += '</div>';
    html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px">';
    html += infoChip('Tanggal',s.tanggal||'-');
    html += infoChip('Mulai',s.waktuMulai||'-');
    html += infoChip('Selesai',s.waktuSelesai||'-');
    html += infoChip('Durasi',durationStr(s.waktuMulai,s.waktuSelesai));
    html += '</div></div>';
  }
  return html;
}

// ================================================================
// PER-DAY DASHBOARD
// ================================================================
function renderDayDashboard(state) {
  var feat = getFeatureConfig(currentView);
  var p = calcPipeline(state);
  var dist = p.distKecil + p.distKarkas;
  var overPct = pct(dist, p.total || 1);

  var html = '<div class="page-header"><div><div class="page-title">Dashboard Day '+currentView+'</div><div class="page-subtitle">Monitoring operasional qurban hari ke-'+currentView+'</div></div><div class="page-actions">';
  html += '<button class="btn btn-secondary btn-sm" onclick="enterMonitorMode()">Mode Monitor</button>';
  html += '<button class="btn btn-ghost btn-sm" onclick="refreshAll()">Refresh</button>';
  html += '<button class="btn btn-danger btn-sm admin-only" onclick="forceRefreshAllDevices()">Refresh All Device</button>';
  html += '<button class="btn btn-primary btn-sm" onclick="exportExcel()">Export Excel</button>';
  html += '</div></div>';

  // Stats - percentages relative to upstream step (consistent with pipeline)
  html += '<div class="stats-grid">';
  html += statCardHtml('green','Total Target',p.total,'Target','green');
  if (feat.kandang) html += statCardHtml('blue','Keluar Kandang',p.keluar,pct(p.keluar,p.total)+'% dari total','blue');
  if (feat.sembelih) html += statCardHtml('maroon','Penyembelihan',p.dipotong,pct(p.dipotong,p.keluar||1)+'% dari keluar','maroon');
  if (feat.sembelih) html += statCardHtml('maroon','Belum Tersembelih',Math.max(0,p.total-p.dipotong),'Sisa','maroon');
  if (feat.pengulitan) html += statCardHtml('purple','Pengulitan',p.dikuliti,pct(p.dikuliti,p.dipotong||1)+'% dari sembelih','purple');
  if (feat.karkas) html += statCardHtml('amber','Karkas',p.karkasTotal,pct(p.karkasTotal,p.dikuliti||1)+'% dari kuliti','amber');
  if (feat.abf) html += statCardHtml('blue','ABF Keluar',p.abfKeluar,pct(p.abfKeluar,p.karkasTotal||1)+'% dari karkas','blue');
  if (feat.cacah) html += statCardHtml('purple','Pencacahan',p.dicacah,pct(p.dicacah,p.dikuliti||1)+'% dari kuliti','purple');
  if (feat.packingKecil) html += statCardHtml('blue','Packing Kecil',p.packKecil,pct(p.packKecil,p.dicacah||1)+'% dari cacah','blue');
  if (feat.packingKarkas) html += statCardHtml('amber','Packing Karkas',p.packKarkas,pct(p.packKarkas,p.karkasTotal||1)+'% dari karkas','amber');
  if (feat.distribusiKecil) html += statCardHtml('green','Dist. Kecil',p.distKecil,pct(p.distKecil,p.packKecil||1)+'% dari packing','green');
  if (feat.distribusiKarkas) html += statCardHtml('green','Dist. Karkas',p.distKarkas,pct(p.distKarkas,p.packKarkas||1)+'% dari packing','green');
  html += '</div>';

  // Progress bar
  html += '<div class="card" style="margin-bottom:20px"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px"><div style="font-weight:700;font-size:15px">Progress Keseluruhan</div><div class="mono" style="font-weight:700;color:var(--green)">'+overPct+'%</div></div>';
  html += '<div class="progress-bar" style="height:12px;margin-bottom:16px"><div class="progress-fill green" style="width:'+overPct+'%"></div></div>';
  html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px">';
  html += infoChip('Waktu Mulai',state.waktuMulai);
  html += infoChip('Waktu Selesai',state.waktuSelesai||(overPct>=100?'Selesai':'Berjalan...'));
  html += infoChip('Durasi',durationStr(state.waktuMulai,state.waktuSelesai));
  html += '</div></div>';

  // Pipeline
  html += '<div class="card"><div style="font-weight:700;font-size:15px;margin-bottom:16px">Pipeline Proses</div>';
  html += renderPipelineHtml(p, feat);
  html += '</div>';
  return html;
}

