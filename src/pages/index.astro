// ================================================================
let dashEditMode = false;
let monitorMode = false;
const defaultLayout = {order:['stat-total','stat-sembelih','stat-keluar','stat-distribusi','big-kuliti','big-karkas','big-packing','progress'],hidden:[]};

const widgetRegistry = [
  {id:'clock', name:'Jam Realtime', desc:'Jam digital WIB ukuran besar', wide:false, removable:true},
  {id:'tanggal', name:'Tanggal & Hari', desc:'Tanggal qurban dan hari ini', wide:false, removable:true},
  {id:'stat-total', name:'Total Hewan', desc:'Statistik total hewan qurban', wide:false},
  {id:'stat-sembelih', name:'Tersembelih', desc:'Jumlah hewan tersembelih', wide:false},
  {id:'stat-keluar', name:'Keluar Kandang', desc:'Jumlah hewan keluar dari kandang', wide:false},
  {id:'stat-distribusi', name:'Distribusi', desc:'Jumlah distribusi selesai', wide:false},
  {id:'big-kuliti', name:'Kartu Hewan Terkuliti', desc:'Kartu besar progress kuliti', wide:false},
  {id:'big-karkas', name:'Kartu Hewan Terkarkas', desc:'Kartu besar progress karkas', wide:false},
  {id:'big-packing', name:'Kartu Packing Selesai', desc:'Kartu besar progress packing', wide:false},
  {id:'progress', name:'Progress Keseluruhan', desc:'Bar progress & waktu operasional', wide:true},
];

function loadLayout() {
  try {
    const raw = localStorage.getItem('qurbanLayout');
    if (!raw) return {order:[...defaultLayout.order], hidden:[], sizes:{}};
    const parsed = JSON.parse(raw);
    const order = (parsed.order || defaultLayout.order).filter(x => x !== 'processList').map(x => x === 'stat-kuliti' ? 'stat-keluar' : x);
    return {order, hidden: (parsed.hidden||[]).filter(x => x !== 'processList'), sizes: parsed.sizes || {}, spans: parsed.spans || {}};
  } catch(e) { return {order:[...defaultLayout.order], hidden:[], sizes:{}, spans:{}}; }
}

function saveLayout(layout) {
  localStorage.setItem('qurbanLayout', JSON.stringify(layout));
}

function createWidgetEl(id) {
  const reg = widgetRegistry.find(w => w.id === id);
  const title = reg ? reg.name : id;
  const layout = loadLayout();
  const sizes = layout.sizes || {};
  const spans = layout.spans || {};
  const size = sizes[id] || 100;
  const span = spans[id] || (reg && reg.wide ? 4 : 1);
  const div = document.createElement('div');
  div.className = 'dash-widget';
  div.dataset.widget = id;
  div.setAttribute('draggable','true');
  if (span > 1) div.style.gridColumn = 'span '+span;
  div.innerHTML =
    '<div class="dash-widget-bar"><span class="dash-widget-grip">⠿</span><span class="dash-widget-title">'+title+'</span>'+
    '<div class="dash-widget-span"><label>W</label><select>'+
    '<option value="1"'+(span===1?' selected':'')+'>1</option>'+
    '<option value="2"'+(span===2?' selected':'')+'>2</option>'+
    '<option value="3"'+(span===3?' selected':'')+'>3</option>'+
    '<option value="4"'+(span===4?' selected':'')+'>Full</option>'+
    '</select></div>'+
    '<div class="dash-widget-size"><label>Aa</label><input type="range" min="50" max="200" step="10" value="'+size+'"><span>'+size+'%</span></div>'+
    '<button class="dash-widget-toggle">👁</button></div>'+
    '<div class="dash-widget-body" id="dw-'+id+'" style="font-size:'+size+'%"></div>';
  return div;
}

function applyLayout() {
  const layout = loadLayout();
  const container = document.getElementById('dashWidgetContainer');
  if (!container) return;
  container.innerHTML = '';
  layout.order.forEach(id => {
    const el = createWidgetEl(id);
    if (layout.hidden.includes(id)) {
      el.classList.add('hidden-widget');
      const btn = el.querySelector('.dash-widget-toggle');
      if (btn) { btn.textContent = '🚫'; btn.classList.add('off'); }
    }
    container.appendChild(el);
    bindWidgetEvents(el);
  });
}

function renderWidgetContent(id) {
  const el = document.getElementById('dw-'+id);
  if (!el) return;
  const total = state.totalHewan;
  const dipotong = totalDipotong();
  const dikuliti = totalDikuliti();
  const karkas = state.karkas.sudah || 0;
  const distrib = state.distribusi.selesai || 0;
  const packing = state.distribusi.packingSelesai || 0;
  const totalPack = state.distribusi.totalPacking || 0;

  switch(id) {
    case 'clock':
      if (!el.querySelector('.clock-widget')) {
        el.innerHTML = '<div class="clock-widget"><div class="clock-widget-label">Waktu Saat Ini</div><div class="clock-widget-time" id="widgetClock">--:--:--</div></div>';
      }
      const now = new Date();
      const cEl = document.getElementById('widgetClock');
      if (cEl) cEl.textContent = now.toLocaleTimeString('id-ID', {timeZone:'Asia/Jakarta',hour12:false,hour:'2-digit',minute:'2-digit',second:'2-digit'});
      break;
    case 'tanggal':
      el.innerHTML = '<div class="clock-widget"><div class="clock-widget-label">Tanggal Qurban</div><div class="clock-widget-time" style="font-size:2em;color:var(--blue)">'+(state.tanggal||'—')+'</div><div class="clock-widget-date">Mulai: '+(state.waktuMulai||'—')+' WIB</div></div>';
      break;
    case 'stat-total': el.innerHTML = statCard('green','Total Hewan',total,'Target','green'); break;
    case 'stat-sembelih': el.innerHTML = statCard('blue','Tersembelih',dipotong,pct(dipotong,total)+'%','blue'); break;
    case 'stat-keluar': { const kel = totalKeluar(); el.innerHTML = statCard('amber','Keluar Kandang',kel,pct(kel,total)+'%','amber'); break; }
    case 'stat-distribusi': el.innerHTML = statCard('maroon','Distribusi Selesai',distrib,pct(distrib,total)+'%','maroon'); break;
    case 'big-kuliti': el.innerHTML = bigStat('teal','Hewan Terkuliti',dikuliti,total,pct(dikuliti,total)); break;
    case 'big-karkas': el.innerHTML = bigStat('orange','Hewan Terkarkas',karkas,total,pct(karkas,total)); break;
    case 'big-packing': el.innerHTML = bigStat('violet','Packing Selesai',packing,totalPack,pct(packing,totalPack||1)); break;
    case 'progress': {
      const overallPct = pct(distrib, total);
      el.innerHTML =
        '<div class="card progress-widget-card"><div class="monitor-progress-head">'+
        '<div class="monitor-progress-title">Progress Keseluruhan</div>'+
        '<div class="mono monitor-progress-pct">'+overallPct+'%</div></div>'+
        '<div style="margin-bottom:16px"><div class="progress-bar"><div class="progress-fill green" style="width:'+overallPct+'%"></div></div></div>'+
        '<div class="monitor-progress-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px">'+
        '<div class="info-chip"><div class="info-chip-label">Waktu Mulai</div><div class="info-chip-val mono">'+(state.waktuMulai||'—')+'</div></div>'+
        '<div class="info-chip"><div class="info-chip-label">Waktu Selesai</div><div class="info-chip-val mono">'+(state.waktuSelesai||(overallPct>=100?'Selesai':'Berjalan...'))+'</div></div>'+
        '<div class="info-chip"><div class="info-chip-label">Durasi</div><div class="info-chip-val mono">'+durationStr(state.waktuMulai,state.waktuSelesai)+'</div></div>'+
        '</div></div>';
      break;
    }
  }
}

