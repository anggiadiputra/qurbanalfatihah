function renderInputPage(state) {
  var feat = getFeatureConfig(currentView);
  var html = '<div class="page-header"><div><div class="page-title">Input Data</div><div class="page-subtitle">Data otomatis tersimpan saat diubah</div></div><div class="page-actions"><span class="autosave-badge"><span class="autosave-dot"></span> Auto-save aktif</span></div></div>';

  // Data Umum
  html += '<div class="form-section"><div class="form-section-title">Data Umum Qurban</div><div class="form-grid">';
  html += fg('Total Hewan Qurban','number','inp_totalHewan',state.totalHewan||0);
  html += fg('Tanggal Qurban','date','inp_tanggal',state.tanggal||'');
  html += fg('Waktu Mulai','time','inp_waktuMulai',state.waktuMulai||'');
  html += fg('Waktu Selesai','time','inp_waktuSelesai',state.waktuSelesai||'');
  html += '</div></div>';

  // Kandang
  if (feat.kandang) {
    html += '<div class="form-section"><div class="form-section-title">Data Kandang</div><div class="form-grid">';
    (state.kandang||[]).forEach(function(k) {
      html += fg('Kandang #'+k.no+' Keluar','number','f_kandang_keluar_'+k.no,k.keluar||0);
    });
    html += fg('Waktu Mulai','time','f_kandang_mulai',state.kandang?.[0]?.waktuMulai||'');
    html += fg('Waktu Selesai','time','f_kandang_selesai',state.kandang?.[0]?.waktuSelesai||'');
    html += '</div></div>';
  }

  // Sembelih
  if (feat.sembelih) {
    html += '<div class="form-section"><div class="form-section-title">Data Penyembelihan</div><div class="form-grid">';
    (state.sembelih||[]).forEach(function(s) {
      html += fg('Lubang #'+s.no+' Dipotong','number','f_sembelih_dipotong_'+s.no,s.dipotong||0);
    });
    html += fg('Waktu Mulai','time','f_sembelih_mulai',state.sembelih?.[0]?.waktuMulai||'');
    html += fg('Waktu Selesai','time','f_sembelih_selesai',state.sembelih?.[0]?.waktuSelesai||'');
    html += '</div></div>';
  }

  // Transit
  if (feat.transit) {
    html += '<div class="form-section"><div class="form-section-title">Data Transit</div><div class="form-grid">';
    html += fg('Kaki & Kepala','number','inp_kakiKepalaTransit',state.transit?.kakiKepala||0);
    html += fg('Waktu Mulai','time','inp_transitMulai',state.transit?.waktuMulai||'');
    html += fg('Waktu Selesai','time','inp_transitSelesai',state.transit?.waktuSelesai||'');
    html += '</div></div>';
  }

  // Pengulitan
  if (feat.pengulitan) {
    html += '<div class="form-section"><div class="form-section-title">Data Pengulitan (6 Lane)</div><div class="form-grid">';
    (state.lane||[]).forEach(function(ln) {
      html += fg('Lane #'+ln.no+' Total','number','f_lane_total_'+ln.no,ln.total||0);
    });
    html += fg('Waktu Mulai','time','inp_pengulitanMulai',state.pengulitanMulai||'');
    html += fg('Waktu Selesai','time','inp_pengulitanSelesai',state.pengulitanSelesai||'');
    html += '</div></div>';
  }

  // Karkas
  if (feat.karkas) {
    html += '<div class="form-section"><div class="form-section-title">Data Karkas</div><div class="form-grid">';
    html += fg('Sudah Karkas','number','inp_karkasTotal',state.karkas?.total||0);
    html += fg('Mulai Karkas','time','inp_karkasMulai',state.karkas?.waktuMulai||'');
    html += fg('Selesai Karkas','time','inp_karkasSelesai',state.karkas?.waktuSelesai||'');
    html += '</div></div>';
  }

  // ABF
  if (feat.abf) {
    html += '<div class="form-section"><div class="form-section-title">Data Keluar ABF</div><div class="form-grid">';
    html += fg('Keluar ABF','number','inp_abfKeluar',state.abf?.keluar||0);
    html += fg('Mulai ABF','time','inp_abfMulai',state.abf?.waktuMulai||'');
    html += fg('Selesai ABF','time','inp_abfSelesai',state.abf?.waktuSelesai||'');
    html += '</div></div>';
  }

  // Cacah
  if (feat.cacah) {
    html += '<div class="form-section"><div class="form-section-title">Data Pencacahan</div><div class="form-grid">';
    (state.cacah||[]).forEach(function(c) {
      html += fg('Meja #'+c.no+' Total','number','f_cacah_total_'+c.no,c.total||0);
    });
    html += fg('Cacah dari ABF','number','inp_cacahDariAbf',state.cacahDariAbf||0);
    html += fg('Waktu Mulai','time','f_cacah_mulai',state.cacah?.[0]?.waktuMulai||'');
    html += fg('Waktu Selesai','time','f_cacah_selesai',state.cacah?.[0]?.waktuSelesai||'');
    html += '</div></div>';
  }

  // Packing Kecil
  if (feat.packingKecil) {
    html += '<div class="form-section"><div class="form-section-title">Data Packing Kecil</div><div class="form-grid">';
    html += fg('Total Box Kecil','number','inp_packKecilTotal',state.packingKecil?.total||0);
    html += fg('Mulai','time','inp_packKecilMulai',state.packingKecil?.waktuMulai||'');
    html += fg('Selesai','time','inp_packKecilSelesai',state.packingKecil?.waktuSelesai||'');
    html += '</div></div>';
  }

  // Packing Karkas
  if (feat.packingKarkas) {
    html += '<div class="form-section"><div class="form-section-title">Data Packing Karkas</div><div class="form-grid">';
    html += fg('Packing Karkas Domba/Kambing','number','inp_packKarkasDomba',state.packingKarkas?.domba||0);
    html += fg('Packing Sapi','number','inp_packKarkasSapi',state.packingKarkas?.sapi||0);
    html += fg('Mulai','time','inp_packKarkasMulai',state.packingKarkas?.waktuMulai||'');
    html += fg('Selesai','time','inp_packKarkasSelesai',state.packingKarkas?.waktuSelesai||'');
    html += '</div></div>';
  }

  // Distribusi Kecil
  if (feat.distribusiKecil) {
    html += '<div class="form-section"><div class="form-section-title">Data Distribusi Kecil</div>';
    html += '<div class="form-grid" style="margin-bottom:16px">';
    html += fg('Waktu Mulai','time','inp_distKecilMulai',state.distribusiKecil?.waktuMulai||'');
    html += fg('Waktu Selesai','time','inp_distKecilWSelesai',state.distribusiKecil?.waktuSelesai||'');
    html += '</div>';
    html += '<div style="font-size:13px;font-weight:700;margin-bottom:12px">Daftar Lokasi Distribusi</div>';
    html += '<div id="distKecilRows">';
    var dkRows = state.distribusiKecil?.lokasi || [];
    if (dkRows.length === 0) {
      html += '<div style="color:var(--text-muted);font-size:12px;margin-bottom:12px">Belum ada lokasi. Klik "+ Tambah Lokasi".</div>';
    } else {
      dkRows.forEach(function(lok, idx) {
        html += '<div style="display:grid;grid-template-columns:24px 1fr;gap:8px;padding:12px 14px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:8px">';
        html += '<span style="font-size:12px;color:var(--text-muted);padding-top:10px">'+(idx+1)+'.</span>';
        html += '<div class="dk-row-inner" style="display:grid;grid-template-columns:1fr auto auto auto;gap:8px;align-items:center">';
        html += '<input type="text" class="form-control" placeholder="Nama lokasi" value="'+(lok.nama||'')+'" style="width:100%" onchange="updateDistKecilRow('+idx+',\'nama\',this.value)">';
        html += '<div class="num-input-wrap" style="width:130px"><button type="button" class="num-btn" onclick="distKecilNumStep('+idx+',-1)">-</button><input type="number" class="form-control" id="dk_jumlah_'+idx+'" value="'+(lok.jumlah||0)+'" min="0" onchange="updateDistKecilRow('+idx+',\'jumlah\',Number(this.value))"><button type="button" class="num-btn" onclick="distKecilNumStep('+idx+',1)">+</button></div>';
        html += '<select class="form-control" style="width:100px" onchange="updateDistKecilRow('+idx+',\'status\',this.value)"><option value="proses"'+(lok.status==='proses'?' selected':'')+'>Proses</option><option value="selesai"'+(lok.status==='selesai'?' selected':'')+'>Selesai</option></select>';
        html += '<button style="background:var(--maroon-light);color:var(--maroon);border:none;border-radius:6px;padding:8px 10px;font-size:12px;font-weight:700;cursor:pointer" onclick="removeDistKecilRow('+idx+')">&#x2715;</button>';
        html += '</div></div>';
      });
    }
    html += '</div>';
    html += '<div style="margin-top:8px"><button class="btn btn-ghost btn-sm" onclick="addDistKecilRow()">+ Tambah Lokasi</button></div>';
    html += '</div>';
  }

  // Distribusi Karkas
  if (feat.distribusiKarkas) {
    html += '<div class="form-section"><div class="form-section-title">Data Distribusi Karkas</div><div class="form-grid">';
    html += fg('Distribusi Karkas Domba/Kambing','number','inp_distKarkasDomba',state.distribusiKarkas?.domba||0);
    html += fg('Selesai Domba/Kambing','number','inp_distKarkasSelesaiDomba',state.distribusiKarkas?.selesaiDomba||0);
    html += fg('Distribusi Sapi ke ABF','number','inp_distKarkasSapi',state.distribusiKarkas?.sapi||0);
    html += fg('Selesai Sapi','number','inp_distKarkasSelesaiSapi',state.distribusiKarkas?.selesaiSapi||0);
    html += fg('Mulai','time','inp_distKarkasMulai',state.distribusiKarkas?.waktuMulai||'');
    html += fg('Selesai Waktu','time','inp_distKarkasWSelesai',state.distribusiKarkas?.waktuSelesai||'');
    html += '</div></div>';
  }

  html += '<div style="display:flex;gap:12px;flex-wrap:wrap" class="admin-only"><button class="btn btn-danger btn-sm" onclick="resetCurrentDay()">Reset Data Day '+currentView+'</button></div>';
  return html;
}

function fg(label,type,id,val) {
  if (type === 'number') {
    return '<div class="form-group"><label>'+label+'</label><div class="num-input-wrap"><button type="button" class="num-btn" onclick="numStep(\''+id+'\',-1)">-</button><input type="number" class="form-control" id="'+id+'" value="'+(val!=null?val:0)+'" min="0"><button type="button" class="num-btn" onclick="numStep(\''+id+'\',1)">+</button></div></div>';
  }
  return '<div class="form-group"><label>'+label+'</label><input type="'+type+'" class="form-control" id="'+id+'" value="'+(val!=null?val:'')+'"></div>';
}
function numStep(id, dir) {
  var el = document.getElementById(id);
  if (!el) return;
  var v = parseInt(el.value) || 0;
  el.value = Math.max(0, v + dir);
  el.dispatchEvent(new Event('input', {bubbles:true}));
}
function addDistKecilRow() {
  var state = getState(); if (!state) return;
  if (!state.distribusiKecil) state.distribusiKecil = {lokasi:[],waktuMulai:'',waktuSelesai:''};
  if (!state.distribusiKecil.lokasi) state.distribusiKecil.lokasi = [];
  state.distribusiKecil.lokasi.push({nama:'',jumlah:0,status:'proses'});
  saveDayState(currentView);
  renderCurrentPage();
}
function removeDistKecilRow(idx) {
  var state = getState(); if (!state || !state.distribusiKecil || !state.distribusiKecil.lokasi) return;
  state.distribusiKecil.lokasi.splice(idx, 1);
  saveDayState(currentView);
  renderCurrentPage();
}
function updateDistKecilRow(idx, field, val) {
  var state = getState(); if (!state || !state.distribusiKecil || !state.distribusiKecil.lokasi) return;
  if (state.distribusiKecil.lokasi[idx]) state.distribusiKecil.lokasi[idx][field] = val;
  saveDayState(currentView);
}
function distKecilNumStep(idx, dir) {
  var el = document.getElementById('dk_jumlah_'+idx); if (!el) return;
  var v = parseInt(el.value)||0; el.value = Math.max(0, v+dir);
  updateDistKecilRow(idx, 'jumlah', Math.max(0, v+dir));
}
function fgSelect(label,id,current) {
  return '<div class="form-group"><label>'+label+'</label><select class="form-control" id="'+id+'">'+statusOpts(current)+'</select></div>';
}

function collectCurrentFormData() {
  var state = getState();
  if (!state) return;
  var gv = function(id) { var el = document.getElementById(id); return el ? el.value : ''; };
  var gi = function(id) { var v = parseInt(gv(id)); return isNaN(v) ? 0 : v; };

  state.totalHewan = gi('inp_totalHewan');
  state.tanggal = gv('inp_tanggal');
  state.waktuMulai = gv('inp_waktuMulai');
  state.waktuSelesai = gv('inp_waktuSelesai');

  var kandangMulai = gv('f_kandang_mulai'), kandangSelesai = gv('f_kandang_selesai');
  (state.kandang||[]).forEach(function(k) {
    k.keluar = gi('f_kandang_keluar_'+k.no);
    k.waktuMulai = kandangMulai;
    k.waktuSelesai = kandangSelesai;
  });
  var sembelihMulai = gv('f_sembelih_mulai'), sembelihSelesai = gv('f_sembelih_selesai');
  (state.sembelih||[]).forEach(function(s) {
    s.dipotong = gi('f_sembelih_dipotong_'+s.no);
    s.waktuMulai = sembelihMulai;
    s.waktuSelesai = sembelihSelesai;
  });
  if (state.transit) {
    state.transit.kakiKepala = gi('inp_kakiKepalaTransit');
    state.transit.waktuMulai = gv('inp_transitMulai');
    state.transit.waktuSelesai = gv('inp_transitSelesai');
  }
  (state.lane||[]).forEach(function(ln) {
    ln.total = gi('f_lane_total_'+ln.no);
  });
  state.pengulitanMulai = gv('inp_pengulitanMulai');
  state.pengulitanSelesai = gv('inp_pengulitanSelesai');
  if (state.karkas) {
    state.karkas.total = gi('inp_karkasTotal');
    state.karkas.waktuMulai = gv('inp_karkasMulai');
    state.karkas.waktuSelesai = gv('inp_karkasSelesai');
  }
  if (state.abf) {
    state.abf.keluar = gi('inp_abfKeluar');
    state.abf.waktuMulai = gv('inp_abfMulai');
    state.abf.waktuSelesai = gv('inp_abfSelesai');
  }
  var cacahMulai = gv('f_cacah_mulai'), cacahSelesai = gv('f_cacah_selesai');
  (state.cacah||[]).forEach(function(c) {
    c.total = gi('f_cacah_total_'+c.no);
    c.waktuMulai = cacahMulai;
    c.waktuSelesai = cacahSelesai;
  });
  state.cacahDariAbf = gi('inp_cacahDariAbf');
  if (state.packingKecil) {
    state.packingKecil.total = gi('inp_packKecilTotal');
    state.packingKecil.waktuMulai = gv('inp_packKecilMulai');
    state.packingKecil.waktuSelesai = gv('inp_packKecilSelesai');
  }
  if (state.packingKarkas) {
    state.packingKarkas.domba = gi('inp_packKarkasDomba');
    state.packingKarkas.sapi = gi('inp_packKarkasSapi');
    state.packingKarkas.waktuMulai = gv('inp_packKarkasMulai');
    state.packingKarkas.waktuSelesai = gv('inp_packKarkasSelesai');
  }
  if (state.distribusiKecil) {
    state.distribusiKecil.waktuMulai = gv('inp_distKecilMulai');
    state.distribusiKecil.waktuSelesai = gv('inp_distKecilWSelesai');
  }
  if (state.distribusiKarkas) {
    state.distribusiKarkas.domba = gi('inp_distKarkasDomba');
    state.distribusiKarkas.sapi = gi('inp_distKarkasSapi');
    state.distribusiKarkas.selesaiDomba = gi('inp_distKarkasSelesaiDomba');
    state.distribusiKarkas.selesaiSapi = gi('inp_distKarkasSelesaiSapi');
    state.distribusiKarkas.waktuMulai = gv('inp_distKarkasMulai');
    state.distribusiKarkas.waktuSelesai = gv('inp_distKarkasWSelesai');
  }

  // Pipeline validation
  var kel = totalKeluarDay(state), dip = totalDipotongDay(state), kul = totalDikulitiDay(state);
  if (dip > kel) toast('Tersembelih ('+dip+') > Keluar Kandang ('+kel+')','error');
  if (kul > dip) toast('Terkuliti ('+kul+') > Tersembelih ('+dip+')','error');
}

