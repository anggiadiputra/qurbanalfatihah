let dragEl = null;
function bindWidgetEvents(w) {
  const container = document.getElementById('dashWidgetContainer');
  w.addEventListener('dragstart', e => {
    if (!dashEditMode) { e.preventDefault(); return; }
    dragEl = w; w.style.opacity = '0.4';
    e.dataTransfer.effectAllowed = 'move';
  });
  w.addEventListener('dragend', () => {
    if (dragEl) dragEl.style.opacity = '1'; dragEl = null;
    container.querySelectorAll('.dash-widget').forEach(el => el.classList.remove('drag-over'));
  });
  w.addEventListener('dragover', e => {
    if (!dashEditMode || !dragEl || dragEl === w) return;
    e.preventDefault(); e.dataTransfer.dropEffect = 'move';
    container.querySelectorAll('.dash-widget').forEach(el => el.classList.remove('drag-over'));
    w.classList.add('drag-over');
  });
  w.addEventListener('dragleave', () => w.classList.remove('drag-over'));
  w.addEventListener('drop', e => {
    e.preventDefault();
    if (!dragEl || dragEl === w) return;
    w.classList.remove('drag-over');
    const all = Array.from(container.querySelectorAll('.dash-widget'));
    if (all.indexOf(dragEl) < all.indexOf(w)) w.after(dragEl);
    else container.insertBefore(dragEl, w);
    const layout = loadLayout();
    layout.order = Array.from(container.querySelectorAll('.dash-widget')).map(el => el.dataset.widget);
    saveLayout(layout);
  });

  const toggleBtn = w.querySelector('.dash-widget-toggle');
  if (toggleBtn) toggleBtn.addEventListener('click', () => {
    const id = w.dataset.widget;
    const layout = loadLayout();
    const idx = layout.hidden.indexOf(id);
    if (idx >= 0) layout.hidden.splice(idx, 1);
    else layout.hidden.push(id);
    saveLayout(layout);
    w.classList.toggle('hidden-widget');
    const isHidden = w.classList.contains('hidden-widget');
    toggleBtn.textContent = isHidden ? '🚫' : '👁';
    toggleBtn.classList.toggle('off', isHidden);
  });

  const removeBtn = w.querySelector('.dash-widget-remove');
  if (removeBtn) removeBtn.addEventListener('click', () => {
    const id = w.dataset.widget;
    w.remove();
    const layout = loadLayout();
    layout.order = layout.order.filter(x => x !== id);
    layout.hidden = layout.hidden.filter(x => x !== id);
    if (layout.sizes) delete layout.sizes[id];
    saveLayout(layout);
    toast('Widget "'+id+'" dihapus', 'info');
  });

  const sizeSlider = w.querySelector('.dash-widget-size input[type=range]');
  if (sizeSlider) {
    const sizeLabel = w.querySelector('.dash-widget-size span');
    const body = w.querySelector('.dash-widget-body');
    sizeSlider.addEventListener('input', () => {
      const val = sizeSlider.value;
      if (sizeLabel) sizeLabel.textContent = val + '%';
      if (body) body.style.fontSize = val + '%';
      const id = w.dataset.widget;
      const layout = loadLayout();
      if (!layout.sizes) layout.sizes = {};
      layout.sizes[id] = parseInt(val);
      saveLayout(layout);
    });
  }

  const spanSelect = w.querySelector('.dash-widget-span select');
  if (spanSelect) {
    spanSelect.addEventListener('change', () => {
      const val = parseInt(spanSelect.value);
      const id = w.dataset.widget;
      w.style.gridColumn = val > 1 ? 'span '+val : '';
      const layout = loadLayout();
      if (!layout.spans) layout.spans = {};
      layout.spans[id] = val;
      saveLayout(layout);
    });
  }
}

// Widget picker
function openWidgetPicker() {
  renderWidgetPickerList();
  document.getElementById('widgetPickerOverlay').classList.add('visible');
}

function renderWidgetPickerList() {
  const layout = loadLayout();
  const list = document.getElementById('widgetPickerList');
  list.innerHTML = widgetRegistry.map(w => {
    const exists = layout.order.includes(w.id);
    return '<div class="widget-picker-item" data-wid="'+w.id+'">'+
      '<div class="wpi-info"><div class="wpi-name">'+(exists?'✓ ':'')+w.name+'</div><div class="wpi-desc">'+w.desc+'</div></div>'+
      '<button class="btn '+(exists?'btn-danger':'btn-primary')+' btn-sm" style="flex-shrink:0">'+(exists?'Hapus':'Tambah')+'</button>'+
      '</div>';
  }).join('');
}

function setupWidgetPickerDelegation() {
  document.getElementById('widgetPickerList').addEventListener('click', e => {
    const btn = e.target.closest('.btn');
    if (!btn) return;
    const item = btn.closest('.widget-picker-item');
    if (!item) return;
    const wid = item.dataset.wid;
    const layout = loadLayout();
    if (layout.order.includes(wid)) {
      removeWidgetFromLayout(wid);
    } else {
      addWidgetToLayout(wid);
    }
    renderWidgetPickerList();
  });
}

function removeWidgetFromLayout(id) {
  const container = document.getElementById('dashWidgetContainer');
  const el = container.querySelector('[data-widget="'+id+'"]');
  if (el) el.remove();
  const layout = loadLayout();
  layout.order = layout.order.filter(x => x !== id);
  layout.hidden = layout.hidden.filter(x => x !== id);
  if (layout.sizes) delete layout.sizes[id];
  if (layout.spans) delete layout.spans[id];
  saveLayout(layout);
  toast('Widget dihapus', 'info');
}

function addWidgetToLayout(id) {
  const container = document.getElementById('dashWidgetContainer');
  const layout = loadLayout();
  layout.order.push(id);
  saveLayout(layout);
  const el = createWidgetEl(id);
  container.appendChild(el);
  bindWidgetEvents(el);
  renderWidgetContent(id);
  toast('Widget ditambahkan', 'success');
}

// Monitor mode
let monitorSlideIdx = 0;
let monitorWidgets = [];
let monitorInterval = null;
let monitorControlsTimer = null;

function getVisibleWidgetIds() {
  const layout = loadLayout();
  return layout.order.filter(id => !layout.hidden.includes(id));
}

function enterMonitorMode() {
  if (monitorMode) return;
  monitorMode = true;
  monitorWidgets = getVisibleWidgetIds();
  if (monitorWidgets.length === 0) { monitorMode = false; toast('Tidak ada widget aktif','error'); return; }
  monitorSlideIdx = 0;
  document.documentElement.classList.add('monitoring');
  document.body.classList.add('monitoring');
  document.getElementById('monitorOverlay').classList.add('visible');
  renderMonitorSlide();
  renderMonitorDots();
  showMonitorControls();
  if (document.documentElement.requestFullscreen) document.documentElement.requestFullscreen().catch(()=>{});
  monitorInterval = setInterval(() => { renderMonitorSlide(); }, 1000);
}

function exitMonitorMode() {
  if (!monitorMode) return;
  monitorMode = false;
  document.documentElement.classList.remove('monitoring');
  document.body.classList.remove('monitoring');
  const overlay = document.getElementById('monitorOverlay');
  overlay.classList.remove('visible','controls-visible');
  if (monitorInterval) { clearInterval(monitorInterval); monitorInterval = null; }
  if (monitorControlsTimer) { clearTimeout(monitorControlsTimer); monitorControlsTimer = null; }
  if (document.fullscreenElement) document.exitFullscreen().catch(()=>{});
}

function hideMonitorControls() {
  const overlay = document.getElementById('monitorOverlay');
  overlay.classList.remove('controls-visible');
  monitorControlsTimer = null;
}

function showMonitorControls() {
  if (!monitorMode) return;
  const overlay = document.getElementById('monitorOverlay');
  overlay.classList.add('controls-visible');
  if (monitorControlsTimer) clearTimeout(monitorControlsTimer);
  monitorControlsTimer = setTimeout(hideMonitorControls, 1800);
}

function renderMonitorSlide() {
  const id = monitorWidgets[monitorSlideIdx];
  if (!id) return;
  const slide = document.getElementById('monitorSlide');
  const tempDiv = document.createElement('div');
  tempDiv.id = 'dw-' + id;
  tempDiv.className = 'monitor-widget monitor-widget-' + id;
  slide.innerHTML = '';
  slide.appendChild(tempDiv);
  renderWidgetContent(id);
  document.getElementById('monitorInfo').textContent = (monitorSlideIdx+1) + ' / ' + monitorWidgets.length;
}

function renderMonitorDots() {
  const dots = document.getElementById('monitorDots');
  dots.innerHTML = monitorWidgets.map((_, i) =>
    '<div class="monitor-nav-dot'+(i===monitorSlideIdx?' active':'')+'"></div>'
  ).join('');
}

function monitorGo(dir) {
  monitorSlideIdx = (monitorSlideIdx + dir + monitorWidgets.length) % monitorWidgets.length;
  renderMonitorSlide();
  renderMonitorDots();
  showMonitorControls();
}

function toggleMonitorMode() { monitorMode ? exitMonitorMode() : enterMonitorMode(); }

document.addEventListener('keydown', e => {
  if (!monitorMode) return;
  if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); monitorGo(1); }
  else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); monitorGo(-1); }
  else if (e.key === 'Escape') { e.preventDefault(); exitMonitorMode(); }
});
document.addEventListener('fullscreenchange', () => {
  if (!document.fullscreenElement && monitorMode) exitMonitorMode();
});

function setupDashLayout() {
  applyLayout();
  document.getElementById('editLayoutBtn').addEventListener('click', toggleEditLayout);
  document.getElementById('addWidgetBtn').addEventListener('click', openWidgetPicker);
  document.getElementById('widgetPickerClose').addEventListener('click', () => document.getElementById('widgetPickerOverlay').classList.remove('visible'));
  document.getElementById('widgetPickerOverlay').addEventListener('click', e => { if (e.target === e.currentTarget) e.currentTarget.classList.remove('visible'); });
  document.getElementById('monitorModeBtn').addEventListener('click', toggleMonitorMode);
  document.getElementById('monitorExitBtn').addEventListener('click', exitMonitorMode);
  document.getElementById('monitorPrev').addEventListener('click', () => monitorGo(-1));
  document.getElementById('monitorNext').addEventListener('click', () => monitorGo(1));
  document.getElementById('monitorOverlay').addEventListener('mousemove', showMonitorControls);
  document.getElementById('monitorOverlay').addEventListener('mousedown', showMonitorControls);
  setupWidgetPickerDelegation();
}

