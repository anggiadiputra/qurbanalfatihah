---
import { COOKIE_NAME, getRole } from '../lib/auth';
const auth = Astro.cookies.get(COOKIE_NAME)?.value;
const role = getRole(auth) || 'viewer';
---
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Qurban Command Center</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Cabin:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&family=Lato:wght@300;400;700&family=Lexend:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600;700;800&family=Nunito:wght@300;400;500;600;700;800&family=Open+Sans:wght@300;400;500;600;700&family=Poppins:wght@300;400;500;600;700;800&family=Quicksand:wght@300;400;500;600;700&family=Raleway:wght@300;400;500;600;700;800&family=Roboto:wght@300;400;500;700&family=Rubik:wght@300;400;500;600;700&family=Source+Sans+3:wght@300;400;500;600;700&family=Ubuntu:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<style is:global>
:root {
  --bg: #f8f9fc;
  --surface: #ffffff;
  --surface2: #f1f3f9;
  --surface-glass: rgba(255,255,255,.7);
  --border: #e5e7ef;
  --border-light: #eef0f6;
  --text-primary: #111827;
  --text-secondary: #4b5563;
  --text-muted: #9ca3af;
  --green: #10b981;
  --green-light: #d1fae5;
  --green-dark: #059669;
  --blue: #3b82f6;
  --blue-light: #dbeafe;
  --blue-dark: #2563eb;
  --maroon: #e11d48;
  --maroon-light: #ffe4e6;
  --maroon-dark: #be123c;
  --amber: #f59e0b;
  --amber-light: #fef3c7;
  --purple: #8b5cf6;
  --purple-light: #ede9fe;
  --teal: #06b6d4;
  --orange: #f97316;
  --sidebar-w: 250px;
  --sidebar-w-collapsed: 68px;
  --header-h: 60px;
  --radius: 16px;
  --radius-sm: 10px;
  --shadow: 0 1px 3px rgba(0,0,0,.04), 0 1px 2px rgba(0,0,0,.06);
  --shadow-md: 0 4px 20px rgba(0,0,0,.08);
  --shadow-lg: 0 10px 40px rgba(0,0,0,.12);
  --transition: .2s cubic-bezier(.4,0,.2,1);
}
.dark {
  --bg: #0c0f1a;
  --surface: #161b2e;
  --surface2: #1e2438;
  --surface-glass: rgba(22,27,46,.8);
  --border: #2a3150;
  --border-light: #232945;
  --text-primary: #f1f5f9;
  --text-secondary: #94a3b8;
  --text-muted: #64748b;
  --shadow: 0 1px 3px rgba(0,0,0,.3);
  --shadow-md: 0 4px 20px rgba(0,0,0,.4);
  --shadow-lg: 0 10px 40px rgba(0,0,0,.5);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text-primary);min-height:100vh;transition:background var(--transition),color var(--transition);overflow-x:hidden}
button{cursor:pointer;font-family:inherit}
input,select,textarea{font-family:inherit}
.mono{font-family:'JetBrains Mono',monospace}

.app-layout{display:flex;min-height:100vh}

/* Sidebar */
.sidebar{width:var(--sidebar-w);background:var(--surface-glass);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-right:1px solid var(--border-light);position:fixed;top:0;left:0;bottom:0;z-index:100;display:flex;flex-direction:column;transition:width var(--transition),transform var(--transition);overflow:hidden}
.sidebar.collapsed{width:var(--sidebar-w-collapsed)}
.sidebar-brand{height:var(--header-h);display:flex;align-items:center;gap:12px;padding:0 18px;border-bottom:1px solid var(--border-light);flex-shrink:0}
.brand-icon{width:36px;height:36px;background:#EA7E8F;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 2px 8px rgba(234,126,143,.3)}
.brand-text{display:flex;flex-direction:column;overflow:hidden;white-space:nowrap;opacity:1;transition:opacity var(--transition)}
.brand-title{font-weight:800;font-size:14px;color:var(--text-primary);line-height:1.2}
.brand-sub{font-size:10px;color:var(--text-muted);font-weight:500}
.sidebar.collapsed .brand-text{opacity:0;pointer-events:none}
.sidebar-nav{flex:1;overflow-y:auto;padding:12px 0}
.sidebar-nav::-webkit-scrollbar{width:3px}
.sidebar-nav::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.nav-section-label{font-size:10px;font-weight:700;letter-spacing:.1em;color:var(--text-muted);text-transform:uppercase;padding:16px 20px 6px;white-space:nowrap;opacity:1;transition:opacity var(--transition)}
.sidebar.collapsed .nav-section-label{opacity:0}

/* Day Dropdown */
.day-dropdown-wrap{padding:8px 10px 14px;border-bottom:1px solid var(--border-light)}
.day-dropdown{width:100%;padding:9px 14px 9px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);background:var(--surface);color:var(--text-primary);font-size:13px;font-weight:700;cursor:pointer;outline:none;transition:all var(--transition);font-family:inherit;-webkit-appearance:none;-moz-appearance:none;appearance:none;background-image:url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 24 24' fill='none' stroke='%239ca3af' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolyline points='6 9 12 15 18 9'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 12px center;padding-right:32px}
.day-dropdown:focus{border-color:var(--green);box-shadow:0 0 0 3px rgba(16,185,129,.1)}
.sidebar.collapsed .day-dropdown-wrap{padding:4px 6px 10px}
.sidebar.collapsed .day-dropdown{font-size:10px;padding:6px 4px;text-align:center}

.nav-item{display:flex;align-items:center;gap:12px;padding:10px 20px;cursor:pointer;transition:all var(--transition);color:var(--text-secondary);font-size:13px;font-weight:500;white-space:nowrap;position:relative;border-radius:0;margin:1px 0}
.nav-item:hover{background:var(--surface2);color:var(--text-primary)}
.nav-item.active{background:linear-gradient(90deg,rgba(16,185,129,.1),rgba(16,185,129,.05));color:var(--green-dark)}
.dark .nav-item.active{background:linear-gradient(90deg,rgba(16,185,129,.15),rgba(16,185,129,.05));color:var(--green)}
.nav-item.active::before{content:'';position:absolute;left:0;top:6px;bottom:6px;width:3px;background:linear-gradient(180deg,var(--green),var(--teal));border-radius:0 3px 3px 0}
.nav-icon{width:22px;display:flex;align-items:center;justify-content:center;flex-shrink:0;opacity:.7}
.nav-item.active .nav-icon{opacity:1}
.nav-item:hover .nav-icon{opacity:1}
.nav-label{opacity:1;transition:opacity var(--transition)}
.sidebar.collapsed .nav-label{opacity:0;pointer-events:none}

/* Main */
.main-content{margin-left:var(--sidebar-w);width:calc(100% - var(--sidebar-w));flex:0 0 auto;display:flex;flex-direction:column;transition:margin-left var(--transition),width var(--transition);min-width:0}
.sidebar.collapsed ~ .main-content{margin-left:var(--sidebar-w-collapsed);width:calc(100% - var(--sidebar-w-collapsed))}

/* Header */
.header{height:var(--header-h);background:var(--surface-glass);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border-light);display:flex;align-items:center;padding:0 24px;gap:16px;position:sticky;top:0;z-index:90;flex-shrink:0}
.header-toggle{background:none;border:1px solid var(--border);border-radius:var(--radius-sm);width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:var(--text-secondary);transition:all var(--transition)}
.header-toggle:hover{background:var(--surface2);color:var(--text-primary)}
.header-title{font-weight:700;font-size:16px;flex:1}
.header-clock{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text-secondary);background:var(--surface2);padding:6px 14px;border-radius:20px;font-weight:500;border:1px solid var(--border-light)}
.header-actions{display:flex;align-items:center;gap:6px}
.btn-icon{background:none;border:1px solid var(--border);border-radius:var(--radius-sm);width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:var(--text-secondary);transition:all var(--transition);font-size:16px}
.btn-icon:hover{background:var(--surface2);color:var(--text-primary);border-color:var(--text-muted)}

/* Save indicator */
.save-indicator{position:fixed;top:12px;right:24px;z-index:200;background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:6px 14px;font-size:12px;font-weight:600;color:var(--blue);display:none;align-items:center;gap:8px;box-shadow:var(--shadow-md);animation:fadeIn .2s ease}
.save-indicator.visible{display:flex}
.save-dot{width:6px;height:6px;border-radius:50%;background:var(--blue);animation:pulse 1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* Page content */
.page-content{padding:24px;flex:1;animation:fadeIn .3s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px}
.page-title{font-size:22px;font-weight:800;letter-spacing:-.02em}
.page-subtitle{font-size:12px;color:var(--text-muted);margin-top:3px;font-weight:500}
.page-actions{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

/* Buttons */
.btn{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:var(--radius-sm);font-size:13px;font-weight:600;border:none;transition:all var(--transition);cursor:pointer;letter-spacing:-.01em}
.btn-primary{background:linear-gradient(135deg,var(--green),var(--green-dark));color:#fff;box-shadow:0 2px 8px rgba(16,185,129,.25)}
.btn-primary:hover{box-shadow:0 4px 16px rgba(16,185,129,.35);transform:translateY(-1px)}
.btn-secondary{background:linear-gradient(135deg,var(--blue),var(--blue-dark));color:#fff;box-shadow:0 2px 8px rgba(59,130,246,.25)}
.btn-secondary:hover{box-shadow:0 4px 16px rgba(59,130,246,.35);transform:translateY(-1px)}
.btn-danger{background:linear-gradient(135deg,var(--maroon),var(--maroon-dark));color:#fff;box-shadow:0 2px 8px rgba(225,29,72,.2)}
.btn-danger:hover{box-shadow:0 4px 16px rgba(225,29,72,.3);transform:translateY(-1px)}
.btn-ghost{background:var(--surface2);color:var(--text-primary);border:1px solid var(--border)}
.btn-ghost:hover{background:var(--border);border-color:var(--text-muted)}
.btn-sm{padding:7px 14px;font-size:12px}

/* Cards */
.card{background:var(--surface);border-radius:var(--radius);box-shadow:var(--shadow);border:1px solid var(--border-light);padding:22px;transition:all var(--transition)}
.card:hover{box-shadow:var(--shadow-md)}

/* Stat cards */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(185px,1fr));gap:16px;margin-bottom:20px}
.stat-card{background:var(--surface);border-radius:var(--radius);box-shadow:var(--shadow);border:1px solid var(--border-light);padding:20px;display:flex;flex-direction:column;gap:10px;transition:all var(--transition);position:relative;overflow:hidden}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.stat-card.green::before{background:linear-gradient(90deg,var(--green),var(--teal))}
.stat-card.blue::before{background:linear-gradient(90deg,var(--blue),var(--purple))}
.stat-card.maroon::before{background:linear-gradient(90deg,var(--maroon),var(--orange))}
.stat-card.amber::before{background:linear-gradient(90deg,var(--amber),var(--orange))}
.stat-card.purple::before{background:linear-gradient(90deg,var(--purple),var(--blue))}
.stat-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-md)}
.stat-label{font-size:12px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.08em}
.stat-value{font-size:36px;font-weight:800;font-family:'JetBrains Mono',monospace;line-height:1}
.stat-badge{font-size:11px;padding:3px 10px;border-radius:20px;font-weight:600;position:absolute;bottom:12px;right:14px}
.stat-badge.green{background:var(--green-light);color:var(--green-dark)}
.stat-badge.blue{background:var(--blue-light);color:var(--blue-dark)}
.stat-badge.maroon{background:var(--maroon-light);color:var(--maroon)}
.dark .stat-badge.green{background:rgba(16,185,129,.15);color:var(--green)}
.dark .stat-badge.blue{background:rgba(59,130,246,.15);color:var(--blue)}
.dark .stat-badge.maroon{background:rgba(225,29,72,.15);color:#fb7185}

/* Progress */
.progress-wrap{margin-top:4px}
.progress-label-row{display:flex;justify-content:space-between;margin-bottom:6px;font-size:12px}
.progress-label{font-weight:600;color:var(--text-secondary)}
.progress-pct{font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--text-primary)}
.progress-bar{height:8px;background:var(--surface2);border-radius:99px;overflow:hidden}
.progress-fill{height:100%;border-radius:99px;transition:width .8s cubic-bezier(.4,0,.2,1);position:relative;overflow:hidden}
.progress-fill::after{content:'';position:absolute;top:0;left:-100%;bottom:0;width:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.35),transparent);animation:shimmer 2.5s infinite}
@keyframes shimmer{to{left:200%}}
.progress-fill.green{background:linear-gradient(90deg,var(--green),#34d399)}
.progress-fill.blue{background:linear-gradient(90deg,var(--blue),#60a5fa)}
.progress-fill.maroon{background:linear-gradient(90deg,var(--maroon),#f43f5e)}
.progress-fill.amber{background:linear-gradient(90deg,var(--amber),#fbbf24)}
.progress-fill.purple{background:linear-gradient(90deg,var(--purple),#a78bfa)}

/* Grids */
.grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.grid-5{display:grid;grid-template-columns:repeat(5,1fr);gap:16px}
.grid-6{display:grid;grid-template-columns:repeat(6,1fr);gap:16px}
@media(max-width:1200px){.grid-6{grid-template-columns:repeat(4,1fr)}}
@media(max-width:900px){.grid-5,.grid-6{grid-template-columns:repeat(3,1fr)}}
@media(max-width:768px){
  .grid-2,.grid-3,.grid-4,.grid-5,.grid-6{grid-template-columns:repeat(2,1fr)}
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .main-content{margin-left:0!important;width:100%!important}
  .sidebar{transform:translateX(-100%)}
  .sidebar.mobile-open{transform:translateX(0)}
}
@media(max-width:480px){
  .grid-2,.grid-3,.grid-4,.grid-5,.grid-6{grid-template-columns:1fr}
  .stats-grid{grid-template-columns:1fr}
  .dk-row-inner{grid-template-columns:1fr!important}
  .num-input-wrap{width:100%!important}
}

/* Status badges */
.status-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600}
.status-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:currentColor}
.status-selesai{background:var(--green-light);color:var(--green-dark)}
.status-berjalan{background:var(--blue-light);color:var(--blue-dark)}
.status-menunggu{background:var(--amber-light);color:#92400e}
.status-belum{background:var(--maroon-light);color:var(--maroon)}
.dark .status-selesai{background:rgba(16,185,129,.15);color:#34d399}
.dark .status-berjalan{background:rgba(59,130,246,.15);color:#60a5fa}
.dark .status-menunggu{background:rgba(245,158,11,.15);color:var(--amber)}
.dark .status-belum{background:rgba(225,29,72,.15);color:#fb7185}

/* Process row */
.process-row{display:flex;flex-direction:column;gap:10px}
.process-item{background:var(--surface);border-radius:var(--radius);border:1px solid var(--border-light);padding:14px 18px;display:grid;grid-template-columns:32px 1fr auto auto auto;align-items:center;gap:14px;box-shadow:var(--shadow);transition:all var(--transition)}
.process-item:hover{box-shadow:var(--shadow-md);transform:translateX(2px)}
.process-num{font-size:11px;font-weight:700;color:var(--text-muted);font-family:'JetBrains Mono',monospace}
.process-info{min-width:0}
.process-name{font-size:13px;font-weight:600}
.process-sub{font-size:11px;color:var(--text-muted);margin-top:2px}
.process-progress{width:180px}
.process-count{font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:700;text-align:right;min-width:50px}
.process-status{min-width:80px}
@media(max-width:768px){.process-item{grid-template-columns:1fr}.process-progress{width:100%}}

/* Unit cards */
.unit-card{background:var(--surface);border-radius:var(--radius);border:1px solid var(--border-light);padding:16px;box-shadow:var(--shadow);transition:all var(--transition)}
.unit-card:hover{box-shadow:var(--shadow-md);transform:translateY(-2px)}
.unit-card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.unit-num{font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em}
.unit-val{font-size:28px;font-weight:800;font-family:'JetBrains Mono',monospace;margin:4px 0}
.unit-meta{font-size:11px;color:var(--text-muted)}
.unit-times{margin-top:10px;font-size:11px;color:var(--text-muted);display:grid;grid-template-columns:1fr 1fr;gap:6px}
.unit-time-val{font-family:'JetBrains Mono',monospace;font-weight:500;color:var(--text-secondary)}

/* Info chip */
.info-chip{background:var(--surface2);border-radius:var(--radius-sm);padding:12px 16px;border:1px solid var(--border-light)}
.info-chip-label{font-size:11px;color:var(--text-muted);font-weight:600}
.info-chip-val{font-size:15px;font-weight:700;margin-top:4px}

/* Forms */
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;margin-bottom:16px}
.form-group{display:flex;flex-direction:column;gap:6px}
.form-group label{font-size:12px;font-weight:600;color:var(--text-secondary)}
.form-control{padding:10px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);background:var(--surface);color:var(--text-primary);font-size:13px;transition:all var(--transition);outline:none}
input[type=number].form-control{-moz-appearance:textfield}
input[type=number].form-control::-webkit-inner-spin-button,input[type=number].form-control::-webkit-outer-spin-button{-webkit-appearance:none;margin:0}
.num-input-wrap{display:flex;align-items:stretch;gap:0;border:1.5px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;transition:all var(--transition)}
.num-input-wrap:focus-within{border-color:var(--green);box-shadow:0 0 0 3px rgba(16,185,129,.1)}
.num-input-wrap input{flex:1;border:none;padding:10px 6px;background:var(--surface);color:var(--text-primary);font-size:15px;font-weight:700;outline:none;min-width:0;text-align:center;font-family:'JetBrains Mono',monospace}
.num-btn{width:36px;background:var(--surface2);border:none;color:var(--text-secondary);font-size:18px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all var(--transition);user-select:none;flex-shrink:0}
.num-btn:hover{background:var(--green);color:#fff}
.num-btn:active{transform:scale(.95)}
.form-control:focus{border-color:var(--green);box-shadow:0 0 0 3px rgba(16,185,129,.1)}
.form-control:hover{border-color:var(--text-muted)}
.form-section{background:var(--surface);border-radius:var(--radius);border:1px solid var(--border-light);padding:22px;margin-bottom:20px;box-shadow:var(--shadow)}
.form-section-title{font-size:14px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;gap:8px;padding-bottom:12px;border-bottom:1px solid var(--border-light);color:var(--text-primary)}

/* Autosave badge */
.autosave-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:20px;font-size:12px;font-weight:600;color:var(--green-dark);background:var(--green-light);border:1px solid rgba(16,185,129,.2)}
.dark .autosave-badge{background:rgba(16,185,129,.15);color:var(--green);border-color:rgba(16,185,129,.2)}
.autosave-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}

/* Kalet cards */
.kalet-card{background:var(--surface);border-radius:var(--radius-sm);border:1px solid var(--border-light);padding:10px 12px;box-shadow:var(--shadow);transition:all var(--transition);display:flex;flex-direction:column;gap:4px}
.kalet-card:hover{box-shadow:var(--shadow-md);transform:translateY(-1px)}
.kalet-header{display:flex;align-items:center;justify-content:space-between}
.kalet-id{font-size:13px;font-weight:800;font-family:'JetBrains Mono',monospace}
.kalet-val{font-size:22px;font-weight:800;font-family:'JetBrains Mono',monospace;line-height:1}
.kalet-times{display:grid;grid-template-columns:1fr 1fr;gap:4px;font-size:10px;color:var(--text-muted);margin-top:2px}
.kalet-time-val{font-family:'JetBrains Mono',monospace;font-weight:500;color:var(--text-secondary);font-size:11px}
.grid-9{display:grid;grid-template-columns:repeat(9,1fr);gap:10px}
@media(max-width:1400px){.grid-9{grid-template-columns:repeat(7,1fr)}}
@media(max-width:1100px){.grid-9{grid-template-columns:repeat(5,1fr)}}
@media(max-width:768px){.grid-9{grid-template-columns:repeat(3,1fr)}}

/* Toast */
.toast-container{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px}
.toast{background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius-sm);padding:12px 18px;box-shadow:var(--shadow-lg);display:flex;align-items:center;gap:10px;font-size:13px;font-weight:500;min-width:260px;animation:slideUp .3s ease;backdrop-filter:blur(10px)}
@keyframes slideUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.toast.success{border-left:3px solid var(--green)}
.toast.error{border-left:3px solid var(--maroon)}
.toast.info{border-left:3px solid var(--blue)}
.toast-icon{font-size:16px;flex-shrink:0}

/* Settings */
.settings-row{display:flex;align-items:center;justify-content:space-between;padding:16px 0;border-bottom:1px solid var(--border-light)}
.settings-row:last-child{border-bottom:none}
.settings-label{font-size:13px;font-weight:600}
.settings-desc{font-size:12px;color:var(--text-muted);margin-top:3px}
.toggle-switch{width:44px;height:24px;background:var(--border);border-radius:12px;cursor:pointer;position:relative;transition:background var(--transition);border:none;flex-shrink:0}
.toggle-switch.on{background:var(--green)}
.toggle-switch::after{content:'';position:absolute;width:18px;height:18px;background:#fff;border-radius:50%;top:3px;left:3px;transition:left var(--transition);box-shadow:0 1px 4px rgba(0,0,0,.2)}
.toggle-switch.on::after{left:23px}

/* Overlay */
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);z-index:99}
@media(max-width:768px){.sidebar-overlay.active{display:block}}

/* Config overlay */
.config-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);z-index:300;align-items:center;justify-content:center}
.config-overlay.visible{display:flex}
.config-panel{background:var(--surface);border-radius:var(--radius);box-shadow:var(--shadow-lg);padding:24px;width:90%;max-width:500px;max-height:80vh;overflow-y:auto}
.config-panel h3{font-size:16px;font-weight:700;margin-bottom:16px}
.config-item{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border-light)}
.config-item:last-child{border-bottom:none}
.config-item label{flex:1;font-size:13px;font-weight:600;cursor:pointer}
.config-item input[type=checkbox]{width:18px;height:18px;accent-color:var(--green);cursor:pointer}

/* Monitor mode */
html.monitoring,body.monitoring{height:100%;overflow:hidden}
.monitor-overlay{display:none;position:fixed;inset:0;z-index:500;background:var(--bg);flex-direction:column;overflow-y:auto;padding:24px 32px}
.monitor-overlay.visible{display:flex}
.monitor-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-shrink:0}
.monitor-header-left{display:flex;align-items:center;gap:16px}
.monitor-header-title{font-size:20px;font-weight:800}
.monitor-header-clock{font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:700;color:var(--green)}
.monitor-header-date{font-size:13px;color:var(--text-secondary);font-weight:500}
.monitor-exit{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;transition:all var(--transition);color:var(--text-primary)}
.monitor-exit:hover{background:var(--maroon);color:#fff;border-color:var(--maroon)}
.monitor-widget-bar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:20px;padding:12px 16px;background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius-sm)}
.mw-toggle{display:flex;align-items:center;gap:6px;padding:5px 12px;border-radius:20px;font-size:12px;font-weight:600;cursor:grab;border:1px solid var(--border);background:var(--surface2);color:var(--text-secondary);transition:all var(--transition);user-select:none}
.mw-toggle:active{cursor:grabbing}
.mw-toggle.on{background:var(--green);border-color:var(--green);color:#fff}
.mw-toggle:hover{border-color:var(--green)}
.mw-toggle.dragging{opacity:.4}
.mw-toggle.drag-over{margin-left:24px}
.mw-toggle-dot{width:8px;height:8px;border-radius:50%;background:var(--border);transition:background var(--transition)}
.mw-toggle.on .mw-toggle-dot{background:#fff}
.mon-stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:24px}
.mon-stats-grid .stat-card{padding:26px}
.mon-stats-grid .stat-card:hover{transform:none}
.mon-stats-grid .stat-value{font-size:38px}
.mon-stats-grid .stat-label{font-size:14px}
.monitor-overlay .progress-bar{height:12px}
.monitor-overlay .process-name{font-size:16px}
.monitor-overlay .process-count{font-size:16px}
.monitor-overlay .info-chip-val{font-size:18px}
.monitor-overlay .stat-badge{font-size:13px;padding:4px 12px}
.monitor-overlay .card{padding:28px}
.monitor-live-badge{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;color:var(--green);letter-spacing:.04em;animation:monLiveText 3s ease-in-out infinite}
.monitor-live-dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 4px var(--green),0 0 8px rgba(34,197,94,.4);animation:monLiveDot 2s ease-in-out infinite}
@keyframes monLiveDot{0%,100%{box-shadow:0 0 4px var(--green),0 0 8px rgba(34,197,94,.3);opacity:.85}50%{box-shadow:0 0 8px var(--green),0 0 16px rgba(34,197,94,.5);opacity:1}}
@keyframes monLiveText{0%,100%{opacity:.8;letter-spacing:.04em}50%{opacity:1;letter-spacing:.06em}}
.monitor-editor-bar{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius-sm);margin-bottom:20px;flex-wrap:wrap;gap:12px}
.monitor-editor-bar .btn{flex-shrink:0}
.monitor-editor-label{font-size:13px;font-weight:700;color:var(--text-muted)}
.monitor-mode-live .monitor-editor-bar{display:none}
.monitor-mode-live .monitor-widget-bar{display:none}
.monitor-mode-live .monitor-header{padding:0 0 16px}

/* Color picker */
.color-picker{width:44px;height:34px;border:2px solid var(--border);border-radius:var(--radius-sm);padding:2px;cursor:pointer;background:var(--surface)}
.color-picker::-webkit-color-swatch-wrapper{padding:0}
.color-picker::-webkit-color-swatch{border:none;border-radius:4px}

/* Day summary card */
.day-summary-card{background:var(--surface);border-radius:var(--radius);border:1px solid var(--border-light);box-shadow:var(--shadow);padding:22px;transition:all var(--transition);cursor:pointer}
.day-summary-card:hover{box-shadow:var(--shadow-md);transform:translateY(-2px)}
.day-summary-title{font-size:15px;font-weight:700;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between}
.day-summary-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:12px}
.day-summary-stat{display:flex;justify-content:space-between}
.day-summary-stat .ds-label{color:var(--text-muted);font-weight:500}
.day-summary-stat .ds-val{font-weight:700;font-family:'JetBrains Mono',monospace}

/* Search */
.search-bar{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.search-input{flex:1;min-width:200px;padding:9px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);background:var(--surface);color:var(--text-primary);font-size:13px;outline:none;transition:all var(--transition)}
.search-input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(59,130,246,.1)}
.filter-select{padding:9px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);background:var(--surface);color:var(--text-primary);font-size:13px;outline:none;cursor:pointer;transition:all var(--transition)}

/* Bar chart */
.bar-chart-big{display:flex;align-items:flex-end;gap:12px;height:180px;padding:16px 0}
.bar-wrap{display:flex;flex-direction:column;align-items:center;flex:1;gap:8px}
.bar-fill{width:100%;border-radius:8px 8px 0 0;min-height:4px;transition:height .8s cubic-bezier(.4,0,.2,1)}
.bar-label{font-size:11px;color:var(--text-muted);font-weight:600;text-align:center}
.bar-val{font-size:14px;font-weight:700;font-family:'JetBrains Mono',monospace}

/* Timeline */
.timeline{display:flex;flex-direction:column;gap:0}
.timeline-item{display:flex;gap:14px;position:relative;padding-bottom:20px}
.timeline-item:last-child{padding-bottom:0}
.timeline-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0;margin-top:4px;position:relative}
.timeline-dot::after{content:'';position:absolute;left:50%;top:12px;width:1.5px;height:calc(100% + 8px);background:var(--border);transform:translateX(-50%)}
.timeline-item:last-child .timeline-dot::after{display:none}
.timeline-dot.green{background:var(--green);box-shadow:0 0 0 4px var(--green-light)}
.timeline-dot.blue{background:var(--blue);box-shadow:0 0 0 4px var(--blue-light)}
.timeline-dot.amber{background:var(--amber);box-shadow:0 0 0 4px var(--amber-light)}
.timeline-dot.maroon{background:var(--maroon);box-shadow:0 0 0 4px var(--maroon-light)}
.timeline-dot.gray{background:var(--border)}
.dark .timeline-dot.green{box-shadow:0 0 0 4px rgba(16,185,129,.15)}
.dark .timeline-dot.blue{box-shadow:0 0 0 4px rgba(59,130,246,.15)}
.dark .timeline-dot.amber{box-shadow:0 0 0 4px rgba(245,158,11,.15)}
.dark .timeline-dot.maroon{box-shadow:0 0 0 4px rgba(225,29,72,.15)}
.timeline-content{flex:1;min-width:0}
.timeline-title{font-size:13px;font-weight:600}
.timeline-meta{font-size:11px;color:var(--text-muted);margin-top:2px}

/* Print */
@media print{.sidebar,.header,.page-actions,.header-actions,.save-indicator,.autosave-badge{display:none!important}.main-content{margin-left:0!important}.page-content{padding:16px}}

/* Auth role */
body[data-role="viewer"] .editor-only{display:none!important}
body[data-role="viewer"] .admin-only{display:none!important}
body[data-role="editor"] .admin-only{display:none!important}
.role-badge{font-size:11px;font-weight:600;padding:4px 12px;border-radius:20px;white-space:nowrap}
.role-badge.admin{background:var(--purple-light);color:var(--purple)}
.role-badge.editor{background:var(--green-light);color:var(--green-dark)}
.role-badge.viewer{background:var(--blue-light);color:var(--blue-dark)}
.dark .role-badge.admin{background:rgba(139,92,246,.15);color:#a78bfa}
.dark .role-badge.editor{background:rgba(16,185,129,.15);color:var(--green)}
.dark .role-badge.viewer{background:rgba(59,130,246,.15);color:var(--blue)}

@media(min-width:1600px){
  .mon-stats-grid{grid-template-columns:repeat(5,1fr)}
  .mon-stats-grid .stat-value{font-size:52px}
  .mon-stats-grid .stat-label{font-size:16px}
  .mon-stats-grid .stat-card{padding:34px}
  .monitor-header-title{font-size:26px}
  .monitor-header-clock{font-size:22px}
  .monitor-overlay .process-name{font-size:18px}
  .monitor-overlay .process-count{font-size:18px}
  .monitor-overlay .info-chip-val{font-size:22px}
  .monitor-overlay .card{padding:34px}
}
@media(min-width:2400px){
  .monitor-overlay{padding:40px 60px}
  .mon-stats-grid .stat-card{padding:44px}
  .mon-stats-grid .stat-value{font-size:68px}
  .mon-stats-grid .stat-label{font-size:20px}
  .monitor-header-title{font-size:34px}
  .monitor-header-clock{font-size:28px}
  .monitor-overlay .process-name{font-size:22px}
  .monitor-overlay .process-count{font-size:22px}
  .monitor-overlay .info-chip-val{font-size:28px}
  .monitor-overlay .card{padding:44px}
  .monitor-live-badge{font-size:14px}
  .monitor-live-dot{width:10px;height:10px}
}
</style>
</head>
<body data-role={role}>

<!-- Toast Container -->
<div class="toast-container" id="toastContainer"></div>

<!-- Feature Config Overlay -->
<div class="config-overlay" id="configOverlay">
  <div class="config-panel">
    <h3>Konfigurasi Fitur <span id="configDayLabel"></span></h3>
    <div id="configChecklist"></div>
    <div style="margin-top:16px;display:flex;gap:8px;justify-content:flex-end">
      <button class="btn btn-ghost btn-sm" onclick="closeConfig()">Tutup</button>
    </div>
  </div>
</div>

<!-- Monitor Overlay -->
<div class="monitor-overlay" id="monitorOverlay">
  <div class="monitor-header">
    <div class="monitor-header-left">
      <div class="monitor-header-title" id="monitorTitle">Qurban Command Center</div>
      <div class="monitor-live-badge"><span class="monitor-live-dot"></span> LIVE</div>
    </div>
    <div style="display:flex;align-items:center;gap:16px">
      <div class="monitor-header-date" id="monitorDate">--</div>
      <div class="monitor-header-clock" id="monitorClock">--:--:--</div>
      <button class="monitor-exit" id="monitorExitBtn">Keluar</button>
    </div>
  </div>
  <div class="monitor-editor-bar" id="monitorEditorBar">
    <div class="monitor-editor-label">Editor Mode - Atur widget monitor</div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-primary btn-sm" onclick="startLiveMonitor()">Tampilkan Monitor</button>
    </div>
  </div>
  <div class="monitor-widget-bar" id="monitorWidgetBar"></div>
  <div id="monitorContent"></div>
</div>

<!-- Sidebar Overlay (Mobile) -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- App Layout -->
<div class="app-layout">
  <!-- Sidebar -->
  <nav class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <div class="brand-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
      </div>
      <div class="brand-text">
        <span class="brand-title">Qurban Center</span>
        <span class="brand-sub">Qurban Command Center</span>
      </div>
    </div>
    <div class="sidebar-nav">
      <div class="day-dropdown-wrap">
        <select class="day-dropdown" id="dayDropdown">
          <option value="all">All Day</option>
          <option value="1">Day 1</option>
          <option value="2">Day 2</option>
          <option value="3">Day 3</option>
          <option value="4">Day 4</option>
        </select>
      </div>
      <div id="sidebarNavItems"></div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="main-content">
    <header class="header">
      <button class="header-toggle" id="sidebarToggle">&#9776;</button>
      <div>
        <div class="header-title" id="headerTitle">Dashboard</div>
      </div>
      <div style="flex:1"></div>
      <div class="header-clock" id="clockDisplay">--:--:-- WIB</div>
      <span class={`role-badge ${role}`}>{role === 'admin' ? 'Admin' : role === 'editor' ? 'Editor' : 'Viewer'}</span>
      <div class="header-actions">
        <button class="btn-icon editor-only" id="configBtn" title="Konfigurasi Fitur" style="display:none">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </button>
        <button class="btn-icon admin-only" id="darkToggleBtn" title="Dark Mode">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <button class="btn-icon" id="exportBtn" title="Export Excel">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </button>
        <button class="btn-icon" id="printBtn" title="Print" onclick="window.print()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        </button>
        <button class="btn-icon" id="logoutBtn" title="Logout">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </header>

    <div class="save-indicator" id="saveIndicator">
      <div class="save-dot"></div><span>Menyimpan...</span>
    </div>

    <div class="page-content" id="pageContent"></div>
  </div>
</div>

<script is:inline>
// ================================================================
// STATE
// ================================================================
var currentView = 'all';
var currentPage = 'dashboard';
var dayStates = {1:null, 2:null, 3:null, 4:null};
var settings = {darkMode:false, theme:{}, autoRefresh:true, featureConfig:{}, monitorWidgets:{}, monitorOrder:[], forceRefreshTs:0};
var lastKnownForceTs = 0;

var defaultFeatures = {
  kandang:true, sembelih:true, transit:true, pengulitan:true,
  karkas:true, abf:false, cacah:true, packingKecil:true,
  packingKarkas:true, distribusiKecil:true, distribusiKarkas:true
};

function getFeatureConfig(day) {
  var saved = settings.featureConfig && settings.featureConfig['day'+day];
  var defaults = {};
  for (var k in defaultFeatures) defaults[k] = defaultFeatures[k];
  if (parseInt(day) >= 2) defaults.abf = true;
  if (saved) { for (var k in saved) defaults[k] = saved[k]; }
  return defaults;
}

function defaultDayState() {
  return {
    totalHewan:0, tanggal:'', waktuMulai:'', waktuSelesai:'',
    kandang: Array.from({length:8},function(_,i){return {no:i+1,total:12,keluar:0,waktuMulai:'',waktuSelesai:'',status:'belum'};}),
    sembelih: Array.from({length:8},function(_,i){return {no:i+1,dipotong:0,waktuMulai:'',waktuSelesai:''};}),
    transit:{kakiKepala:0,hewan:0,waktuMulai:'',waktuSelesai:''},
    lane: Array.from({length:6},function(_,i){return {no:i+1,total:0};}),
    pengulitanMulai:'',pengulitanSelesai:'',
    karkas:{total:0,waktuMulai:'',waktuSelesai:''},
    abf:{keluar:0,waktuMulai:'',waktuSelesai:''},
    cacah: Array.from({length:6},function(_,i){return {no:i+1,total:0,status:'belum',waktuMulai:'',waktuSelesai:''};}),
    cacahDariAbf:0,
    packingKecil:{total:0,waktuMulai:'',waktuSelesai:''},
    distribusiKecil:{lokasi:[],waktuMulai:'',waktuSelesai:''},
    packingKarkas:{domba:0,sapi:0,waktuMulai:'',waktuSelesai:''},
    distribusiKarkas:{domba:0,sapi:0,selesaiDomba:0,selesaiSapi:0,waktuMulai:'',waktuSelesai:''}
  };
}

// ================================================================
// API
// ================================================================
var isSaving=false, pendingSave=false, saveTimeout=null;
var isSettingsSaving=false, pendingSettingsSave=false, settingsSaveTimeout=null;
var autoRefreshInterval=null;
var monitorMode=false, monitorInterval=null;

function migrateState(s) {
  if (!s) return s;
  // kalet → lane migration
  if (!s.lane && s.kalet) {
    s.lane = Array.from({length:6},function(_,i){return {no:i+1,total:0};});
  }
  if (!s.lane) s.lane = Array.from({length:6},function(_,i){return {no:i+1,total:0};});
  if (s.pengulitanMulai === undefined) s.pengulitanMulai = '';
  if (s.pengulitanSelesai === undefined) s.pengulitanSelesai = '';
  // sembelih 10→8
  if (s.sembelih && s.sembelih.length > 8) s.sembelih = s.sembelih.slice(0,8);
  if (s.sembelih && s.sembelih.length < 8) {
    while (s.sembelih.length < 8) s.sembelih.push({no:s.sembelih.length+1,dipotong:0,waktuMulai:'',waktuSelesai:''});
  }
  // transit kaki+kepala merge
  if (s.transit && s.transit.kaki !== undefined && s.transit.kakiKepala === undefined) {
    s.transit.kakiKepala = (s.transit.kaki||0) + (s.transit.kepala||0);
  }
  if (s.transit && s.transit.kakiKepala === undefined) s.transit.kakiKepala = 0;
  // distribusiKecil old format migration
  if (s.distribusiKecil && !s.distribusiKecil.lokasi) {
    s.distribusiKecil = {lokasi:[], waktuMulai:s.distribusiKecil.waktuMulai||'', waktuSelesai:s.distribusiKecil.waktuSelesai||''};
  }
  return s;
}

function loadAllStates() {
  return fetch('/api/day-state?day=all').then(function(r) {
    if (r.ok) return r.json();
    return null;
  }).then(function(d) {
    if (d) { for (var i = 1; i <= 4; i++) dayStates[i] = migrateState(d[String(i)] || defaultDayState()); }
    else { for (var i = 1; i <= 4; i++) if (!dayStates[i]) dayStates[i] = defaultDayState(); }
  }).catch(function() {
    for (var i = 1; i <= 4; i++) if (!dayStates[i]) dayStates[i] = defaultDayState();
  });
}

function saveDayState(day) {
  if (isSaving) { pendingSave = day; return Promise.resolve(); }
  isSaving = true; showSaveIndicator(true);
  return fetch('/api/day-state?day='+day, {method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify(dayStates[day])})
    .catch(function() { toast('Gagal menyimpan','error'); })
    .then(function() {
      isSaving=false; showSaveIndicator(false);
      if (pendingSave) { var d = pendingSave; pendingSave=false; return saveDayState(d); }
    });
}

function loadSettings() {
  return fetch('/api/global-settings').then(function(r){ if(r.ok) return r.json(); return null; })
    .then(function(d){ if(d) settings=d; }).catch(function(){});
}

function saveSettings() {
  if (isSettingsSaving) { pendingSettingsSave=true; return Promise.resolve(); }
  isSettingsSaving=true;
  return fetch('/api/global-settings',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify(settings)})
    .catch(function(){})
    .then(function(){ isSettingsSaving=false; if(pendingSettingsSave){pendingSettingsSave=false; return saveSettings();} });
}

function queueSettingsSave() {
  if (settingsSaveTimeout) clearTimeout(settingsSaveTimeout);
  settingsSaveTimeout = setTimeout(saveSettings, 400);
}

function showSaveIndicator(show) {
  var el = document.getElementById('saveIndicator');
  if (el) el.classList.toggle('visible', show);
}

function queueDaySave(day) {
  if (saveTimeout) clearTimeout(saveTimeout);
  saveTimeout = setTimeout(function() { saveDayState(day); }, 400);
}

// ================================================================
// VIEW SWITCHING
// ================================================================
function switchView(view) {
  currentView = view;
  currentPage = 'dashboard';
  var url = new URL(window.location);
  if (view === 'all') url.searchParams.delete('day');
  else url.searchParams.set('day', view);
  history.replaceState(null, '', url);
  document.getElementById('configBtn').style.display = view === 'all' ? 'none' : '';
  renderSidebar();
  renderCurrentPage();
  updateHeaderTitle();
}

function navigate(page) {
  currentPage = page;
  renderCurrentPage();
  updateHeaderTitle();
  var sb = document.getElementById('sidebar');
  if (window.innerWidth <= 768 && sb.classList.contains('mobile-open')) closeMobileSidebar();
}

function updateHeaderTitle() {
  var titles = {dashboard:'Dashboard',kandang:'Kandang',sembelih:'Penyembelihan',transit:'Transit',pengulitan:'Pengulitan',karkas:'Karkas & ABF',cacah:'Pencacahan',packing:'Packing',distKecil:'Distribusi Kecil',distKarkas:'Distribusi Karkas',input:'Input Data',pengaturan:'Pengaturan',ringkasan:'Ringkasan per Day'};
  var t = titles[currentPage] || currentPage;
  if (currentView !== 'all' && currentPage !== 'pengaturan') t += ' - Day ' + currentView;
  document.getElementById('headerTitle').textContent = t;
}

