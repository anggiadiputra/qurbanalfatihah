  {id:'sembelih',name:'Penyembelihan',on:false},
  {id:'transit',name:'Transit',on:false},
  {id:'pengulitan',name:'Pengulitan',on:false},
  {id:'karkas-abf',name:'Karkas & ABF',on:false},
  {id:'cacah',name:'Pencacahan',on:false},
  {id:'packing',name:'Packing',on:false},
  {id:'distribusi',name:'Distribusi',on:false},
  {id:'waktu',name:'Waktu Proses',on:true},
  {id:'clock',name:'Jam Besar',on:false},
  {id:'day-summary',name:'Ringkasan per Day',on:false}
];

function loadMonitorWidgets() {
  var saved = settings.monitorWidgets;
  if (saved && typeof saved === 'object') {
    monitorWidgetReg.forEach(function(w) { if (saved[w.id] !== undefined) w.on = !!saved[w.id]; });
  }
  var order = settings.monitorOrder;
  if (order && Array.isArray(order) && order.length) {
    var sorted = [];
    order.forEach(function(id) { var w = monitorWidgetReg.find(function(x){return x.id===id}); if(w) sorted.push(w); });
    monitorWidgetReg.forEach(function(w) { if (!sorted.includes(w)) sorted.push(w); });
    monitorWidgetReg.length = 0; sorted.forEach(function(w) { monitorWidgetReg.push(w); });
  }
}

function saveMonitorWidgets() {
  var obj = {};
  monitorWidgetReg.forEach(function(w) { obj[w.id] = w.on; });
  settings.monitorWidgets = obj;
  settings.monitorOrder = monitorWidgetReg.map(function(w) { return w.id; });
  queueSettingsSave();
}

function enterMonitorMode() {
  if (monitorMode) return;
  monitorMode = true;
  loadMonitorWidgets();
  document.documentElement.classList.add('monitoring');
  document.body.classList.add('monitoring');
  document.getElementById('monitorOverlay').classList.add('visible');
  document.getElementById('monitorTitle').textContent = currentView === 'all' ? 'Qurban Command Center' : 'Qurban Command Center - Day ' + currentView;
  renderMonitorWidgetBar();
  renderMonitorDashboard();
  monitorInterval = setInterval(monitorTick, 1000);
}

function startLiveMonitor() {
  document.getElementById('monitorOverlay').classList.add('monitor-mode-live');
  if (document.documentElement.requestFullscreen) document.documentElement.requestFullscreen().catch(function(){});
}

function exitMonitorMode() {
  if (!monitorMode) return;
  var overlay = document.getElementById('monitorOverlay');
  if (overlay.classList.contains('monitor-mode-live')) {
    overlay.classList.remove('monitor-mode-live');
    if (document.fullscreenElement) document.exitFullscreen().catch(function(){});
    return;
  }
  monitorMode = false;
  document.documentElement.classList.remove('monitoring');
  document.body.classList.remove('monitoring');
  overlay.classList.remove('visible');
  if (monitorInterval) { clearInterval(monitorInterval); monitorInterval = null; }
  if (document.fullscreenElement) document.exitFullscreen().catch(function(){});
}

var mwDragEl = null;
function renderMonitorWidgetBar() {
  var bar = document.getElementById('monitorWidgetBar');
  bar.innerHTML = '<span style="font-size:12px;font-weight:700;color:var(--text-muted);margin-right:4px">Widgets:</span>' +
    monitorWidgetReg.map(function(w) {
      return '<div class="mw-toggle' + (w.on ? ' on' : '') + '" data-mw="' + w.id + '" draggable="true">' +
        '<span class="mw-toggle-dot"></span>' + w.name + '</div>';
    }).join('');
  bar.querySelectorAll('.mw-toggle').forEach(function(el) {
    el.addEventListener('dragstart', function(e) { mwDragEl = el; el.classList.add('dragging'); e.dataTransfer.effectAllowed = 'move'; });
    el.addEventListener('dragend', function() { if (mwDragEl) mwDragEl.classList.remove('dragging'); mwDragEl = null; bar.querySelectorAll('.mw-toggle').forEach(function(t) { t.classList.remove('drag-over'); }); });
    el.addEventListener('dragover', function(e) { if (!mwDragEl || mwDragEl === el) return; e.preventDefault(); e.dataTransfer.dropEffect = 'move'; bar.querySelectorAll('.mw-toggle').forEach(function(t) { t.classList.remove('drag-over'); }); el.classList.add('drag-over'); });
    el.addEventListener('dragleave', function() { el.classList.remove('drag-over'); });
    el.addEventListener('drop', function(e) {
      e.preventDefault(); el.classList.remove('drag-over'); if (!mwDragEl || mwDragEl === el) return;
      var fromId = mwDragEl.dataset.mw, toId = el.dataset.mw;
      var fromIdx = monitorWidgetReg.findIndex(function(w) { return w.id === fromId; });
      var toIdx = monitorWidgetReg.findIndex(function(w) { return w.id === toId; });
      if (fromIdx < 0 || toIdx < 0) return;
      var item = monitorWidgetReg.splice(fromIdx, 1)[0]; monitorWidgetReg.splice(toIdx, 0, item);
      widgetToggleCooldown = Date.now() + 5000; saveMonitorWidgets(); renderMonitorWidgetBar(); renderMonitorDashboard();
    });
  });
}

function mwBarChart(bars, title) {
  var maxVal = Math.max.apply(null, bars.map(function(b){return b.v})) || 1;
  var h = '<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:15px;margin-bottom:16px">' + title + '</div><div class="bar-chart-big">';
  bars.forEach(function(b) {
    h += '<div class="bar-wrap"><div class="bar-fill" style="background:'+b.c+';height:'+Math.max(4,b.v/maxVal*100)+'%"></div><div class="bar-val">'+b.v+'</div><div class="bar-label">'+b.l+'</div></div>';
  });
  return h + '</div></div>';
}

function mwPieChart(segments, centerVal, centerLabel, title) {
  var total = 0; segments.forEach(function(s){total+=s.v}); if(!total) total=1;
  var gradParts=[],cum=0;
  segments.forEach(function(s){var p=s.v/total*100;gradParts.push(s.c+' '+cum+'% '+(cum+p)+'%');cum+=p;});
  var h = '<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:15px;margin-bottom:16px">' + title + '</div>';
  h += '<div style="display:flex;align-items:center;justify-content:center;gap:32px;padding:16px 0;flex-wrap:wrap">';
  h += '<div style="width:200px;height:200px;border-radius:50%;position:relative;background:conic-gradient('+gradParts.join(',')+')">';
  h += '<div style="position:absolute;inset:22%;background:var(--surface);border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center">';
  h += '<div style="font-size:28px;font-weight:800;font-family:\'JetBrains Mono\',monospace">'+centerVal+'</div>';
  h += '<div style="font-size:11px;color:var(--text-muted);font-weight:600">'+centerLabel+'</div></div></div>';
  h += '<div style="display:flex;flex-direction:column;gap:10px">';
  segments.forEach(function(s){
    h+='<div style="display:flex;align-items:center;gap:10px;font-size:14px;font-weight:500"><div style="width:12px;height:12px;border-radius:3px;background:'+s.c+';flex-shrink:0"></div>'+s.l+'<span style="font-family:\'JetBrains Mono\',monospace;font-weight:700;margin-left:auto">'+s.v+'</span></div>';
  });
  return h + '</div></div></div>';
}

function mwWaktu(state) {
  return '<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:15px;margin-bottom:16px">Waktu Proses</div>'+
    '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px">'+
    '<div class="info-chip"><div class="info-chip-label">Mulai</div><div class="info-chip-val mono">'+(state.waktuMulai||'-')+'</div></div>'+
    '<div class="info-chip"><div class="info-chip-label">Selesai</div><div class="info-chip-val mono">'+(state.waktuSelesai||'-')+'</div></div>'+
    '<div class="info-chip"><div class="info-chip-label">Durasi</div><div class="info-chip-val mono">'+durationStr(state.waktuMulai,state.waktuSelesai)+'</div></div>'+
    '<div class="info-chip"><div class="info-chip-label">Tanggal</div><div class="info-chip-val mono">'+(state.tanggal||'-')+'</div></div>'+
    '</div></div>';
}

function mwKandang(state) {
  var kelPct = pct(totalKeluarDay(state), state.totalHewan||1);
  var pieGrad = 'conic-gradient(var(--green) 0% '+kelPct+'%, var(--border) '+kelPct+'% 100%)';
  var h = '<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:18px;margin-bottom:20px">Kandang - '+totalKeluarDay(state)+' / '+(state.totalHewan||0)+' Keluar</div>';
  h += '<div style="display:flex;align-items:center;gap:24px;flex-wrap:wrap;margin-bottom:16px"><div style="width:120px;height:120px;border-radius:50%;position:relative;background:'+pieGrad+'"><div style="position:absolute;inset:25%;background:var(--surface);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:800;color:var(--green)">'+kelPct+'%</div></div>';
  h += '<div class="bar-chart-big" style="flex:1;height:120px">';
  (state.kandang||[]).forEach(function(k){var kp=pct(k.keluar||0,k.total||1);h+='<div class="bar-wrap"><div class="bar-fill" style="background:var(--green);height:'+Math.max(4,kp)+'%"></div><div class="bar-val">'+(k.keluar||0)+'</div><div class="bar-label">#'+k.no+'</div></div>';});
  return h + '</div></div></div>';
}

function mwSembelih(state) {
  var h = '<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:18px;margin-bottom:20px">Penyembelihan - '+totalDipotongDay(state)+' dipotong</div>';
  h += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px">';
  (state.sembelih||[]).forEach(function(s){
    var col=s.status==='selesai'?'var(--green)':s.status==='berjalan'?'var(--blue)':'var(--maroon)';
    h+='<div style="background:var(--surface2);border-radius:var(--radius-sm);padding:16px;text-align:center;border-left:4px solid '+col+'"><div style="font-size:13px;font-weight:700;color:var(--text-muted);margin-bottom:6px">Lubang #'+s.no+'</div><div style="font-size:32px;font-weight:800;font-family:\'JetBrains Mono\',monospace;color:'+col+';line-height:1">'+(s.dipotong||0)+'</div><div style="margin-top:8px"><span class="status-badge '+statusClass(s.status)+'" style="font-size:11px">'+statusLabel(s.status)+'</span></div></div>';
  });
  return h + '</div></div>';
}

function mwTransit(state) {
  var t=state.transit||{};
  var dip=totalDipotongDay(state), dik=totalDikulitiDay(state);
  var hewanTransit=Math.max(0,dip-dik);
  return '<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:18px;margin-bottom:20px">Transit - '+hewanTransit+' Menunggu</div>'+
    '<div class="mon-stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(150px,1fr))">'+
    monStatCard('blue','Kaki & Kepala',t.kakiKepala||0,'Tersedia')+monStatCard('amber','Hewan Transit',hewanTransit,'Menunggu')+monStatCard('green','Disembelih',dip,'Total')+monStatCard('purple','Dikuliti',dik,'Total')+
    '</div>'+
    '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:16px">'+infoChip('Mulai',t.waktuMulai)+infoChip('Selesai',t.waktuSelesai)+infoChip('Durasi',durationStr(t.waktuMulai,t.waktuSelesai))+'</div></div>';
}

function mwPengulitan(state) {
  var dik=totalDikulitiDay(state);
  var dip=totalDipotongDay(state);
  var kulPct=pct(dik,dip||1);
  var pieGrad='conic-gradient(var(--blue) 0% '+kulPct+'%, var(--border) '+kulPct+'% 100%)';
  var h='<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:18px;margin-bottom:20px">Pengulitan - '+dik+' / '+(dip||0)+' Dikuliti</div>';
  h+='<div style="display:flex;align-items:center;gap:24px;flex-wrap:wrap;margin-bottom:16px"><div style="width:120px;height:120px;border-radius:50%;position:relative;background:'+pieGrad+'"><div style="position:absolute;inset:25%;background:var(--surface);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:800;color:var(--blue)">'+kulPct+'%</div></div>';
  h+='<div class="bar-chart-big" style="flex:1;height:120px">';
  var lanes=state.lane||[];
  var maxL=1;lanes.forEach(function(ln){if((ln.total||0)>maxL)maxL=ln.total});
  lanes.forEach(function(ln){
    var hp=Math.max(4,(ln.total||0)/maxL*100);
    h+='<div class="bar-wrap"><div class="bar-fill" style="background:var(--blue);height:'+hp+'%"></div><div class="bar-val">'+(ln.total||0)+'</div><div class="bar-label">Lane '+ln.no+'</div></div>';
  });
  return h+'</div></div></div>';
}

function mwKarkasAbf(state, feat) {
  feat = feat || {};
  var kt=state.karkas?state.karkas.total||0:0, ak=state.abf?state.abf.keluar||0:0;
  var h='<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:15px;margin-bottom:16px">Karkas & ABF</div><div class="mon-stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(150px,1fr))">';
  h+=monStatCard('amber','Total Karkas',kt,pct(kt,state.totalHewan||1)+'%');
  if(feat.abf) h+=monStatCard('purple','Keluar ABF',ak,pct(ak,kt||1)+'%');
  h+=monStatCard('blue','Sisa di ABF',Math.max(0,kt-ak),'Tersisa');
  return h+'</div></div>';
}

function mwCacah(state) {
  var dc=totalDicacahDay(state), dab=state.cacahDariAbf||0;
  var h='<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:18px;margin-bottom:20px">Pencacahan - '+dc+' dicacah'+(dab?' (+'+dab+' dari ABF)':'')+'</div>';
  h+='<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px">';
  (state.cacah||[]).forEach(function(c){
    var col=c.status==='selesai'?'var(--green)':c.status==='berjalan'?'var(--blue)':'var(--maroon)';
    h+='<div style="background:var(--surface2);border-radius:var(--radius-sm);padding:18px;border-left:4px solid '+col+'"><div style="font-size:13px;font-weight:700;color:var(--text-muted);margin-bottom:6px">Meja #'+c.no+'</div><div style="font-size:32px;font-weight:800;font-family:\'JetBrains Mono\',monospace;color:'+col+';line-height:1">'+(c.total||0)+'</div><div style="margin-top:8px"><span class="status-badge '+statusClass(c.status)+'" style="font-size:11px">'+statusLabel(c.status)+'</span></div></div>';
  });
  return h+'</div></div>';
}

function mwPacking(state) {
  var pk=state.packingKecil?state.packingKecil.total||0:0, pkk=state.packingKarkas?(state.packingKarkas.domba||0)+(state.packingKarkas.sapi||0):0;
  return '<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:15px;margin-bottom:16px">Packing</div><div class="mon-stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(150px,1fr))">'+
    monStatCard('blue','Packing Kecil',pk,'Pack')+monStatCard('amber','Packing Karkas',pkk,'Karkas')+monStatCard('green','Total',pk+pkk,'Semua')+
    '</div></div>';
}

function mwDistribusi(state) {
  var dkLok=state.distribusiKecil&&state.distribusiKecil.lokasi?state.distribusiKecil.lokasi:[];
  var dk=dkLok.filter(function(x){return x.status==='selesai'}).length;
  var tkecil=dkLok.length;
  var dkk=state.distribusiKarkas?(state.distribusiKarkas.selesaiDomba||0)+(state.distribusiKarkas.selesaiSapi||0):0;
  var tkarkas=state.distribusiKarkas?state.distribusiKarkas.total||0:0;
  return '<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:15px;margin-bottom:16px">Distribusi</div><div class="mon-stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(150px,1fr))">'+
    monStatCard('green','Dist. Kecil',dk+'/'+tkecil,pct(dk,tkecil||1)+'%')+
    monStatCard('amber','Dist. Karkas',dkk+'/'+tkarkas,pct(dkk,tkarkas||1)+'%')+
    monStatCard('blue','Total Selesai',dk+dkk,'Terkirim')+
    '</div></div>';
}

function mwDaySummary() {
  var h='<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:15px;margin-bottom:16px">Ringkasan per Day</div><div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px">';
  for(var i=1;i<=4;i++){
    var s=dayStates[i];if(!s)continue;
    var t=s.totalHewan||0,kel=totalKeluarDay(s),dk=(s.distribusiKecil&&s.distribusiKecil.lokasi?s.distribusiKecil.lokasi.filter(function(x){return x.status==='selesai'}).length:0)+(s.distribusiKarkas?(s.distribusiKarkas.selesaiDomba||0)+(s.distribusiKarkas.selesaiSapi||0):0);
    var p2=pct(dk,t);
    h+='<div style="background:var(--surface2);border-radius:var(--radius-sm);padding:16px;border-left:3px solid var(--green)"><div style="font-size:12px;font-weight:700;color:var(--text-muted);margin-bottom:6px">Day '+i+'</div><div style="font-size:24px;font-weight:800;font-family:\'JetBrains Mono\',monospace;color:var(--green)">'+t+'</div><div style="font-size:11px;color:var(--text-muted);margin-top:4px">Keluar: '+kel+' | Dist: '+dk+'</div><div class="progress-bar" style="margin-top:8px;height:6px"><div class="progress-fill green" style="width:'+p2+'%"></div></div></div>';
  }
  return h+'</div></div>';
}

var monitorTickBusy = false;
var widgetToggleCooldown = 0;
function monitorTick() {
  if (monitorTickBusy) return;
  monitorTickBusy = true;
  var skipSettings = Date.now() < widgetToggleCooldown || isSettingsSaving || pendingSettingsSave;
  loadAllStates().then(function() {
    if (skipSettings) return Promise.resolve();
    return loadSettings();
  }).then(function() {
    if (!skipSettings) {
      if (settings.forceRefreshTs && settings.forceRefreshTs > lastKnownForceTs && lastKnownForceTs > 0) {
        window.location.reload(); return;
      }
      lastKnownForceTs = settings.forceRefreshTs || 0;
      var shouldDark = !!settings.darkMode;
      if (shouldDark !== document.body.classList.contains('dark')) document.body.classList.toggle('dark', shouldDark);
      applyTheme(loadTheme());
      loadMonitorWidgets();
      renderMonitorWidgetBar();
    }
    renderMonitorDashboard();
    monitorTickBusy = false;
  }).catch(function() { monitorTickBusy = false; });
}

function renderMonitorDashboard() {
  var html = '';
  var now = new Date();
  var timeStr = now.toLocaleTimeString('id-ID',{timeZone:'Asia/Jakarta',hour12:false,hour:'2-digit',minute:'2-digit',second:'2-digit'});
  document.getElementById('monitorClock').textContent = timeStr + ' WIB';
  document.getElementById('monitorDate').textContent = now.toLocaleDateString('id-ID',{timeZone:'Asia/Jakarta',weekday:'long',day:'numeric',month:'long',year:'numeric'});

  var procBars = [{l:'Keluar',c:'var(--green)'},{l:'Sembelih',c:'var(--maroon)'},{l:'Pengulitan',c:'var(--blue)'},{l:'Cacah',c:'var(--purple)'},{l:'Distribusi',c:'var(--amber)'}];
  var procPie = [{c:'var(--green)'},{c:'var(--maroon)'},{c:'var(--blue)'},{c:'var(--purple)'},{c:'var(--amber)'}];

  if (currentView === 'all') {
    var tT=0,tK=0,tD=0,tU=0,tC=0,tDist=0;
    for(var i=1;i<=4;i++){var s=dayStates[i];if(!s)continue;tT+=s.totalHewan||0;tK+=totalKeluarDay(s);tD+=totalDipotongDay(s);tU+=totalDikulitiDay(s);tC+=totalDicacahDay(s);tDist+=(s.distribusiKecil&&s.distribusiKecil.lokasi?s.distribusiKecil.lokasi.filter(function(x){return x.status==='selesai'}).length:0)+(s.distribusiKarkas?(s.distribusiKarkas.selesaiDomba||0)+(s.distribusiKarkas.selesaiSapi||0):0);}
    var vals=[tK,tD,tU,tC,tDist];

    monitorWidgetReg.forEach(function(w){
      if(!w.on)return;
      if(w.id==='stats'){var tPK=0,tPKK=0,tDK=0,tDKK=0;for(var j=1;j<=4;j++){var sj=dayStates[j];if(sj){tPK+=(sj.packingKecil?sj.packingKecil.total||0:0);tPKK+=(sj.packingKarkas?(sj.packingKarkas.domba||0)+(sj.packingKarkas.sapi||0):0);tDK+=(sj.distribusiKecil&&sj.distribusiKecil.lokasi?sj.distribusiKecil.lokasi.filter(function(x){return x.status==='selesai'}).length:0);tDKK+=(sj.distribusiKarkas?(sj.distribusiKarkas.selesaiDomba||0)+(sj.distribusiKarkas.selesaiSapi||0):0);}} html+='<div class="mon-stats-grid">'+monStatCard('green','Total Target',tT,'4 Hari')+monStatCard('blue','Keluar',tK,pct(tK,tT)+'%')+monStatCard('maroon','Sembelih',tD,pct(tD,tK||1)+'%')+monStatCard('maroon','Belum Tersembelih',Math.max(0,tT-tD),'Sisa')+monStatCard('purple','Pengulitan',tU,pct(tU,tD||1)+'%')+monStatCard('amber','Cacah',tC,pct(tC,tU||1)+'%')+monStatCard('blue','Packing Kecil',tPK,pct(tPK,tC||1)+'%')+monStatCard('amber','Packing Karkas',tPKK,'Karkas')+monStatCard('green','Dist. Kecil',tDK,pct(tDK,tPK||1)+'%')+monStatCard('amber','Dist. Karkas',tDKK,pct(tDKK,tPKK||1)+'%')+'</div>';}
      if(w.id==='pipeline'){var pp={total:tT,keluar:tK,dipotong:tD,dikuliti:tU,karkasTotal:0,abfKeluar:0,dicacah:tC,packKecil:0,packKarkas:0,distKecil:tDist,distKarkas:0};html+='<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:15px;margin-bottom:16px">Pipeline Proses</div>'+renderPipelineHtml(pp)+'</div>';}
      if(w.id==='chart-bar') html+=mwBarChart(procBars.map(function(b,j){return{v:vals[j],l:b.l,c:b.c}}),'Chart Bar - Proses Utama');
      if(w.id==='chart-pie') html+=mwPieChart(procBars.map(function(b,j){return{v:vals[j],l:b.l,c:b.c}}),pct(tDist,tT)+'%','Progress','Chart Lingkaran - Proses Utama');
      if(w.id==='day-summary') html+=mwDaySummary();
      if(w.id==='clock') html+='<div class="card" style="text-align:center;margin-bottom:24px;padding:32px"><div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px">Waktu WIB</div><div style="font-size:72px;font-weight:800;font-family:\'JetBrains Mono\',monospace;color:var(--green);line-height:1">'+timeStr+'</div></div>';
    });
  } else {
    var state = getState();
    if(state){
      var p = calcPipeline(state);
      var feat = getFeatureConfig(currentView);
      var vals=[p.keluar,p.dipotong,p.dikuliti,p.dicacah,p.distKecil+p.distKarkas];

      monitorWidgetReg.forEach(function(w){
        if(!w.on)return;
        if(w.id==='stats') html+='<div class="mon-stats-grid">'+monStatCard('green','Target',p.total,'Day '+currentView)+monStatCard('blue','Keluar',p.keluar,pct(p.keluar,p.total)+'%')+monStatCard('maroon','Sembelih',p.dipotong,pct(p.dipotong,p.keluar||1)+'%')+monStatCard('maroon','Belum Tersembelih',Math.max(0,p.total-p.dipotong),'Sisa')+monStatCard('purple','Pengulitan',p.dikuliti,pct(p.dikuliti,p.dipotong||1)+'%')+monStatCard('amber','Cacah',p.dicacah,pct(p.dicacah,p.dikuliti||1)+'%')+(feat.karkas?monStatCard('blue','Karkas',p.karkasTotal,pct(p.karkasTotal,p.dikuliti||1)+'%'):'')+(feat.abf?monStatCard('purple','Keluar ABF',p.abfKeluar,pct(p.abfKeluar,p.karkasTotal||1)+'%'):'')+(feat.packingKecil?monStatCard('blue','Packing Kecil',p.packKecil,pct(p.packKecil,p.dicacah||1)+'%'):'')+(feat.packingKarkas?monStatCard('amber','Packing Karkas',p.packKarkas,pct(p.packKarkas,p.karkasTotal||1)+'%'):'')+(feat.distribusiKecil?monStatCard('green','Dist. Kecil',p.distKecil,pct(p.distKecil,p.packKecil||1)+'%'):'')+(feat.distribusiKarkas?monStatCard('amber','Dist. Karkas',p.distKarkas,pct(p.distKarkas,p.packKarkas||1)+'%'):'')+'</div>';
        if(w.id==='pipeline') html+='<div class="card" style="margin-bottom:24px"><div style="font-weight:700;font-size:15px;margin-bottom:16px">Pipeline Proses</div>'+renderPipelineHtml(p,feat)+'</div>';
        if(w.id==='chart-bar') html+=mwBarChart(procBars.map(function(b,j){return{v:vals[j],l:b.l,c:b.c}}),'Chart Bar - Proses Utama');
        if(w.id==='chart-pie') html+=mwPieChart(procBars.map(function(b,j){return{v:vals[j],l:b.l,c:b.c}}),pct(p.distKecil+p.distKarkas,p.total)+'%','Progress','Chart Lingkaran - Proses Utama');
        if(w.id==='kandang') html+=mwKandang(state);
        if(w.id==='sembelih') html+=mwSembelih(state);
        if(w.id==='transit') html+=mwTransit(state);
        if(w.id==='pengulitan') html+=mwPengulitan(state);
        if(w.id==='karkas-abf') html+=mwKarkasAbf(state,feat);
        if(w.id==='cacah') html+=mwCacah(state);
        if(w.id==='packing') html+=mwPacking(state);
        if(w.id==='distribusi') html+=mwDistribusi(state);
        if(w.id==='waktu') html+=mwWaktu(state);
        if(w.id==='clock') html+='<div class="card" style="text-align:center;margin-bottom:24px;padding:32px"><div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px">Waktu WIB</div><div style="font-size:72px;font-weight:800;font-family:\'JetBrains Mono\',monospace;color:var(--green);line-height:1">'+timeStr+'</div></div>';
        if(w.id==='day-summary') html+=mwDaySummary();
      });
    }
  }
  document.getElementById('monitorContent').innerHTML = html;
}

function monStatCard(color, label, value, badge) {
  return '<div class="stat-card ' + color + '"><div class="stat-label">' + label + '</div><div class="stat-value" style="color:var(--' + color + ')">' + value + '</div><div class="stat-badge ' + color + '">' + badge + '</div></div>';
}

// ================================================================
// THEME
// ================================================================
var defaultTheme = {
  font: "'Inter',system-ui,sans-serif",
  primary: '#10b981', secondary: '#3b82f6', accent: '#8b5cf6', success: '#06b6d4', danger: '#e11d48'
};

function hexToHsl(hex) {
  var r = parseInt(hex.slice(1,3),16)/255;
  var g = parseInt(hex.slice(3,5),16)/255;
  var b = parseInt(hex.slice(5,7),16)/255;
  var max = Math.max(r,g,b), min = Math.min(r,g,b);
  var h=0, s=0, l=(max+min)/2;
  if (max !== min) {
    var d = max - min;
    s = l > 0.5 ? d/(2-max-min) : d/(max+min);
    if (max === r) h = ((g-b)/d + (g<b?6:0))/6;
    else if (max === g) h = ((b-r)/d+2)/6;
    else h = ((r-g)/d+4)/6;
  }
  return {h:Math.round(h*360), s:Math.round(s*100), l:Math.round(l*100)};
}

function colorVariant(hex, lighten) {
  var hsl = hexToHsl(hex);
  var nl = Math.max(0, Math.min(100, hsl.l + lighten));
  return 'hsl('+hsl.h+','+hsl.s+'%,'+nl+'%)';
}

function loadTheme() {
  var t = {};
  for (var k in defaultTheme) t[k] = defaultTheme[k];
  if (settings.theme) { for (var k in settings.theme) t[k] = settings.theme[k]; }
  return t;
}

function applyTheme(theme) {
  var root = document.documentElement;
  root.style.setProperty('--font-body', theme.font);
  document.body.style.fontFamily = theme.font;
  root.style.setProperty('--green', theme.primary);
  root.style.setProperty('--green-dark', colorVariant(theme.primary, -12));
  root.style.setProperty('--green-light', colorVariant(theme.primary, 40));
  root.style.setProperty('--blue', theme.secondary);
  root.style.setProperty('--blue-dark', colorVariant(theme.secondary, -12));
  root.style.setProperty('--blue-light', colorVariant(theme.secondary, 40));
  root.style.setProperty('--purple', theme.accent);
  root.style.setProperty('--purple-light', colorVariant(theme.accent, 40));
  root.style.setProperty('--teal', theme.success);
  root.style.setProperty('--maroon', theme.danger);
  root.style.setProperty('--maroon-dark', colorVariant(theme.danger, -12));
  root.style.setProperty('--maroon-light', colorVariant(theme.danger, 40));
}

function setupThemeUI() {
  var theme = loadTheme();
  applyTheme(theme);
}

function bindSettingsListeners() {
  var theme = loadTheme();
  var fontEl = document.getElementById('themeFont');
  if (fontEl) fontEl.addEventListener('change', function() { theme.font = fontEl.value; settings.theme = theme; applyTheme(theme); queueSettingsSave(); });
  var colorMap = {primary:'themeColorPrimary',secondary:'themeColorSecondary',accent:'themeColorAccent',success:'themeColorSuccess',danger:'themeColorDanger'};
  for (var key in colorMap) {
    (function(k) {
      var el = document.getElementById(colorMap[k]);
      if (el) el.addEventListener('input', function() { theme[k] = el.value; settings.theme = theme; applyTheme(theme); queueSettingsSave(); });
    })(key);
  }
  var resetBtn = document.getElementById('resetThemeBtn');
  if (resetBtn) resetBtn.addEventListener('click', function() {
    var def = {};
    for (var k in defaultTheme) def[k] = defaultTheme[k];
    settings.theme = def;
    applyTheme(def);
    queueSettingsSave();
    renderCurrentPage();
  });
  var darkSwitch = document.getElementById('darkModeSwitch');
  if (darkSwitch) darkSwitch.addEventListener('click', function() { toggleDark(); darkSwitch.classList.toggle('on', settings.darkMode); });
  var arSwitch = document.getElementById('autoRefreshSwitch');
  if (arSwitch) arSwitch.addEventListener('click', function() { toggleAutoRefresh(); arSwitch.classList.toggle('on', settings.autoRefresh !== false); });
}

// ================================================================
// DARK MODE
// ================================================================
function toggleDark() {
  document.body.classList.toggle('dark');
  settings.darkMode = document.body.classList.contains('dark');
  queueSettingsSave();
}

// ================================================================
// AUTO REFRESH
// ================================================================
function startAutoRefresh() {
  if (autoRefreshInterval) clearInterval(autoRefreshInterval);
  autoRefreshInterval = setInterval(function() {
    if (currentPage === 'input' || currentPage === 'pengaturan') return;
    loadAllStates().then(function() {
      return loadSettings();
    }).then(function() {
      if (settings.forceRefreshTs && settings.forceRefreshTs > lastKnownForceTs && lastKnownForceTs > 0) {
        window.location.reload(); return;
      }
      lastKnownForceTs = settings.forceRefreshTs || 0;
      var shouldDark = !!settings.darkMode;
      if (shouldDark !== document.body.classList.contains('dark')) document.body.classList.toggle('dark', shouldDark);
      applyTheme(loadTheme());
      renderCurrentPage();
    });
  }, 1000);
}

function toggleAutoRefresh() {
  if (settings.autoRefresh === false) {
    settings.autoRefresh = true;
    startAutoRefresh();
    toast('Auto refresh aktif','info');
  } else {
    settings.autoRefresh = false;
    if (autoRefreshInterval) { clearInterval(autoRefreshInterval); autoRefreshInterval = null; }
    toast('Auto refresh nonaktif','info');
  }
  queueSettingsSave();
}

// ================================================================
// CLOCK
// ================================================================
function startClock() {
  function update() {
    var now = new Date();
    var opts = {timeZone:'Asia/Jakarta', hour12:false, hour:'2-digit', minute:'2-digit', second:'2-digit'};
    var timeRaw = now.toLocaleTimeString('id-ID', opts);
    var el = document.getElementById('clockDisplay');
    if (el) el.textContent = timeRaw + ' WIB';
  }
  update();
  setInterval(update, 1000);
}

// ================================================================
// SIDEBAR TOGGLE
// ================================================================
function toggleSidebar() {
  var sb = document.getElementById('sidebar');
  if (window.innerWidth <= 768) {
    sb.classList.toggle('mobile-open');
    document.getElementById('sidebarOverlay').classList.toggle('active', sb.classList.contains('mobile-open'));
  } else {
    sb.classList.toggle('collapsed');
  }
}

function closeMobileSidebar() {
  document.getElementById('sidebar').classList.remove('mobile-open');
  document.getElementById('sidebarOverlay').classList.remove('active');
}

// ================================================================
// REFRESH
// ================================================================
function refreshAll() {
  window.location.reload();
}
function forceRefreshAllDevices() {
  if (!confirm('Refresh semua device yang terhubung?')) return;
  settings.forceRefreshTs = Date.now();
  saveSettings().then(function() {
    toast('Force refresh dikirim ke semua device','info');
    setTimeout(function(){ window.location.reload(); }, 500);
  });
}

// ================================================================
// RESET
// ================================================================
function resetCurrentDay() {
  if (!confirm('Reset data Day '+currentView+'? Tidak dapat dibatalkan.')) return;
  dayStates[currentView] = defaultDayState();
  saveDayState(currentView).then(function() {
    renderCurrentPage();
    toast('Data Day '+currentView+' direset','info');
  });
}

function resetAllData() {
  if (!confirm('Reset SEMUA data (4 hari)? Tidak dapat dibatalkan.')) return;
  for (var i = 1; i <= 4; i++) dayStates[i] = defaultDayState();
  var saves = [];
  for (var i = 1; i <= 4; i++) saves.push(saveDayState(i));
  Promise.all(saves).then(function() {
    renderCurrentPage();
    toast('Semua data direset','info');
  });
}

// ================================================================
// EXPORT EXCEL
// ================================================================
function exportExcel() {
  if (typeof XLSX === 'undefined') { toast('Library Excel tidak tersedia','error'); return; }
  var wb = XLSX.utils.book_new();

  function styledSheet(data, cols) {
    var ws = XLSX.utils.aoa_to_sheet(data);
    ws['!cols'] = cols;
    return ws;
  }

  if (currentView === 'all') {
    // Summary of all days
    var summary = [['QURBAN COMMAND CENTER'],['Laporan Keseluruhan (4 Hari)'],[]];
    for (var d = 1; d <= 4; d++) {
      var s = dayStates[d] || defaultDayState();
      var p = calcPipeline(s);
      summary.push(['Day '+d]);
      summary.push(['Total Hewan',s.totalHewan||0]);
      summary.push(['Keluar Kandang',p.keluar]);
      summary.push(['Penyembelihan',p.dipotong]);
      summary.push(['Pengulitan',p.dikuliti]);
      summary.push(['Pencacahan',p.dicacah]);
      summary.push(['Distribusi Kecil',p.distKecil]);
      summary.push(['Distribusi Karkas',p.distKarkas]);
      summary.push([]);
    }
    XLSX.utils.book_append_sheet(wb, styledSheet(summary,[{wch:22},{wch:12}]), 'Ringkasan');
  } else {
    var s = getState();
    if (!s) return;
    var summary = [['QURBAN COMMAND CENTER'],['Laporan Day '+currentView],[]];
    summary.push(['Total Hewan',s.totalHewan||0]);
    summary.push(['Tanggal',s.tanggal||'-']);
    summary.push(['Waktu Mulai',s.waktuMulai||'-']);
    summary.push(['Waktu Selesai',s.waktuSelesai||'-']);
    XLSX.utils.book_append_sheet(wb, styledSheet(summary,[{wch:22},{wch:14}]), 'Ringkasan');

    var kandangData = [['No','Kapasitas','Keluar','Status','Mulai','Selesai']];
    (s.kandang||[]).forEach(function(k) { kandangData.push(['Kandang #'+k.no,k.total,k.keluar||0,statusLabel(k.status),k.waktuMulai||'-',k.waktuSelesai||'-']); });
    XLSX.utils.book_append_sheet(wb, styledSheet(kandangData,[{wch:14},{wch:10},{wch:8},{wch:10},{wch:12},{wch:12}]), 'Kandang');

    var sembData = [['No','Dipotong','Status','Mulai','Selesai']];
    (s.sembelih||[]).forEach(function(sb) { sembData.push(['Lubang #'+sb.no,sb.dipotong||0,statusLabel(sb.status),sb.waktuMulai||'-',sb.waktuSelesai||'-']); });
    XLSX.utils.book_append_sheet(wb, styledSheet(sembData,[{wch:12},{wch:10},{wch:10},{wch:12},{wch:12}]), 'Penyembelihan');

    var kaletData = [['ID','Dikuliti','Status','Mulai','Selesai']];
    (s.lane||[]).forEach(function(ln) { kaletData.push(['Lane #'+ln.no,ln.total||0,'-',s.pengulitanMulai||'-',s.pengulitanSelesai||'-']); });
    XLSX.utils.book_append_sheet(wb, styledSheet(kaletData,[{wch:10},{wch:14},{wch:10},{wch:12},{wch:12}]), 'Pengulitan');

    var cacahData = [['No','Dicacah','Status','Mulai','Selesai']];
    (s.cacah||[]).forEach(function(c) { cacahData.push(['Meja #'+c.no,c.total||0,statusLabel(c.status),c.waktuMulai||'-',c.waktuSelesai||'-']); });
    XLSX.utils.book_append_sheet(wb, styledSheet(cacahData,[{wch:10},{wch:14},{wch:10},{wch:12},{wch:12}]), 'Pencacahan');
  }

  var fname = currentView === 'all' ? 'qurban-all-days.xlsx' : 'qurban-day'+currentView+'.xlsx';
  XLSX.writeFile(wb, fname);
  toast('File Excel berhasil diunduh!','success');
}

// ================================================================
// TOAST
// ================================================================
function toast(msg, type) {
  type = type || 'info';
  var container = document.getElementById('toastContainer');
  var icons = {success:'✅',error:'❌',info:'ℹ️'};
  var el = document.createElement('div');
  el.className = 'toast ' + type;
  el.innerHTML = '<span class="toast-icon">'+icons[type]+'</span><span>'+msg+'</span>';
  container.appendChild(el);
  setTimeout(function() {
    el.style.opacity = '0';
    el.style.transform = 'translateY(16px)';
    el.style.transition = 'all .3s';
    setTimeout(function() { el.remove(); }, 300);
  }, 2500);
}

// ================================================================
// EVENT LISTENERS
// ================================================================
function setupEventListeners() {
  document.getElementById('dayDropdown').addEventListener('change', function() { switchView(this.value); });
  document.getElementById('sidebarToggle').addEventListener('click', toggleSidebar);
  document.getElementById('sidebarOverlay').addEventListener('click', closeMobileSidebar);
  document.getElementById('darkToggleBtn').addEventListener('click', toggleDark);
  document.getElementById('configBtn').addEventListener('click', openConfig);
  document.getElementById('exportBtn').addEventListener('click', exportExcel);
  document.getElementById('logoutBtn').addEventListener('click', function() { fetch('/api/login',{method:'DELETE'}).then(function(){ window.location.href='/login'; }); });
  document.getElementById('monitorExitBtn').addEventListener('click', exitMonitorMode);
  document.getElementById('configOverlay').addEventListener('click', function(e) { if (e.target === e.currentTarget) closeConfig(); });

  // Monitor widget toggles
  document.addEventListener('click', function(e) {
    var tog = e.target.closest('.mw-toggle');
    if (!tog) return;
    var id = tog.dataset.mw;
    var w = monitorWidgetReg.find(function(x) { return x.id === id; });
    if (!w) return;
    w.on = !w.on;
    tog.classList.toggle('on', w.on);
    widgetToggleCooldown = Date.now() + 5000;
    saveMonitorWidgets();
    renderMonitorDashboard();
  });

  // Escape key for monitor
  document.addEventListener('keydown', function(e) {
    if (monitorMode && e.key === 'Escape') { e.preventDefault(); exitMonitorMode(); }
  });
  document.addEventListener('fullscreenchange', function() {
    var overlay = document.getElementById('monitorOverlay');
    if (!document.fullscreenElement && monitorMode && overlay.classList.contains('monitor-mode-live')) {
      overlay.classList.remove('monitor-mode-live');
    }
  });
}

// Bind settings listeners after rendering pengaturan
var _origRender = renderCurrentPage;
renderCurrentPage = function() {
  _origRender();
  if (currentPage === 'pengaturan') bindSettingsListeners();
};

// ================================================================
// INIT
// ================================================================
document.addEventListener('DOMContentLoaded', function() {
  var params = new URLSearchParams(window.location.search);
  var dayParam = params.get('day');
  if (dayParam && ['1','2','3','4'].includes(dayParam)) currentView = dayParam;

  startClock();
  loadSettings().then(function() {
    if (settings.darkMode) document.body.classList.add('dark');
    lastKnownForceTs = settings.forceRefreshTs || 0;
    setupThemeUI();
    return loadAllStates();
  }).then(function() {
    document.getElementById('dayDropdown').value = currentView;
    renderSidebar();
    renderCurrentPage();
    setupEventListeners();
    if (settings.autoRefresh !== false) startAutoRefresh();
  });
});
</script>

