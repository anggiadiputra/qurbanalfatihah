// ================================================================
// DISTRIBUSI KECIL PAGE
// ================================================================
function renderDistKecilPage(state) {
  var dk = state.distribusiKecil||{};
  var dkL = dk.lokasi||[];
  var dkS = dkL.filter(function(x){return x.status==='selesai'}).length;
  var dkT = dkL.length;
  var dkJumlah = dkL.reduce(function(a,x){return a+(x.jumlah||0)},0);
  var p1 = pct(dkS, dkT||1);
  var html = '<div class="page-header"><div><div class="page-title">Distribusi Kecil</div><div class="page-subtitle">Monitoring distribusi packing kecil</div></div></div>';
  html += '<div class="stats-grid">';
  html += statCardHtml('green','Selesai',dkS,pct(dkS,dkT||1)+'%','green');
  html += statCardHtml('blue','Proses',dkT-dkS,'Berjalan','blue');
  html += statCardHtml('amber','Total Lokasi',dkT,'Lokasi','amber');
  html += statCardHtml('purple','Total Unit',dkJumlah,'Unit','purple');
  html += '</div>';
  html += '<div class="card" style="margin-bottom:20px"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px"><div style="font-weight:700;font-size:16px">Daftar Lokasi - '+dkS+' / '+dkT+' Selesai</div></div>';
  html += '<div class="progress-wrap" style="margin-bottom:16px"><div class="progress-label-row"><span class="progress-label">Progress</span><span class="progress-pct">'+p1+'%</span></div><div class="progress-bar" style="height:10px"><div class="progress-fill green" style="width:'+p1+'%"></div></div></div>';
  if (dkL.length > 0) {
    html += '<div style="overflow-x:auto;border:1px solid var(--border-light);border-radius:var(--radius-sm)"><table style="width:100%;border-collapse:collapse"><thead><tr><th style="background:var(--surface2);padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em">#</th><th style="background:var(--surface2);padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em">Lokasi</th><th style="background:var(--surface2);padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em">Jumlah</th><th style="background:var(--surface2);padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em">Status</th></tr></thead><tbody>';
    dkL.forEach(function(lok, idx) {
      var badge = lok.status === 'selesai' ? 'status-selesai' : 'status-berjalan';
      var label = lok.status === 'selesai' ? 'Selesai' : 'Proses';
      html += '<tr><td style="padding:12px 16px;border-bottom:1px solid var(--border-light);font-family:\'JetBrains Mono\',monospace;color:var(--text-muted);font-size:13px">'+String(idx+1).padStart(2,'0')+'</td><td style="padding:12px 16px;border-bottom:1px solid var(--border-light);font-weight:600;font-size:14px">'+(lok.nama||'-')+'</td><td style="padding:12px 16px;border-bottom:1px solid var(--border-light);font-family:\'JetBrains Mono\',monospace;font-weight:700;font-size:15px">'+(lok.jumlah||0)+'</td><td style="padding:12px 16px;border-bottom:1px solid var(--border-light)"><span class="status-badge '+badge+'">'+label+'</span></td></tr>';
    });
    html += '</tbody></table></div>';
  } else {
    html += '<div style="text-align:center;padding:24px;color:var(--text-muted);font-size:13px">Belum ada data lokasi distribusi</div>';
  }
  html += '<div style="margin-top:16px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">'+infoChip('Mulai',dk.waktuMulai)+infoChip('Selesai',dk.waktuSelesai)+infoChip('Durasi',durationStr(dk.waktuMulai,dk.waktuSelesai))+'</div></div>';
  return html;
}

