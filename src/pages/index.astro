  html += '<div class="settings-row"><div><div class="settings-label">Auto Refresh</div><div class="settings-desc">Refresh data setiap 1 detik</div></div><button class="toggle-switch'+(settings.autoRefresh!==false?' on':'')+'" id="autoRefreshSwitch"></button></div>';
  html += '<div class="settings-row"><div><div class="settings-label">Export Excel</div><div class="settings-desc">Download semua data</div></div><button class="btn btn-secondary btn-sm" onclick="exportExcel()">Download</button></div>';
  html += '<div class="settings-row editor-only"><div><div class="settings-label">Reset Semua Data</div><div class="settings-desc">Hapus seluruh data</div></div><button class="btn btn-danger btn-sm" onclick="resetAllData()">Reset</button></div>';
  html += '<div class="settings-row"><div><div class="settings-label">Versi</div><div class="settings-desc">Qurban Command Center</div></div><span style="font-size:12px;color:var(--text-muted);font-family:\'JetBrains Mono\',monospace">v2.0.0</span></div>';
  html += '</div>';
  return html;
}

// ================================================================
// CONFIG OVERLAY
// ================================================================
function openConfig() {
  var day = currentView;
  if (day === 'all') return;
  var feat = getFeatureConfig(day);
  var items = [
    {id:'kandang',label:'Kandang'},{id:'sembelih',label:'Penyembelihan'},{id:'transit',label:'Transit'},
    {id:'pengulitan',label:'Pengulitan'},{id:'karkas',label:'Karkas'},{id:'abf',label:'Keluar ABF'},
    {id:'cacah',label:'Pencacahan'},{id:'packingKecil',label:'Packing Kecil'},{id:'packingKarkas',label:'Packing Karkas'},
    {id:'distribusiKecil',label:'Distribusi Kecil'},{id:'distribusiKarkas',label:'Distribusi Karkas'}
  ];
  document.getElementById('configDayLabel').textContent = '- Day ' + day;
  document.getElementById('configChecklist').innerHTML = items.map(function(it) {
    return '<div class="config-item"><input type="checkbox" id="cfg-'+it.id+'" '+(feat[it.id]?'checked':'')+' onchange="toggleFeature(\''+it.id+'\',this.checked)"><label for="cfg-'+it.id+'">'+it.label+'</label></div>';
  }).join('');
  document.getElementById('configOverlay').classList.add('visible');
}

function closeConfig() { document.getElementById('configOverlay').classList.remove('visible'); }

function toggleFeature(id, on) {
  if (!settings.featureConfig) settings.featureConfig = {};
  var key = 'day' + currentView;
  if (!settings.featureConfig[key]) {
    settings.featureConfig[key] = {};
    for (var k in defaultFeatures) settings.featureConfig[key][k] = defaultFeatures[k];
  }
  settings.featureConfig[key][id] = on;
  queueSettingsSave();
  renderSidebar();
  renderCurrentPage();
}

