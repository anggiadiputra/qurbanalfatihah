  html += '<div class="progress-wrap" style="margin-bottom:16px"><div class="progress-label-row"><span class="progress-label">Sapi</span><span class="progress-pct">'+pct(sSapi,sapi||1)+'%</span></div><div class="progress-bar" style="height:10px"><div class="progress-fill purple" style="width:'+pct(sSapi,sapi||1)+'%"></div></div></div>';
