  html += '</select></div>';

  var colorItems = [{key:'primary',id:'themeColorPrimary',label:'Primary',desc:'Warna utama'},{key:'secondary',id:'themeColorSecondary',label:'Secondary',desc:'Warna sekunder'},{key:'accent',id:'themeColorAccent',label:'Accent',desc:'Warna aksen'},{key:'success',id:'themeColorSuccess',label:'Success',desc:'Warna sukses'},{key:'danger',id:'themeColorDanger',label:'Danger',desc:'Warna bahaya'}];
